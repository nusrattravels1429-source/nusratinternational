<%- include('partials/header', { pageTitle: 'About Us — Nusrat International', activePage: 'about', cssFiles: ['common.css', 'About_us.css'], bodyClass: '' }) %>

<!-- ================= HERO ================= -->
<section class="about-hero">

  <!-- Animated geometric background blobs -->
  <div class="about-hero-bg">
    <div class="hero-geo geo-1"></div>
    <div class="hero-geo geo-2"></div>
    <div class="hero-geo geo-3"></div>
  </div>

  <div class="about-hero-inner">

    <!-- Left: text -->
    <div class="about-hero-text">
      <span class="eyebrow">✦ <%= aboutContent['about-header']?.tagline_en || 'ABOUT US — আমাদের সম্পর্কে' %></span>
      <h1><%- aboutContent['about-header']?.page_title_en || 'Trusted For<br>Over <em>15 Years</em><br>Of Excellence' %></h1>
      <p><%= aboutContent['about-header']?.description_en || 'From the heart of Banani, Dhaka to destinations across the globe — Nusrat International has been Bangladesh\'s trusted name in travel, Hajj & Umrah, and international manpower recruitment since 2010.' %></p>
      <div class="hero-cta-row">
        <a href="#story" class="btn-about-primary">Our Story →</a>
        <a href="#contact" class="btn-about-ghost">Get In Touch</a>
      </div>
    </div>

    <!-- Right: floating credential cards orbiting logo -->
    <div class="about-hero-visual">
      <div class="credential-stack">

        <div class="cred-card top-left" data-delay="0">
          <span class="cred-icon">🏛</span>
          <div>
            <strong>BAIRA Member</strong>
            <small>Bangladesh Association of<br>International Recruiting Agencies</small>
          </div>
        </div>

        <div class="cred-card top-right" data-delay="1">
          <span class="cred-icon">✈</span>
          <div>
            <strong>IATA Accredited</strong>
            <small>International Air Transport<br>Association</small>
          </div>
        </div>

        <div class="cred-card bottom-left" data-delay="2">
          <span class="cred-icon">🏢</span>
          <div>
            <strong>ATAB Member</strong>
            <small>Association of Travel<br>Agents of Bangladesh</small>
          </div>
        </div>

        <div class="cred-card bottom-right" data-delay="3">
          <span class="cred-icon">📜</span>
          <div>
            <strong>Govt. Approved</strong>
            <small>Recruiting Agency<br>License No. RL-1429</small>
          </div>
        </div>

        <!-- Central logo circle -->
        <div class="cred-center">
          <img src="https://image2url.com/r2/default/images/1771964863151-2518979a-0fe0-4990-9a1a-9175b88e5ac8.jpg"
               alt="Nusrat International" onerror="this.src='https://picsum.photos/id/1018/200/200'">
          <span>Since 2010</span>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- ================= STATS STRIP ================= -->
<div class="about-stats">
  <div class="about-stat">
    <% 
      const raw1 = aboutContent['about-stats']?.stat1_value || '15+';
      const num1 = raw1.replace(/[^0-9]/g, '') || '0';
      const plus1 = raw1.replace(/[0-9]/g, '');
    %>
    <span class="as-num" data-target="<%= num1 %>">0</span><span class="as-plus"><%= plus1 %></span>
    <span class="as-label"><%= aboutContent['about-stats']?.stat1_label_en || 'Years in Business' %></span>
  </div>
  <div class="about-stat">
    <% 
      const raw2 = aboutContent['about-stats']?.stat2_value || '12000+';
      const num2 = raw2.replace(/[^0-9]/g, '') || '0';
      const plus2 = raw2.replace(/[0-9]/g, '');
    %>
    <span class="as-num" data-target="<%= num2 %>">0</span><span class="as-plus"><%= plus2 %></span>
    <span class="as-label"><%= aboutContent['about-stats']?.stat2_label_en || 'Clients Served' %></span>
  </div>
  <div class="about-stat">
    <% 
      const raw3 = aboutContent['about-stats']?.stat3_value || '5000+';
      const num3 = raw3.replace(/[^0-9]/g, '') || '0';
      const plus3 = raw3.replace(/[0-9]/g, '');
    %>
    <span class="as-num" data-target="<%= num3 %>">0</span><span class="as-plus"><%= plus3 %></span>
    <span class="as-label"><%= aboutContent['about-stats']?.stat3_label_en || 'Workers Placed Abroad' %></span>
  </div>
  <div class="about-stat">
    <% 
      const raw4 = aboutContent['about-stats']?.stat4_value || '98%';
      const num4 = raw4.replace(/[^0-9]/g, '') || '0';
      const plus4 = raw4.replace(/[0-9]/g, '');
    %>
    <span class="as-num" data-target="<%= num4 %>">0</span><span class="as-plus"><%= plus4 %></span>
    <span class="as-label"><%= aboutContent['about-stats']?.stat4_label_en || 'Visa Success Rate' %></span>
  </div>
</div>

<!-- ================= STORY SECTION ================= -->
<section class="story-section" id="story">
  <div class="story-inner">
    <!-- Side label column -->
    <div class="story-label-col">
      <div class="section-side-tag"><%= aboutContent['about-story']?.tag_en || 'OUR STORY' %></div>
      <div class="story-line"></div>
    </div>
 
    <!-- Content -->
    <div class="story-content">
      <h2><%- aboutContent['about-story']?.title_en || 'A Legacy Built on <em>Trust &amp; Integrity</em>' %></h2>
 
      <% if (aboutContent['about-story']?.content_en) { %>
        <div class="dynamic-story-content">
          <%- aboutContent['about-story'].content_en %>
        </div>
      <% } else { %>
        <p class="story-lead">Nusrat International was founded with a singular vision — to provide Bangladeshi families with safe, legal, and dignified pathways to opportunity abroad.</p>
        <p>What began as a humble travel agency in the commercial heart of Banani, Dhaka has grown into one of Bangladesh's most recognized names in two critical sectors: international manpower recruitment and travel services. Under the steady leadership of <strong>Alhaj Mohammad Zakir Hossain</strong>, the company has maintained an unwavering commitment to ethical practice, regulatory compliance, and genuine care for every client.</p>
        <p>Today, Nusrat International operates two distinct but complementary divisions — <strong>Nusrat International</strong> for manpower recruiting and <strong>Nusrat Travels</strong> for aviation and tour services — both operating from the same Banani address and guided by the same values that have defined the organization from day one.</p>
        <p>Our membership in BAIRA and ATAB, combined with IATA accreditation, reflects not just credentials on paper, but a lived commitment to operating with transparency, dignity, and care for every person who walks through our door.</p>
      <% } %>
 
      <% if (aboutContent['about-story']?.quote_en) { %>
        <div class="story-quote">
          <blockquote>"<%= aboutContent['about-story'].quote_en %>"</blockquote>
          <% if (aboutContent['about-story']?.citation_en) { %>
            <cite>— <%= aboutContent['about-story'].citation_en %></cite>
          <% } %>
        </div>
      <% } else if (!aboutContent['about-story']?.content_en) { %>
        <div class="story-quote">
          <blockquote>"Our mission has always been simple: to serve our clients as if they were our own family — with honesty, care, and full accountability."</blockquote>
          <cite>— Alhaj Mohammad Zakir Hossain, Proprietor</cite>
        </div>
      <% } %>
    </div>
  </div>
</section>

<!-- ================= TWO DIVISIONS ================= -->
<section class="divisions-section">
  <div class="divisions-inner">

    <div class="division-heading">
      <span class="eyebrow-center">✦ OUR TWO CORE DIVISIONS</span>
      <h2>Two Pillars of<br><em>One Trusted Name</em></h2>
    </div>

    <div class="divisions-grid">
      <!-- Division 1: Manpower -->
      <div class="division-card manpower">
        <div class="div-icon-row">
          <span class="div-icon">👷</span>
          <span class="div-badge">Govt. Approved · RL-1429</span>
        </div>
        <h3>Nusrat International</h3>
        <p class="div-tagline">Government Approved Recruiting Agency</p>
        <p>Specializing in the legal and ethical overseas recruitment of Bangladeshi workers, Nusrat International connects skilled, semi-skilled, and unskilled workers with verified employers across the Middle East, Asia, and Europe.</p>
        <ul class="div-features">
          <li>✔ BAIRA Registered Member</li>
          <li>✔ Government License No. RL-1429</li>
          <li>✔ Full visa documentation support</li>
          <li>✔ Pre-departure orientation &amp; guidance</li>
          <li>✔ Post-arrival employee welfare support</li>
        </ul>
        <a href="/work" class="div-btn">View Work Packages →</a>
      </div>

      <!-- Division 2: Travel -->
      <div class="division-card travel">
        <div class="div-icon-row">
          <span class="div-icon">✈</span>
          <span class="div-badge iata">IATA · ATAB Certified</span>
        </div>
        <h3>Nusrat Travels</h3>
        <p class="div-tagline">Government Approved Travel Agency</p>
        <p>As an IATA-accredited travel agency and active ATAB member, Nusrat Travels issues tickets for all major international airlines directly and provides full-service travel solutions for leisure, business, Hajj, and Umrah.</p>
        <ul class="div-features">
          <li>✔ IATA Accredited — direct airline ticketing</li>
          <li>✔ ATAB Member in good standing</li>
          <li>✔ Hajj &amp; Umrah packages</li>
          <li>✔ International &amp; domestic tour packages</li>
          <li>✔ Visa assistance for all destinations</li>
        </ul>
        <a href="/travel" class="div-btn travel-btn">View Travel Packages →</a>
      </div>
    </div>
  </div>
</section>

<!-- ================= LEADERSHIP ================= -->
<section class="leadership-section">
  <div class="leadership-inner">

    <% if (founder) { %>
    <!-- Left: visual card -->
    <div class="leadership-visual">
      <div class="leader-photo-frame">
        <% if (founder.photo?.url || founder.photo || founder.imageUrl) { %>
          <img src="<%= founder.photo?.url || founder.photo || founder.imageUrl %>" alt="<%= founder.name?.en || founder.name %>" style="width: 100%; height: 100%; object-fit: cover; border-radius: 12px; position: absolute; top: 0; left: 0;">
        <% } else { %>
          <div class="leader-photo-bg">
            <div class="leader-initials">FND</div>
          </div>
        <% } %>
        <div class="leader-name-plate">
          <strong><%= founder.name?.en || founder.name || 'Founder' %></strong>
          <span><%= founder.designation?.en || founder.designation || 'Proprietor & Founder' %></span>
        </div>
      </div>
      <div class="leader-credentials"></div>
    </div>

    <!-- Right: biography -->
    <div class="leadership-text">
      <div class="section-side-tag">LEADERSHIP</div>
      <h2>The Man Behind<br><em>The Mission</em></h2>

      <% 
        let bioText = '';
        if (typeof founder.bio === 'string') {
          bioText = founder.bio;
        } else if (founder.bio && typeof founder.bio === 'object') {
          bioText = founder.bio.en || '';
        }
        if (bioText) {
          bioText.split('\n').filter(p => p.trim()).forEach((paragraph, idx) => {
            if (idx === 0) {
      %>
          <p class="leader-lead"><%= paragraph %></p>
      <%    } else { %>
          <p><%= paragraph %></p>
      <%    }
          })
        } else {
      %>
        <p class="leader-lead">Founder bio information goes here.</p>
      <% } %>

      <% if (founder.quote?.en || founder.quote) { %>
      <div class="leader-quote">
        <span class="lq-mark">"</span>
        <p><%= founder.quote?.en || founder.quote %></p>
      </div>
      <% } %>
    </div>
    <% } else { %>
      <div class="leadership-text">
        <p>Founder profile is not currently available.</p>
      </div>
    <% } %>

  </div>
</section>



<%- include('partials/footer') %>

<!-- ================= JAVASCRIPT ================= -->
<script>
  // ---- NAVBAR scroll effect ----
const navbar = document.getElementById('navbar');
window.addEventListener('scroll', () => {
  navbar.classList.toggle('scrolled', window.scrollY > 50);
});

// ---- HAMBURGER MENU (top dropdown) ----
const hamburger = document.getElementById('hamburger');
const navLinks = document.getElementById('nav-links');
const navItems = navLinks.querySelectorAll('li');

function openMenu() {
  hamburger.classList.add('open');
  navLinks.classList.add('open');
  document.body.classList.add('menu-open');
  // Stagger each item sliding down
  navItems.forEach((item, i) => {
    item.style.transitionDelay = `${0.06 + i * 0.07}s`;
    // tiny delay to let the overlay start first
    setTimeout(() => item.classList.add('revealed'), 20);
  });
}

function closeMenu() {
  hamburger.classList.remove('open');
  navLinks.classList.remove('open');
  document.body.classList.remove('menu-open');
  navItems.forEach(item => {
    item.classList.remove('revealed');
    item.style.transitionDelay = '0s';
  });
}

hamburger.addEventListener('click', (e) => {
  e.stopPropagation();
  hamburger.classList.contains('open') ? closeMenu() : openMenu();
});

// Close when a nav link is clicked
document.querySelectorAll('.nav-links a').forEach(link => {
  link.addEventListener('click', closeMenu);
});

// Close when clicking outside
document.addEventListener('click', (e) => {
  if (navLinks.classList.contains('open') &&
      !navLinks.contains(e.target) &&
      !hamburger.contains(e.target)) {
    closeMenu();
  }
});

// ---- COUNTER ANIMATION ----
function animateCounter(el) {
  const target = +el.dataset.target;
  const duration = 2000;
  const steps = 60;
  const increment = target / steps;
  let current = 0;
  const timer = setInterval(() => {
    current = Math.min(current + increment, target);
    el.textContent = target >= 1000
      ? Math.floor(current).toLocaleString()
      : Math.floor(current);
    if (current >= target) clearInterval(timer);
  }, duration / steps);
}

const statsSection = document.querySelector('.about-stats');
let countersRan = false;
const statsObserver = new IntersectionObserver(entries => {
  if (entries[0].isIntersecting && !countersRan) {
    countersRan = true;
    document.querySelectorAll('.as-num').forEach(animateCounter);
    statsObserver.disconnect();
  }
}, { threshold: 0.3 });
if (statsSection) statsObserver.observe(statsSection);

// ---- TIMELINE REVEAL ----
const revealObserver = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
      revealObserver.unobserve(entry.target);
    }
  });
}, { threshold: 0.15 });
document.querySelectorAll('.tl-item.reveal').forEach(el => revealObserver.observe(el));

// ---- CONTACT FORM ----
function handleSubmit(e) {
  e.preventDefault();
  const s = document.getElementById('formSuccess');
  s.style.display = 'block';
  e.target.reset();
  setTimeout(() => s.style.display = 'none', 5000);
}
</script>

</body>
</html>
