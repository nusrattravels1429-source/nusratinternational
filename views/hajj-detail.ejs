<%
  // Support both old schema and new card schema
  const pkgTitle = pkg.title?.en || pkg.title_en || 'Hajj Package';
  const pkgTitleBn = pkg.title?.bn || pkg.title_bn || '';
  const pkgDesc = pkg.description?.en || pkg.desc_en || '';
  const pkgDescBn = pkg.description?.bn || pkg.desc_bn || '';
  const pkgPrice = pkg.pricing?.amount || pkg.price || '';
  const pkgCurrency = pkg.pricing?.currency || 'BDT';
  const pkgImages = (pkg.images && pkg.images.length > 0) ? pkg.images : (pkg.image ? [{ url: pkg.image }] : []);
  const heroImage = pkgImages.length > 0 ? pkgImages[0].url : 'https://picsum.photos/1600/900';
  const pkgLocation = pkg.location?.en || pkg.location || '';
%>
<%- include('partials/header', { pageTitle: pkgTitle + ' - Hajj Details', activePage: 'hajj', bodyClass: bodyClass }) %>

<div class="page-hero pkg-hero">
  <img class="hero-bg-img" src="<%= heroImage %>" alt="<%= pkgTitle %>" />
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <span class="type-badge">☪ HAJJ PACKAGE</span>
    <h1><%= pkgTitle %></h1>
    <p class="hero-sub"><%= pkgTitleBn %></p>
    <div class="hero-meta">
      <% if (pkg.duration) { %>
        <div class="hmeta"><span class="hi">⏱</span><div><small>Duration</small><b><%= pkg.duration %></b></div></div>
      <% } %>
      <% if (pkgLocation) { %>
        <div class="hmeta"><span class="hi">📍</span><div><small>Location</small><b><%= pkgLocation %></b></div></div>
      <% } %>
      <% if (pkgPrice) { %>
        <span class="price-pill"><%= pkgCurrency === 'USD' ? '$' : '৳' %><%= pkgPrice %></span>
      <% } %>
    </div>
  </div>
</div>

<div class="detail-wrap">
  <div class="left-col">

    <div class="sc">
      <div class="sc-head"><span>📋</span> About This Package</div>
      <p class="about-text"><%= pkgDesc %></p>
      <% if (pkgDescBn) { %><p class="about-text about-bn"><%= pkgDescBn %></p><% } %>
    </div>

    <% if (pkg.features && pkg.features.length > 0) { %>
    <div class="sc">
      <div class="sc-head"><span>✨</span> Package Inclusions</div>
      <ul class="features-list">
        <% pkg.features.forEach(f => { %>
          <li>✔ <%= f.en || f %></li>
        <% }); %>
      </ul>
    </div>
    <% } %>

    <% if (pkg.highlights && pkg.highlights.length > 0) { %>
    <div class="sc">
      <div class="sc-head"><span>🕋</span> Highlights</div>
      <div class="hl-grid">
        <% pkg.highlights.forEach(item => { %>
          <div class="hl-item"><span class="hl-icon"><%= item.icon %></span><div class="hl-text"><b><%= item.title %></b><span><%= item.desc %></span></div></div>
        <% }); %>
      </div>
    </div>
    <% } %>

    <% if (pkg.programme && pkg.programme.length > 0) { %>
    <div class="sc">
      <div class="sc-head"><span>🗓️</span> Program</div>
      <% pkg.programme.forEach(plan => { %>
        <div class="tl-item"><div class="tl-num">Day<br /><%= plan.day %></div><div class="tl-body"><h4><%= plan.title %></h4><p><%= plan.desc %></p></div></div>
      <% }); %>
    </div>
    <% } else { %>
    <div class="sc">
      <div class="sc-head"><span>🗓️</span> Program</div>
      <p>Complete schedule will be shared by our team after booking.</p>
    </div>
    <% } %>

    <!-- ===== PHOTO GALLERY ===== -->
    <% if (pkgImages.length > 1) { %>
    <div class="sc pkg-gallery-section">
      <div class="sc-head"><span>🖼️</span> Photo Gallery</div>
      <div class="pkg-gallery-grid">
        <% pkgImages.forEach((img, i) => { %>
          <div class="pkg-gallery-item" onclick="openLightbox('<%= img.url %>', '<%= pkgTitle %>')">
            <img src="<%= img.url %>" alt="<%= pkgTitle %> - Photo <%= i + 1 %>" loading="lazy" />
            <div class="pkg-gallery-overlay"><span>🔍 View Full</span></div>
          </div>
        <% }); %>
      </div>
    </div>
    <% } else if (pkgImages.length === 1) { %>
    <div class="sc pkg-gallery-section">
      <div class="sc-head"><span>🖼️</span> Package Image</div>
      <div class="pkg-gallery-grid single">
        <div class="pkg-gallery-item" onclick="openLightbox('<%= pkgImages[0].url %>', '<%= pkgTitle %>')">
          <img src="<%= pkgImages[0].url %>" alt="<%= pkgTitle %>" loading="lazy" />
          <div class="pkg-gallery-overlay"><span>🔍 View Full</span></div>
        </div>
      </div>
    </div>
    <% } %>

  </div>

  <div class="booking-sticky">
    <div class="booking-card">
      <div class="bk-hdr">
        <div class="bk-label">Starting from</div>
        <div class="bk-price"><%= pkgCurrency === 'USD' ? '$' : '৳' %><%= pkgPrice || 'Contact Us' %></div>
        <div class="bk-per">per person<%= pkg.duration ? ', ' + pkg.duration : '' %></div>
      </div>
      <div class="bk-body">
        <div class="bk-title">📝 Book This Package | বুকিং করুন</div>
        <div class="bf-2col"><div class="bf"><label>Full Name</label><input type="text" placeholder="Your full name" /></div><div class="bf"><label>Phone Number</label><input type="tel" placeholder="+880 XXXXXXXXX" /></div></div>
        <div class="bf"><label>Email Address</label><input type="email" placeholder="you@email.com" /></div>
        <div class="bf"><label>Special Requests</label><textarea rows="3" placeholder="Any special needs... | বিশেষ চাহিদা"></textarea></div>
        <button class="btn-book">Book Now | এখনই বুক করুন ☪</button>
      </div>
    </div>
  </div>
</div>

<!-- Lightbox Modal -->
<div id="lightboxModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.9); z-index:9999; align-items:center; justify-content:center; flex-direction:column;" onclick="closeLightbox()">
  <button onclick="closeLightbox()" style="position:absolute; top:20px; right:30px; background:none; border:none; color:white; font-size:36px; cursor:pointer; z-index:10000;">✕</button>
  <img id="lightboxImg" src="" alt="" style="max-width:90vw; max-height:85vh; border-radius:8px; object-fit:contain;" onclick="event.stopPropagation()">
  <p id="lightboxCaption" style="color:rgba(255,255,255,0.7); margin-top:12px; font-size:14px;"></p>
</div>

<style>
.pkg-gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 12px;
  margin-top: 16px;
}
.pkg-gallery-grid.single { grid-template-columns: 1fr; max-width: 500px; }
.pkg-gallery-item {
  position: relative;
  border-radius: 10px;
  overflow: hidden;
  cursor: pointer;
  aspect-ratio: 4/3;
}
.pkg-gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; display: block; }
.pkg-gallery-item:hover img { transform: scale(1.05); }
.pkg-gallery-overlay {
  position: absolute; inset: 0; background: rgba(0,0,0,0.4);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: opacity 0.3s ease; color: white; font-size: 14px; font-weight: 600;
}
.pkg-gallery-item:hover .pkg-gallery-overlay { opacity: 1; }
.features-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 10px; }
.features-list li { padding: 10px 16px; background: #f5f7ff; border-left: 3px solid #667eea; border-radius: 6px; font-size: 14px; color: #333; }
</style>

<script>
function openLightbox(url, caption) {
  const modal = document.getElementById('lightboxModal');
  document.getElementById('lightboxImg').src = url;
  document.getElementById('lightboxCaption').textContent = caption;
  modal.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}
function closeLightbox() {
  document.getElementById('lightboxModal').style.display = 'none';
  document.body.style.overflow = '';
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
</script>

<%- include('partials/footer') %>
