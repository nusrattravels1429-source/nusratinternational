<%- include('partials/header', { pageTitle: 'Our Team — Nusrat International', activePage: 'about', bodyClass: '' }) %>

<!-- PAGE HERO -->
<section class="page-hero team-hero">
  <div class="hero-bg-overlay"></div>
  <div class="hero-content-wrap">
    <span class="section-tag">👥 OUR PEOPLE</span>
    <h1>Meet Our <em>Team</em></h1>
    <p>The dedicated professionals behind every journey, placement, and pilgrimage.</p>
  </div>
</section>

<!-- FOUNDER'S MESSAGE SECTION -->
<section class="founder-message-section">
  <div class="container">
    <div class="founder-header">
      <span class="section-tag-small">FOUNDER'S MESSAGE</span>
      <h2>A Message from Our Founder</h2>
    </div>
    
    <div class="founder-content-wrapper">
      <div class="founder-profile-card">
        <div class="founder-image-wrapper">
          <div class="founder-initials">AZH</div>
          <img src="https://ui-avatars.com/api/?name=Zakir+Hossain&size=400&background=0D8ABC&color=fff" alt="Alhaj Mohammad Zakir Hossain" class="founder-img">
        </div>
        <div class="founder-info">
          <h3 class="founder-name">Alhaj Mohammad Zakir Hossain</h3>
          <p class="founder-title">Proprietor & Founder</p>
        </div>
      </div>

      <div class="founder-bio">
        <p>Alhaj Mohammad Zakir Hossain is the founder and proprietor of both Nusrat International and Nusrat Travels. A veteran of Bangladesh's travel and recruitment industry, he has built both organizations on a foundation of regulatory compliance, professional integrity, and deep personal dedication to his clients.</p>
        
        <p>His decision to pursue and maintain memberships in BAIRA and ATAB, alongside achieving IATA accreditation, reflects his belief that legitimacy and transparency are not optional — they are the foundation of any business that deals with people's livelihoods and dreams.</p>
        
        <p>Having performed Hajj himself, Alhaj Hossain brings a personal and spiritual understanding to the sacred journeys his company facilitates every year for thousands of Bangladeshi pilgrims. This personal connection gives Nusrat International's pilgrimage services a sincerity that clients immediately feel and trust.</p>
        
        <p>Under his leadership, the company has maintained a near-perfect visa approval record while placing thousands of workers in safe, legal, and dignified employment abroad — changing lives and supporting families across Bangladesh.</p>
        
        <div class="founder-quote">
          "Every client who walks through our door is someone's father, mother, or child. We carry that responsibility with the utmost seriousness — every single day."
        </div>
      </div>
    </div>
  </div>
</section>

<!-- EMPLOYEES -->
<main class="container">
  <div class="team-wrap">
    <div class="employees">
      <% if (typeof employees !== 'undefined' && employees.length > 0) { %>
        <% employees.forEach(emp => { %>
          <div class="employee-card">
            <div class="emp-image-wrap">
              <img src="<%= emp.image %>" alt="<%= emp.name %>">
            </div>
            <div class="emp-info">
              <h3 class="emp-name"><%= emp.name %></h3>
              <p class="emp-position"><%= emp.position %></p>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <!-- Default employees -->
        <div class="employee-card">
          <div class="emp-image-wrap">
            <img src="https://picsum.photos/300/300?1" alt="Md. Nusrat Ullah">
          </div>
          <div class="emp-info">
            <h3 class="emp-name">Md. Nusrat Ullah</h3>
            <p class="emp-position">Managing Director</p>
          </div>
        </div>
        <div class="employee-card">
          <div class="emp-image-wrap">
            <img src="https://picsum.photos/300/300?2" alt="Karim Hossain">
          </div>
          <div class="emp-info">
            <h3 class="emp-name">Karim Hossain</h3>
            <p class="emp-position">Travel Manager</p>
          </div>
        </div>
        <div class="employee-card">
          <div class="emp-image-wrap">
            <img src="https://picsum.photos/300/300?3" alt="Sultana Parvin">
          </div>
          <div class="emp-info">
            <h3 class="emp-name">Sultana Parvin</h3>
            <p class="emp-position">Ticketing Officer</p>
          </div>
        </div>
        <div class="employee-card">
          <div class="emp-image-wrap">
            <img src="https://picsum.photos/300/300?4" alt="Farhan Ahmed">
          </div>
          <div class="emp-info">
            <h3 class="emp-name">Farhan Ahmed</h3>
            <p class="emp-position">Travel Consultant</p>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
