      <div class="slide"><img src="https://picsum.photos/id/1018/1600/900" alt="Mountain Adventure"></div>
      <div class="slide"><img src="https://picsum.photos/id/1015/1600/900" alt="Beautiful Landscape"></div>
      <div class="slide"><img src="https://picsum.photos/id/1019/1600/900" alt="Ocean View"></div>
      <div class="slide"><img src="https://picsum.photos/id/1057/1600/900" alt="Forest Path"></div>
    <% } %>
  </div>

  <div class="overlay"></div>

  <div class="hero-content">
    <span class="hero-tag">✦ DISCOVER THE WORLD</span>
