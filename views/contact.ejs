<%- include('partials/header', { pageTitle: 'Contact Us', activePage: 'contact', bodyClass: '' }) %>

<!-- PAGE HERO -->
<section class="page-hero contact-hero">
  <div class="hero-bg-overlay"></div>
  <div class="hero-content-wrap">
    <span class="section-tag">📞 GET IN TOUCH</span>
    <h1>Contact Us<br><em>Today</em></h1>
    <p>Have questions about our services? We're here to help you 24/7.<br>আমাদের সাথে যোগাযোগ করুন — আমরা সবসময় আপনার সেবায় প্রস্তুত।</p>
  </div>
</section>

<!-- CONTACT SECTION -->
<main class="container">
  <section class="contact-section">
    <div class="contact-grid">
      <!-- Contact Info -->
      <div class="contact-info" id="contactInfoContainer">
        <h2>Contact Information</h2>

        <div class="contact-item">
          <h3>📞 Phone</h3>
          <div id="contact-phone-content">
            <p>Loading...</p>
          </div>
        </div>

        <div class="contact-item">
          <h3>💬 WhatsApp</h3>
          <div id="contact-whatsapp-content">
            <p>Loading...</p>
          </div>
        </div>

        <div class="contact-item">
          <h3>📧 Email</h3>
          <div id="contact-email-content">
            <p>Loading...</p>
          </div>
        </div>

        <div class="contact-item">
          <h3>📍 Address</h3>
          <div id="contact-address-content">
            <p>Loading...</p>
          </div>
        </div>

        <div class="contact-item">
          <h3>⏰ Business Hours</h3>
          <div id="contact-hours-content">
            <p>Loading...</p>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="contact-form-wrap">
        <h2>Send us a Message</h2>
        <form class="contact-form" id="contactForm">
          <div class="form-group">
            <label for="name">Your Name *</label>
            <input type="text" id="name" name="name" required placeholder="Full Name">
          </div>

          <div class="form-group">
            <label for="email">Your Email *</label>
            <input type="email" id="email" name="email" required placeholder="your@email.com">
          </div>

          <div class="form-group">
            <label for="phone">Your Phone *</label>
            <input type="tel" id="phone" name="phone" required placeholder="01700000000">
          </div>

          <div class="form-group">
            <label for="service">Service Interest *</label>
            <select id="service" name="service" required>
              <option value="">Select a service</option>
              <option value="travel">Travel Packages</option>
              <option value="hajj">Hajj & Umrah</option>
              <option value="work">Work Visa</option>
              <option value="ticketing">Air Ticketing</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Your Message *</label>
            <textarea id="message" name="message" required placeholder="Tell us how we can help..." rows="5"></textarea>
          </div>

          <button type="submit" class="btn-primary">Send Message</button>
          <p class="form-note" id="formMessage"></p>
        </form>
      </div>
    </div>
  </section>

</main>

<script>
document.getElementById('contactForm').addEventListener('submit', function(e) {
  e.preventDefault();

  const formMessage = document.getElementById('formMessage');
  const submitBtn = this.querySelector('button[type="submit"]');

  formMessage.textContent = 'Sending...';
  formMessage.style.color = '#0d9f6e';
  submitBtn.disabled = true;

  setTimeout(() => {
    formMessage.textContent = 'Thank you! We will contact you soon.';
    formMessage.style.color = '#0d9f6e';
    this.reset();
    submitBtn.disabled = false;

document.getElementById('contactForm').addEventListener('submit', function(e) {
  e.preventDefault();

  const formMessage = document.getElementById('formMessage');
  const submitBtn = this.querySelector('button[type="submit"]');

  formMessage.textContent = 'Sending...';
  formMessage.style.color = '#0d9f6e';
  submitBtn.disabled = true;

  setTimeout(() => {
    formMessage.textContent = 'Thank you! We will contact you soon.';
    formMessage.style.color = '#0d9f6e';
    this.reset();
    submitBtn.disabled = false;

    setTimeout(() => {
      formMessage.textContent = '';
    }, 5000);
  }, 1000);
});

// Dynamically load contact info from admin settings
document.addEventListener('DOMContentLoaded', async () => {
  try {
    const res = await window.fetch('/api/public/footer');
    const json = await res.json();
    if(json.success && json.data) {
      const d = json.data;
      
      // Update Phone (split by comma if multiple)
      if (d.phone) {
        const phones = d.phone.split(',').map(p => p.trim()).filter(p => p);
        if (phones.length > 0) {
          document.getElementById('contact-phone-content').innerHTML = phones.map(p => `<p><a href="tel:${p}">${p}</a></p>`).join('');
        } else {
          document.getElementById('contact-phone-content').innerHTML = '<p>Not available</p>';
        }
      } else {
        document.getElementById('contact-phone-content').innerHTML = '<p>Not available</p>';
      }

      // Update WhatsApp
      if (d.whatsapp) {
        // Strip everything but numbers and '+'
        const waClean = d.whatsapp.replace(/[^\d+]/g, '');
        document.getElementById('contact-whatsapp-content').innerHTML = `<p><a href="https://wa.me/${waClean}" target="_blank" rel="noopener">${d.whatsapp}</a></p>`;
      } else {
        document.getElementById('contact-whatsapp-content').innerHTML = '<p>Not available</p>';
      }

      // Update Email
      if (d.email) {
        document.getElementById('contact-email-content').innerHTML = `<p><a href="mailto:${d.email}">${d.email}</a></p>`;
      } else {
        document.getElementById('contact-email-content').innerHTML = '<p>Not available</p>';
      }

      // Update Address
      if (d.address && (d.address.en || d.address.bn)) {
        document.getElementById('contact-address-content').innerHTML = `<p>${(d.address.en || d.address.bn).replace(/\n/g, '<br>')}</p>`;
      } else {
        document.getElementById('contact-address-content').innerHTML = '<p>Not available</p>';
      }

      // Update Business Hours
      if (d.businessHours) {
        const days = ['mon','tue','wed','thu','fri','sat','sun'];
        const labels = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
        let hoursHtml = '';
        days.forEach((day, index) => {
          const bh = d.businessHours[day];
          if (bh) {
            if (bh.closed) {
              hoursHtml += `<p>${labels[index]}: Closed</p>`;
            } else {
              hoursHtml += `<p>${labels[index]}: ${bh.open} - ${bh.close}</p>`;
            }
          }
        });
        document.getElementById('contact-hours-content').innerHTML = hoursHtml;
      } else {
        document.getElementById('contact-hours-content').innerHTML = '<p>Not available</p>';
      }
    }
  } catch(err) {
    console.error('Failed to load dynamic contact details:', err);
  }
});
</script>

<%- include('partials/footer') %>
