<%- include('partials/header', { pageTitle: 'Contact Us', activePage: 'contact', bodyClass: '' }) %>

<!-- PAGE HERO -->
<section class="page-hero contact-hero">
  <div class="hero-bg-overlay"></div>
  <div class="hero-content-wrap">
    <span class="section-tag">📞 GET IN TOUCH</span>
    <h1>Contact Us<br><em>Today</em></h1>
    <p>Have questions about our services? We're here to help you 24/7.<br>আমাদের সাথে যোগাযোগ করুন — আমরা সবসময় আপনার সেবায় প্রস্তুত।</p>
  </div>
</section>

<!-- CONTACT SECTION -->
<main class="container">
  <section class="contact-section">
    <div class="contact-grid">
      <!-- Contact Info -->
      <div class="contact-info" id="contactInfoContainer">
        <h2>Contact Information</h2>

        <div class="contact-item">
          <h3>📞 Phone</h3>
          <div id="contact-phone-content">
            <% if (pageContent?.phone_primary) { %>
              <p><a href="tel:<%= pageContent.phone_primary %>"><%= pageContent.phone_primary %></a></p>
            <% } %>
            <% if (pageContent?.phone_secondary) { %>
              <p><a href="tel:<%= pageContent.phone_secondary %>"><%= pageContent.phone_secondary %></a></p>
            <% } %>
            <% if (!pageContent?.phone_primary && !pageContent?.phone_secondary) { %>
              <p>Not available</p>
            <% } %>
          </div>
        </div>

        <div class="contact-item">
          <h3>💬 WhatsApp</h3>
          <div id="contact-whatsapp-content">
            <% if (pageContent?.whatsapp_link) { %>
              <p><a href="<%= pageContent.whatsapp_link %>" target="_blank" rel="noopener">Chat on WhatsApp</a></p>
            <% } else { %>
              <p>Not available</p>
            <% } %>
          </div>
        </div>

        <div class="contact-item">
          <h3>📧 Email</h3>
          <div id="contact-email-content">
            <% if (pageContent?.email_address) { %>
              <p><a href="mailto:<%= pageContent.email_address %>"><%= pageContent.email_address %></a></p>
            <% } else { %>
              <p>Not available</p>
            <% } %>
          </div>
        </div>

        <div class="contact-item">
          <h3>📍 Address</h3>
          <div id="contact-address-content">
            <% if (pageContent?.address_en) { %>
              <p><%- pageContent.address_en.replace(/\n/g, '<br>') %></p>
            <% } else { %>
              <p>Banani Super Market,<br>Banani, Dhaka 1213<br>Bangladesh</p>
            <% } %>
          </div>
        </div>

        <div class="contact-item">
          <h3>⏰ Business Hours</h3>
          <div id="contact-hours-content">
            <% if (pageContent?.hours_en) { %>
              <p><%- pageContent.hours_en.replace(/\n/g, '<br>') %></p>
            <% } else { %>
              <p>Monday - Friday: 9:00 AM - 6:00 PM<br>Saturday: 9:00 AM - 2:00 PM<br>Sunday: Closed</p>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="contact-form-wrap">
        <h2>Send us a Message</h2>
        <form class="contact-form" id="contactForm">
          <div class="form-group">
            <label for="name">Your Name *</label>
            <input type="text" id="name" name="name" required placeholder="Full Name">
          </div>

          <div class="form-group">
            <label for="email">Your Email</label>
            <input type="email" id="email" name="email" placeholder="your@email.com">
          </div>

          <div class="form-group">
            <label for="phone">Your Phone</label>
            <input type="tel" id="phone" name="phone" placeholder="01700000000">
            <small style="font-size: 11px; color: #6b7280; display: block; margin-top: 4px;">* At least one of Email or Phone is required</small>
          </div>

          <div class="form-group">
            <label for="service">Service Interest *</label>
            <select id="service" name="service" required>
              <option value="">Select a service</option>
              <option value="travel">Travel Packages</option>
              <option value="hajj">Hajj & Umrah</option>
              <option value="work">Work Visa</option>
              <option value="ticketing">Air Ticketing</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Your Message *</label>
            <textarea id="message" name="message" required placeholder="Tell us how we can help..." rows="5"></textarea>
          </div>

          <button type="submit" class="btn-primary">Send Message</button>
          <p class="form-note" id="formMessage"></p>
        </form>
      </div>
    </div>
  </section>

</main>

<script>
document.getElementById('contactForm').addEventListener('submit', function(e) {
  e.preventDefault();

  const email = document.getElementById('email').value.trim();
  const phone = document.getElementById('phone').value.trim();
  const formMessage = document.getElementById('formMessage');
  const submitBtn = this.querySelector('button[type="submit"]');

  if (!email && !phone) {
    formMessage.textContent = 'Please provide either your Email or Phone number so we can reach you.';
    formMessage.style.color = '#ef4444';
    return;
  }

  formMessage.textContent = 'Sending...';
  formMessage.style.color = '#0d9f6e';
  submitBtn.disabled = true;

  const data = {
    name: document.getElementById('name').value,
    email: email,
    phone: phone,
    service: document.getElementById('service').value,
    message: document.getElementById('message').value,
    source: 'Contact Page'
  };

  fetch('/api/public/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  })
  .then(res => res.json())
  .then(res => {
    if (res.success) {
      formMessage.textContent = 'Thank you! Your message has been sent successfully.';
      formMessage.style.color = '#0d9f6e';
      this.reset();
    } else {
      formMessage.textContent = res.message || 'Error sending message.';
      formMessage.style.color = '#ef4444';
    }
  })
  .catch(err => {
    formMessage.textContent = 'An error occurred. Please try again.';
    formMessage.style.color = '#ef4444';
  })
  .finally(() => {
    submitBtn.disabled = false;
    setTimeout(() => { formMessage.textContent = ''; }, 5000);
  });
});
</script>

<%- include('partials/footer') %>
