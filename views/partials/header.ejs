<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Nusrat International | Travel, Hajj & Manpower Recruitment' %></title>
  
  <!-- SEO Meta Tags -->
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Nusrat International is a leading travel agency in Bangladesh specializing in International Ticketing, Hajj & Umrah packages, and Global Manpower Recruitment.' %>" />
  <meta name="keywords" content="<%= typeof metaKeywords !== 'undefined' ? metaKeywords : 'Nusrat International, Travel Agency Bangladesh, Hajj Package 2024, Umrah Package, Manpower Recruitment, BAIRA RL-1429, Work Visa, Flight Booking' %>" />
  <meta name="author" content="Nusrat International" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://nusratinternational.com<%= typeof activePath !== 'undefined' ? activePath : '' %>" />
  <link rel="icon" type="image/jpg" href="https://image2url.com/r2/default/images/1771964863151-2518979a-0fe0-4990-9a1a-9175b88e5ac8.jpg" />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://nusratinternational.com" />
  <meta property="og:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle : 'Nusrat International | Travel, Hajj & Manpower Recruitment' %>" />
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Nusrat International is a leading travel agency in Bangladesh specializing in International Ticketing, Hajj & Umrah packages, and Global Manpower Recruitment.' %>" />
  <meta property="og:image" content="https://image2url.com/r2/default/images/1771964863151-2518979a-0fe0-4990-9a1a-9175b88e5ac8.jpg" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content="https://nusratinternational.com" />
  <meta property="twitter:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle : 'Nusrat International | Travel, Hajj & Manpower Recruitment' %>" />
  <meta property="twitter:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Nusrat International is a leading travel agency in Bangladesh specializing in International Ticketing, Hajj & Umrah packages, and Global Manpower Recruitment.' %>" />
  <meta property="twitter:image" content="https://image2url.com/r2/default/images/1771964863151-2518979a-0fe0-4990-9a1a-9175b88e5ac8.jpg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <% cssFiles.forEach(file => { %>
  <link rel="stylesheet" href="/css/<%= file %>" />
  <% }) %>
</head>
<body class="<%= bodyClass || '' %>">
<nav id="navbar">
  <div class="nav-inner">
    <div class="logo">
      <a href="/">
        <img src="https://image2url.com/r2/default/images/1771964863151-2518979a-0fe0-4990-9a1a-9175b88e5ac8.jpg" alt="Nusrat International Logo" id="header-logo-img" onerror="this.style.display='none'" />
        <div class="logo-text"><span id="header-logo-text">Nusrat International</span></div>
      </a>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Toggle menu"><span></span><span></span><span></span></button>

    <ul class="nav-links" id="nav-links">
      <div id="dynamic-links-container" style="display: contents;">
        <!-- STATIC FALLBACK -->
        <li><a href="/" class="<%= activePage==='home' ? 'active' : '' %>">Home</a></li>
        <li><a href="/ticketing">Ticketing</a></li>
        <li><a href="/travel" class="<%= activePage==='travel' ? 'active' : '' %>">Travel</a></li>
        <li><a href="/hajj" class="<%= activePage==='hajj' ? 'active' : '' %>">Hajj</a></li>
        <li><a href="/work" class="<%= activePage==='work' ? 'active' : '' %>">Work</a></li>
        <li><a href="/contact" class="<%= activePage==='contact' ? 'active' : '' %>">Contact</a></li>
      </div>

      <!-- PERMANENT ABOUT DROPDOWN -->
      <li class="has-dropdown" id="aboutDropdown">
        <button class="dropdown-trigger" aria-haspopup="true" aria-expanded="false">About <span class="drop-arrow">▾</span></button>
        <ul class="dropdown-menu" role="menu">
          <li role="none"><a href="/about"><span class="dm-text"><strong>About Us</strong><small>Our story & leadership</small></span></a></li>
          <li role="none"><a href="/gallery"><span class="dm-text"><strong>Gallery</strong><small>Photos & memories</small></span></a></li>
          <li role="none"><a href="/employees"><span class="dm-text"><strong>Our Team</strong><small>Meet our employees</small></span></a></li>
          <li role="none"><a href="/certifications"><span class="dm-text"><strong>Approvals & Certifications</strong><small>BAIRA · IATA · ATAB · RL-1429</small></span></a></li>
        </ul>
      </li>
    </ul>
  </div>
</nav>

<script>
  // Dynamically load Navigation Bar links
  document.addEventListener("DOMContentLoaded", async () => {
    try {
      const res = await window.fetch('/api/public/navbar');
      const json = await res.json();
      if(json.success && json.data) {
        // Update Branding
        if (json.data.headerLogoUrl) {
          document.getElementById('header-logo-img').src = json.data.headerLogoUrl;
        }
        if (json.data.logoText) {
          document.getElementById('header-logo-text').innerHTML = (json.data.logoText.en || '') + (json.data.logoText.bn ? `<br />${json.data.logoText.bn}` : '');
        }

        // Update Links
        if (json.data.items && json.data.items.length > 0) {
          const dynamicContainer = document.getElementById('dynamic-links-container');
          dynamicContainer.innerHTML = ''; // Clear fallback
          
          json.data.items.forEach(item => {
            const li = document.createElement('li');
            const a = document.createElement('a');
            a.href = item.link;
            if (item.isExternal) a.target = '_blank';
            
            // Determine if active
            const currentPath = window.location.pathname;
            if (currentPath === item.link || (item.link !== '/' && currentPath.startsWith(item.link))) {
               a.className = 'active';
               // Also support legacy activePage if defined
               if ('<%= typeof activePage !== "undefined" ? activePage : "" %>' === item.link.replace('/','')) {
                   a.className = 'active';
               }
            }
            
            a.innerHTML = item.label.en + (item.label.bn ? ` | ${item.label.bn}` : '');
            li.appendChild(a);
            dynamicContainer.appendChild(li);
          });
        }
      }
    } catch(err) {
      console.warn('Failed to dynamically load navbar, using static fallback.', err);
    }
  });
</script>
