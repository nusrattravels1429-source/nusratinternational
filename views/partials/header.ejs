<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle || 'Nusrat International' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <% cssFiles.forEach(file => { %>
  <link rel="stylesheet" href="/css/<%= file %>" />
  <% }) %>
</head>
<body class="<%= bodyClass || '' %>">
<nav id="navbar">
  <div class="nav-inner">
    <div class="logo">
      <a href="/">
        <img src="https://image2url.com/r2/default/images/1771964863151-2518979a-0fe0-4990-9a1a-9175b88e5ac8.jpg" alt="Nusrat International Logo" onerror="this.style.display='none'" />
        <div class="logo-text"><span>Nusrat International <br /> Nusrat Travels</span></div>
      </a>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Toggle menu"><span></span><span></span><span></span></button>

    <ul class="nav-links" id="nav-links">
      <!-- STATIC FALLBACK -->
      <li><a href="/" class="<%= activePage==='home' ? 'active' : '' %>">Home | হোম</a></li>
      <li><a href="/ticketing">Ticketing | ভ্রমণ</a></li>
      <li><a href="/travel" class="<%= activePage==='travel' ? 'active' : '' %>">Travel | ভ্রমণ</a></li>
      <li><a href="/hajj" class="<%= activePage==='hajj' ? 'active' : '' %>">Hajj | হাজ্জ</a></li>
      <li><a href="/work" class="<%= activePage==='work' ? 'active' : '' %>">Work | কাজ</a></li>
      <li><a href="/contact" class="<%= activePage==='contact' ? 'active' : '' %>">Contact | যোগাযোগ</a></li>
    </ul>
  </div>
</nav>

<script>
  // Dynamically load Navigation Bar links
  document.addEventListener("DOMContentLoaded", async () => {
    try {
      const res = await window.fetch('/api/public/navbar');
      const json = await res.json();
      if(json.success && json.data && json.data.length > 0) {
        const navList = document.getElementById('nav-links');
        navList.innerHTML = ''; // Clear fallback
        
        json.data.forEach(item => {
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = item.link;
          if (item.isExternal) a.target = '_blank';
          
          // Determine if active
          const currentPath = window.location.pathname;
          if (currentPath === item.link || (item.link !== '/' && currentPath.startsWith(item.link))) {
             a.className = 'active';
             // Also support legacy activePage if defined
             if ('<%= typeof activePage !== "undefined" ? activePage : "" %>' === item.link.replace('/','')) {
                 a.className = 'active';
             }
          }
          
          a.innerHTML = item.label.en + (item.label.bn ? ` | ${item.label.bn}` : '');
          li.appendChild(a);
          navList.appendChild(li);
        });
      }
    } catch(err) {
      console.warn('Failed to dynamically load navbar, using static fallback.', err);
    }
  });
</script>
