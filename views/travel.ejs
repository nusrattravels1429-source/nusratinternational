<%- include('partials/header', { pageTitle: 'Travel Packages — Nusrat International', activePage: 'travel', bodyClass: '', cssFiles: ['Travel.css', 'common.css', 'cards.css', 'contact.css'] }) %>

<div class="page-hero">
  <span class="section-tag">✈ EXPLORE THE WORLD</span>
  <h1>All Traveling<br /><em>Packages</em></h1>
  <p>সকল ট্র্যাভেল প্যাকেজ — Discover your perfect destination from our full collection.</p>
</div>

<main>
  <section class="package-section" id="travel">
    
    <div class="container">
      <% if (packages && packages.length > 0) { %>
        <% packages.forEach(pkg => { %>
          <%- include('partials/card', { pkg: pkg, type: 'travel' }) %>
        <% }); %>
      <% } else { %>
        <p class="no-packages">No travel packages are available at the moment.</p>
      <% } %>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
