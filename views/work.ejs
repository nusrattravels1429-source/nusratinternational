<%- include('partials/header', { pageTitle: 'Work Packages', activePage: 'work', bodyClass: '' }) %>

<div class="page-hero work-hero">
  <div class="hero-badge">💼 WORK ABROAD</div>
  <h1>International Work<br /><em>Packages</em></h1>
  <p>বিদেশে কর্মসংস্থানের সুযোগ — Build your future with our trusted overseas job placements.</p>
  <div class="hero-stats">
    <div class="h-stat"><span>5,000+</span><small>Workers Placed</small></div>
    <div class="h-stat"><span>15+</span><small>Countries</small></div>
    <div class="h-stat"><span>98%</span><small>Visa Success</small></div>
  </div>
</div>

<main>
  <div class="container" id="packagesGrid">
    <% if (packages && packages.length > 0) { %>
      <% packages.forEach(pkg => { %>
        <div class="pkg-card work-card">
          <div class="pkg-img-wrap">
            <img src="<%= pkg.image %>" alt="<%= pkg.title_en %>" />
            <div class="pkg-price">$<%= pkg.price %></div>
            <div class="pkg-duration"><%= pkg.duration %></div>
            <% if (pkg.location) { %><div class="work-badge"><%= pkg.location %></div><% } %>
          </div>
          <div class="pkg-body">
            <div class="pkg-top">
              <div><h3><%= pkg.title_en %></h3><h4><%= pkg.title_bn || '' %></h4></div>
              <span class="rating">★ <%= pkg.rating || 0 %></span>
            </div>
            <p class="pkg-desc"><%= pkg.desc_en %></p>
            <a href="/work/<%= pkg._id %>"><button class="view-btn green">View Details | বিস্তারিত দেখুন</button></a>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <p>No work packages are available at the moment.</p>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
