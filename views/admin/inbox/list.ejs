<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/css/common.css">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'DM Sans', sans-serif; background: #f0f2f8; color: #1a1f2e; }
    .admin-layout { display: flex; min-height: 100vh; }
    .main-content { flex: 1; padding: 30px; overflow-x: hidden; }

    .page-header {
      background: linear-gradient(135deg, #1a56db 0%, #1e429f 100%);
      border-radius: 16px;
      padding: 24px 32px;
      margin-bottom: 28px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: white;
      box-shadow: 0 8px 30px rgba(26, 86, 219, 0.3);
    }
    .page-header h1 { font-size: 24px; font-weight: 700; }

    .inbox-card {
      background: white;
      border-radius: 16px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.05);
      overflow: hidden;
    }

    .table-container { width: 100%; overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; min-width: 900px; }
    th { background: #f9fafb; padding: 16px 24px; text-align: left; font-size: 13px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid #edf2f7; }
    td { padding: 16px 24px; border-bottom: 1px solid #edf2f7; vertical-align: middle; }

    .msg-item { transition: background 0.2s; cursor: pointer; }
    .msg-item:hover { background: #f8fafc; }
    .msg-item.unread { background: #f0f7ff; font-weight: 600; }
    .msg-item.unread:hover { background: #e1effe; }

    .user-info { display: flex; flex-direction: column; }
    .user-name { color: #1a1f2e; font-size: 14px; margin-bottom: 2px; }
    .user-contact { color: #6b7280; font-size: 12px; font-weight: 400; }

    .msg-preview { color: #4b5563; font-size: 14px; max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .msg-source { display: inline-block; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
    .source-contact { background: #e1effe; color: #1e429f; }
    .source-travel { background: #def7ec; color: #03543f; }
    .source-hajj { background: #fef3c7; color: #92400e; }
    .source-work { background: #e5edff; color: #3f83f8; }

    .msg-date { color: #9ca3af; font-size: 12px; }
    
    .actions { display: flex; gap: 10px; }
    .btn-action { width: 32px; height: 32px; border-radius: 8px; border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; }
    .btn-view { background: #f3f4f6; color: #4b5563; }
    .btn-view:hover { background: #e5e7eb; color: #1a1f2e; }
    .btn-delete { background: #fef2f2; color: #ef4444; }
    .btn-delete:hover { background: #fee2e2; color: #b91c1c; }

    /* Modal Styles */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); z-index: 9999; display: none; align-items: center; justify-content: center; padding: 20px; }
    .modal { background: white; width: 100%; max-width: 600px; max-height: 90vh; border-radius: 20px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); overflow: hidden; animation: slideUp 0.3s ease; display: flex; flex-direction: column; }
    @keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    
    .modal-header { padding: 24px; border-bottom: 1px solid #f3f4f6; display: flex; justify-content: space-between; align-items: center; }
    .modal-header h3 { font-size: 18px; color: #1a1f2e; }
    .close-modal { background: none; border: none; font-size: 24px; color: #9ca3af; cursor: pointer; }

    .modal-body { padding: 24px; overflow-y: auto; flex: 1; }
    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
    .info-item label { display: block; font-size: 12px; color: #9ca3af; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 1px; }
    .info-item span { font-size: 15px; color: #1a1f2e; font-weight: 500; }
    .info-item a { color: #1a56db; text-decoration: none; }
    
    .full-message { background: #f9fafb; padding: 20px; border-radius: 12px; border: 1px solid #f3f4f6; margin-bottom: 24px; line-height: 1.6; color: #374151; white-space: pre-wrap; }
    
    .pkg-context { background: #eff6ff; padding: 12px 16px; border-radius: 8px; border-left: 4px solid #1a56db; font-size: 14px; margin-bottom: 20px; }
    .pkg-context strong { color: #1e429f; }

    .modal-footer { padding: 20px 24px; background: #f9fafb; display: flex; justify-content: flex-end; gap: 12px; }
    .btn-secondary { padding: 10px 20px; border-radius: 8px; border: 1px solid #e5e7eb; background: white; color: #4b5563; font-weight: 600; cursor: pointer; }
    .btn-primary { padding: 10px 20px; border-radius: 8px; border: none; background: #1a56db; color: white; font-weight: 600; cursor: pointer; }

    .empty-state { padding: 80px 20px; text-align: center; }
    .empty-icon { font-size: 64px; margin-bottom: 20px; opacity: 0.3; }
    .empty-text { font-size: 18px; color: #9ca3af; }

    @media (max-width: 768px) {
      .main-content { padding: 15px; }
      .info-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="admin-layout">
    <%- include('../partials/sidebar', { admin: admin, activePage: 'inbox' }) %>

    <main class="main-content">
      <div class="page-header">
        <h1>📥 Message Inbox</h1>
        <div class="stats-pills">
          <span style="background: rgba(255,255,255,0.2); padding: 6px 16px; border-radius: 30px; font-size: 13px;">
            Total Messages: <%= messages.length %>
          </span>
        </div>
      </div>

      <div class="inbox-card">
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Sender</th>
                <th>Message Preview</th>
                <th>Source</th>
                <th>Date & Time</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (messages.length > 0) { %>
                <% messages.forEach(msg => { %>
                  <tr class="msg-item <%= msg.isRead ? '' : 'unread' %>" 
                      id="msg-row-<%= msg._id %>" 
                      data-msg='<%= JSON.stringify(msg).replace(/'/g, "&#39;") %>'
                      onclick="viewMessage(this)">
                    <td>
                      <div class="user-info">
                        <span class="user-name"><%= msg.name %></span>
                        <span class="user-contact"><%= msg.phone || msg.email %></span>
                      </div>
                    </td>
                    <td>
                      <p class="msg-preview"><%= msg.message %></p>
                    </td>
                    <td>
                      <% 
                        let sourceClass = 'source-other';
                        if (msg.source === 'Contact Page') sourceClass = 'source-contact';
                        else if (msg.source === 'Travel Page') sourceClass = 'source-travel';
                        else if (msg.source === 'Hajj Page') sourceClass = 'source-hajj';
                        else if (msg.source === 'Work Page') sourceClass = 'source-work';
                      %>
                      <span class="msg-source <%= sourceClass %>"><%= msg.source %></span>
                    </td>
                    <td>
                      <span class="msg-date">
                        <%= new Date(msg.createdAt).toLocaleDateString() %><br>
                        <%= new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
                      </span>
                    </td>
                    <td>
                      <div class="actions" onclick="event.stopPropagation()">
                        <button class="btn-action btn-delete" onclick="deleteMessage('<%= msg._id %>')" title="Delete">🗑️</button>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="5">
                    <div class="empty-state">
                      <div class="empty-icon">📫</div>
                      <div class="empty-text">Your inbox is empty. No messages yet.</div>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <!-- Message Detail Modal -->
  <div class="modal-overlay" id="modalOverlay" onclick="closeModal()">
    <div class="modal" onclick="event.stopPropagation()">
      <div class="modal-header">
        <h3 id="m-sender-name">Message Detail</h3>
        <button class="close-modal" onclick="closeModal()">×</button>
      </div>
      <div class="modal-body">
        <div id="m-pkg-context" class="pkg-context" style="display:none;">
          Interested in: <strong id="m-pkg-name"></strong>
        </div>

        <div class="info-grid">
          <div class="info-item">
            <label>Phone Number</label>
            <span id="m-phone"></span>
          </div>
          <div class="info-item">
            <label>Email Address</label>
            <span id="m-email"></span>
          </div>
          <div class="info-item">
            <label>Source</label>
            <span id="m-source"></span>
          </div>
          <div class="info-item">
            <label>Date Received</label>
            <span id="m-date"></span>
          </div>
        </div>

        <label style="display:block; font-size:12px; color:#9ca3af; margin-bottom:8px; text-transform:uppercase; letter-spacing:1px;">Message Content</label>
        <div class="full-message" id="m-body"></div>
        
        <div class="info-item" style="margin-top: 10px;">
          <label>Service/Topic</label>
          <span id="m-service"></span>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn-secondary" onclick="closeModal()">Close</button>
        <a id="m-call-btn" href="#" class="btn-primary" style="text-decoration:none;">📞 Call User</a>
      </div>
    </div>
  </div>

  <script>
    let currentMsgId = null;

    function viewMessage(row) {
      const msg = JSON.parse(row.dataset.msg);
      currentMsgId = msg._id;

      // Update Modal content
      document.getElementById('m-sender-name').textContent = msg.name;
      document.getElementById('m-phone').textContent = msg.phone || 'N/A';
      document.getElementById('m-email').textContent = msg.email || 'N/A';
      document.getElementById('m-source').textContent = msg.source;
      document.getElementById('m-service').textContent = msg.service;
      document.getElementById('m-date').textContent = new Date(msg.createdAt).toLocaleString();
      document.getElementById('m-body').textContent = msg.message;
      
      const pkgContext = document.getElementById('m-pkg-context');
      if (msg.metadata && msg.metadata.packageName) {
        pkgContext.style.display = 'block';
        document.getElementById('m-pkg-name').textContent = msg.metadata.packageName;
      } else {
        pkgContext.style.display = 'none';
      }

      const callBtn = document.getElementById('m-call-btn');
      if (msg.phone) {
        callBtn.href = 'tel:' + msg.phone;
        callBtn.style.display = 'inline-block';
      } else {
        callBtn.style.display = 'none';
      }

      // Show modal
      document.getElementById('modalOverlay').style.display = 'flex';

      // Mark as read in DB if unread
      if (!msg.isRead) {
        fetch('/admin/inbox/read/' + msg._id, { method: 'POST' })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              document.getElementById('msg-row-' + msg._id).classList.remove('unread');
              if (typeof updateUnreadCount === 'function') updateUnreadCount();
            }
          });
      }
    }

    function closeModal() {
      document.getElementById('modalOverlay').style.display = 'none';
    }

    function deleteMessage(id) {
      if (confirm('Are you sure you want to delete this message?')) {
        fetch('/admin/inbox/delete/' + id, { method: 'POST' })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              document.getElementById('msg-row-' + id).remove();
              if (typeof updateUnreadCount === 'function') updateUnreadCount();
            }
          });
      }
    }
  </script>
</body>
</html>
