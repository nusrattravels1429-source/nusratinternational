<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .inbox-card {
      border-radius: 24px;
      overflow: hidden;
      margin-top: 20px;
    }

    .table-container { width: 100%; overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; min-width: 900px; color: var(--text-main); }
    th { background: rgba(255, 255, 255, 0.05); padding: 20px 24px; text-align: left; font-size: 13px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid var(--glass-border); }
    td { padding: 20px 24px; border-bottom: 1px solid var(--glass-border); vertical-align: middle; }

    .msg-item { transition: all 0.3s ease; cursor: pointer; }
    .msg-item:hover { background: rgba(255, 255, 255, 0.05); }
    .msg-item.unread { background: rgba(99, 102, 241, 0.1); font-weight: 600; border-left: 4px solid var(--primary-color); }
    .msg-item.unread:hover { background: rgba(99, 102, 241, 0.15); }

    .user-info { display: flex; flex-direction: column; }
    .user-name { color: var(--text-main); font-size: 15px; font-weight: 700; margin-bottom: 4px; }
    .user-contact { color: var(--text-muted); font-size: 13px; }

    .msg-preview { color: var(--text-muted); font-size: 14px; max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .msg-source { display: inline-block; padding: 6px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
    .source-contact { background: rgba(6, 182, 212, 0.2); color: #06b6d4; }
    .source-travel { background: rgba(16, 185, 129, 0.2); color: #10b981; }
    .source-hajj { background: rgba(245, 158, 11, 0.2); color: #f59e0b; }
    .source-work { background: rgba(99, 102, 241, 0.2); color: #6366f1; }

    .msg-date { color: var(--text-muted); font-size: 12px; line-height: 1.4; }
    
    .actions { display: flex; gap: 10px; }

    /* Modal Premium Styles */
    .modal-overlay { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(12px); z-index: 9999; display: none; align-items: center; justify-content: center; padding: 20px; }
    .modal { background: #1e293b; width: 100%; max-width: 650px; max-height: 90vh; border-radius: 30px; border: 1px solid var(--glass-border); box-shadow: 0 30px 60px -12px rgba(0,0,0,0.5); overflow: hidden; animation: slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; }
    @keyframes slideUp { from { transform: translateY(40px) scale(0.95); opacity: 0; } to { transform: translateY(0) scale(1); opacity: 1; } }
    
    .modal-header { padding: 32px; border-bottom: 1px solid var(--glass-border); display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.02); }
    .modal-header h3 { font-size: 22px; font-weight: 800; color: white; }
    .close-modal { background: rgba(255,255,255,0.05); border: none; width: 40px; height: 40px; border-radius: 12px; font-size: 24px; color: var(--text-muted); cursor: pointer; transition: all 0.3s; display: flex; align-items: center; justify-content: center; }
    .close-modal:hover { background: var(--error-color); color: white; }

    .modal-body { padding: 32px; overflow-y: auto; flex: 1; }
    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px; }
    .info-item label { display: block; font-size: 11px; color: var(--text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; }
    .info-item span { font-size: 16px; color: white; font-weight: 600; }
    .info-item a { color: var(--primary-color); text-decoration: none; }
    
    .full-message { background: rgba(15, 23, 42, 0.5); padding: 24px; border-radius: 20px; border: 1px solid var(--glass-border); margin-bottom: 32px; line-height: 1.8; color: #e2e8f0; font-size: 15px; white-space: pre-wrap; }
    
    .pkg-context { background: rgba(99, 102, 241, 0.15); padding: 16px 24px; border-radius: 16px; border-left: 4px solid var(--primary-color); font-size: 15px; margin-bottom: 28px; color: #e0e7ff; }
    .pkg-context strong { color: white; font-weight: 800; }

    .modal-footer { padding: 24px 32px; border-top: 1px solid var(--glass-border); background: rgba(255,255,255,0.02); display: flex; justify-content: flex-end; gap: 16px; }
    .btn-secondary { background: rgba(255,255,255,0.05); color: white; }
    .btn-secondary:hover { background: rgba(255,255,255,0.1); }

    .empty-state { padding: 100px 40px; text-align: center; }
    .empty-icon { font-size: 72px; margin-bottom: 24px; opacity: 0.2; }
    .empty-text { font-size: 20px; color: var(--text-muted); font-weight: 500; }
  </style>
</head>
<body>
  <div class="admin-layout">
    <%- include('../partials/sidebar', { admin: admin, activePage: 'inbox' }) %>

    <main class="main-content">
      <div class="page-header">
        <div>
          <h1>Message Inbox</h1>
          <p>You have <strong><%= messages.filter(m => !m.isRead).length %></strong> unread messages out of <%= messages.length %> total.</p>
        </div>
      </div>

      <div class="inbox-card glass-card">
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Sender</th>
                <th>Message Preview</th>
                <th>Source</th>
                <th>Date & Time</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (messages.length > 0) { %>
                <% messages.forEach(msg => { %>
                  <tr class="msg-item <%= msg.isRead ? '' : 'unread' %>" 
                      id="msg-row-<%= msg._id %>" 
                      data-msg='<%= JSON.stringify(msg).replace(/'/g, "&#39;") %>'
                      onclick="viewMessage(this)">
                    <td>
                      <div class="user-info">
                        <span class="user-name"><%= msg.name %></span>
                        <span class="user-contact"><%= msg.phone || msg.email %></span>
                      </div>
                    </td>
                    <td>
                      <p class="msg-preview"><%= msg.message %></p>
                    </td>
                    <td>
                      <% 
                        let sourceClass = 'source-other';
                        if (msg.source === 'Contact Page') sourceClass = 'source-contact';
                        else if (msg.source === 'Travel Page') sourceClass = 'source-travel';
                        else if (msg.source === 'Hajj Page') sourceClass = 'source-hajj';
                        else if (msg.source === 'Work Page') sourceClass = 'source-work';
                      %>
                      <span class="msg-source <%= sourceClass %>"><%= msg.source %></span>
                    </td>
                    <td>
                      <span class="msg-date">
                        <%= new Date(msg.createdAt).toLocaleDateString() %><br>
                        <%= new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
                      </span>
                    </td>
                    <td>
                      <div class="actions" onclick="event.stopPropagation()">
                        <button class="btn-action btn-delete" onclick="deleteMessage('<%= msg._id %>')" title="Delete">🗑️</button>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="5">
                    <div class="empty-state">
                      <div class="empty-icon">📫</div>
                      <div class="empty-text">Your inbox is empty. No messages yet.</div>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <!-- Message Detail Modal -->
  <div class="modal-overlay" id="modalOverlay" onclick="closeModal()">
    <div class="modal" onclick="event.stopPropagation()">
      <div class="modal-header">
        <h3 id="m-sender-name">Message Detail</h3>
        <button class="close-modal" onclick="closeModal()">×</button>
      </div>
      <div class="modal-body">
        <div id="m-pkg-context" class="pkg-context" style="display:none;">
          Interested in: <strong id="m-pkg-name"></strong>
        </div>

        <div class="info-grid">
          <div class="info-item">
            <label>Phone Number</label>
            <span id="m-phone"></span>
          </div>
          <div class="info-item">
            <label>Email Address</label>
            <span id="m-email"></span>
          </div>
          <div class="info-item">
            <label>Source</label>
            <span id="m-source"></span>
          </div>
          <div class="info-item">
            <label>Date Received</label>
            <span id="m-date"></span>
          </div>
        </div>

        <label style="display:block; font-size:12px; color:#9ca3af; margin-bottom:8px; text-transform:uppercase; letter-spacing:1px;">Message Content</label>
        <div class="full-message" id="m-body"></div>
        
        <div class="info-item" style="margin-top: 10px;">
          <label>Service/Topic</label>
          <span id="m-service"></span>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn-secondary" onclick="closeModal()">Close</button>
        <a id="m-call-btn" href="#" class="btn-primary" style="text-decoration:none;">📞 Call User</a>
      </div>
    </div>
  </div>

  <script>
    let currentMsgId = null;

    function viewMessage(row) {
      const msg = JSON.parse(row.dataset.msg);
      currentMsgId = msg._id;

      // Update Modal content
      document.getElementById('m-sender-name').textContent = msg.name;
      document.getElementById('m-phone').textContent = msg.phone || 'N/A';
      document.getElementById('m-email').textContent = msg.email || 'N/A';
      document.getElementById('m-source').textContent = msg.source;
      document.getElementById('m-service').textContent = msg.service;
      document.getElementById('m-date').textContent = new Date(msg.createdAt).toLocaleString();
      document.getElementById('m-body').textContent = msg.message;
      
      const pkgContext = document.getElementById('m-pkg-context');
      if (msg.metadata && msg.metadata.packageName) {
        pkgContext.style.display = 'block';
        document.getElementById('m-pkg-name').textContent = msg.metadata.packageName;
      } else {
        pkgContext.style.display = 'none';
      }

      const callBtn = document.getElementById('m-call-btn');
      if (msg.phone) {
        callBtn.href = 'tel:' + msg.phone;
        callBtn.style.display = 'inline-block';
      } else {
        callBtn.style.display = 'none';
      }

      // Show modal
      document.getElementById('modalOverlay').style.display = 'flex';

      // Mark as read in DB if unread
      if (!msg.isRead) {
        fetch('/admin/inbox/read/' + msg._id, { method: 'POST' })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              document.getElementById('msg-row-' + msg._id).classList.remove('unread');
              if (typeof updateUnreadCount === 'function') updateUnreadCount();
            }
          });
      }
    }

    function closeModal() {
      document.getElementById('modalOverlay').style.display = 'none';
    }

    function deleteMessage(id) {
      if (confirm('Are you sure you want to delete this message?')) {
        fetch('/admin/inbox/delete/' + id, { method: 'POST' })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              document.getElementById('msg-row-' + id).remove();
              if (typeof updateUnreadCount === 'function') updateUnreadCount();
            }
          });
      }
    }
  </script>
</body>
</html>
