<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Team Management - Admin</title>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .panel { padding: 32px; margin-bottom: 32px; }
    .panel-title { font-size: 18px; font-weight: 800; color: white; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--glass-border); display: flex; justify-content: space-between; align-items: center; letter-spacing: -0.5px; }
    
    /* Founder section */
    .founder-layout { display: grid; grid-template-columns: 200px 1fr; gap: 40px; }
    .founder-photo-col { text-align: center; }
    .founder-photo { width: 180px; height: 180px; border-radius: 50%; object-fit: cover; border: 4px solid var(--primary-color); display: block; margin: 0 auto 20px; box-shadow: 0 0 20px var(--primary-glow); }
    .founder-photo-placeholder { width: 180px; height: 180px; border-radius: 50%; background: linear-gradient(135deg, var(--primary-color), var(--secondary-color)); display: flex; align-items: center; justify-content: center; font-size: 56px; margin: 0 auto 20px; color: white; box-shadow: 0 0 20px var(--primary-glow); }
    .founder-tag { background: linear-gradient(135deg, #f59e0b, #d97706); color: white; font-size: 11px; font-weight: 800; padding: 6px 14px; border-radius: 20px; text-transform: uppercase; letter-spacing: 1px; }

    /* Employees grid */
    .employees-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 24px; }
    .employee-card { border-radius: 24px; padding: 32px; text-align: center; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); border: 1px solid var(--glass-border); }
    .employee-card:hover { transform: translateY(-10px); border-color: var(--primary-color); box-shadow: 0 20px 40px -15px var(--primary-glow); }
    .employee-photo { width: 100px; height: 100px; border-radius: 50%; object-fit: cover; border: 3px solid var(--glass-border); display: block; margin: 0 auto 16px; transition: all 0.4s; }
    .employee-card:hover .employee-photo { border-color: var(--primary-color); transform: scale(1.1); }
    .employee-photo-placeholder { width: 100px; height: 100px; border-radius: 50%; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; font-size: 36px; margin: 0 auto 16px; color: var(--text-muted); }
    .employee-name { font-size: 16px; font-weight: 800; color: white; }
    .employee-designation { font-size: 13px; color: var(--primary-color); margin-top: 6px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
    .employee-actions { display: flex; justify-content: center; gap: 10px; margin-top: 20px; }
    .employee-actions .btn { padding: 8px 16px; font-size: 12px; }

    .add-form-panel { display: none; margin-bottom: 32px; }
    .add-form-panel.open { display: block; animation: slideDown 0.4s ease; }
    @keyframes slideDown { from { transform: translateY(-20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    /* Edit Modal Premium Styles */
    .modal-overlay { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(12px); z-index: 9999; display: none; align-items: center; justify-content: center; padding: 20px; }
    .modal { background: #1e293b; width: 100%; max-width: 550px; max-height: 90vh; border-radius: 30px; border: 1px solid var(--glass-border); box-shadow: 0 30px 60px -12px rgba(0,0,0,0.5); overflow-y: auto; padding: 40px; animation: slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
  </style>
</head>
<body>
<div class="admin-layout">
  <%- include('../partials/sidebar', { admin, activePage: 'team' }) %>

    <div class="main-content">
      <div class="page-header">
        <div>
          <h1>Team Management</h1>
          <p>Manage your company's leadership and team members.</p>
        </div>
        <a href="/admin/dashboard" class="btn btn-primary">← Dashboard</a>
      </div>

      <!-- ===== FOUNDER SECTION ===== -->
      <div class="panel glass-card">
        <div class="panel-title">
          <span>Leadership / Founder</span>
          <span class="founder-tag">Protected</span>
        </div>
      <form action="/admin/team/founder" method="POST" enctype="multipart/form-data">
        <div class="founder-layout">
          <div class="founder-photo-col">
            <% if (founder?.photo?.url) { %>
              <img src="<%= founder.photo.url %>" alt="Founder" class="founder-photo">
            <% } else { %>
              <div class="founder-photo-placeholder">👤</div>
            <% } %>
            <input type="hidden" name="existingPhoto" value="<%= founder?.photo?.url || '' %>">
            <div class="form-group" style="text-align:left;">
              <label>Replace Photo</label>
              <input type="file" name="image" class="form-control" accept="image/*">
            </div>
          </div>
          <div>
            <div class="form-row">
              <div class="form-group">
                <label>Name (English)</label>
                <input type="text" name="nameEn" value="<%= founder?.name?.en || '' %>" class="form-control" placeholder="Founder's full name" required>
              </div>
              <div class="form-group">
                <label>Name (বাংলা)</label>
                <input type="text" name="nameBn" value="<%= founder?.name?.bn || '' %>" class="form-control" placeholder="প্রতিষ্ঠাতার নাম">
              </div>
              <div class="form-group">
                <label>Designation (English)</label>
                <input type="text" name="designationEn" value="<%= founder?.designation?.en || '' %>" class="form-control" placeholder="Founder & CEO">
              </div>
              <div class="form-group">
                <label>Designation (বাংলা)</label>
                <input type="text" name="designationBn" value="<%= founder?.designation?.bn || '' %>" class="form-control" placeholder="প্রতিষ্ঠাতা ও সিইও">
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Bio / About (English)</label>
                <textarea name="bioEn" class="form-control"><%= founder?.bio?.en || '' %></textarea>
              </div>
              <div class="form-group">
                <label>Bio / About (বাংলা)</label>
                <textarea name="bioBn" class="form-control"><%= founder?.bio?.bn || '' %></textarea>
              </div>
              <div class="form-group">
                <label>Quote / Message (English)</label>
                <textarea name="quoteEn" class="form-control"><%= founder?.quote?.en || '' %></textarea>
              </div>
              <div class="form-group">
                <label>Quote / Message (বাংলা)</label>
                <textarea name="quoteBn" class="form-control"><%= founder?.quote?.bn || '' %></textarea>
              </div>
            </div>
            <div class="form-row" style="grid-template-columns:1fr 1fr 1fr;">
              <div class="form-group">
                <label>Facebook URL</label>
                <input type="text" name="facebook" value="<%= founder?.socialLinks?.facebook || '' %>" class="form-control" placeholder="https://facebook.com/...">
              </div>
              <div class="form-group">
                <label>LinkedIn URL</label>
                <input type="text" name="linkedin" value="<%= founder?.socialLinks?.linkedin || '' %>" class="form-control">
              </div>
              <div class="form-group">
                <label>Twitter/X URL</label>
                <input type="text" name="twitter" value="<%= founder?.socialLinks?.twitter || '' %>" class="form-control">
              </div>
            </div>
            <button type="submit" class="btn btn-primary">💾 Save Founder Info</button>
          </div>
        </div>
      </form>
    </div>

      <!-- ===== EMPLOYEES SECTION ===== -->
      <div class="panel glass-card">
        <div class="panel-title">
          <span>Our Team Members (<%= employees.length %>)</span>
          <button class="btn btn-primary btn-sm" onclick="toggleAddForm()">+ Add New Member</button>
        </div>

      <!-- Add Form -->
      <div class="add-form-panel" id="addFormPanel">
        <div style="background:#f8faff;border:1.5px solid #e2e8f0;border-radius:10px;padding:20px;margin-bottom:20px;">
          <h4 style="margin-bottom:16px;color:#374151;">Add New Employee</h4>
          <form action="/admin/team/create" method="POST" enctype="multipart/form-data">
            <div class="form-row">
              <div class="form-group">
                <label>Name (English) *</label>
                <input type="text" name="nameEn" class="form-control" placeholder="Employee name" required>
              </div>
              <div class="form-group">
                <label>Name (বাংলা)</label>
                <input type="text" name="nameBn" class="form-control" placeholder="কর্মীর নাম">
              </div>
              <div class="form-group">
                <label>Designation (English) *</label>
                <input type="text" name="designationEn" class="form-control" placeholder="e.g. Travel Consultant" required>
              </div>
              <div class="form-group">
                <label>Designation (বাংলা)</label>
                <input type="text" name="designationBn" class="form-control">
              </div>
              <div class="form-group">
                <label>Photo</label>
                <input type="file" name="image" class="form-control" accept="image/*">
              </div>
              <div class="form-group">
                <label>Display Order</label>
                <input type="number" name="order" value="0" class="form-control">
              </div>
            </div>
            <div style="display:flex;gap:10px;">
              <button type="submit" class="btn btn-primary">💾 Add Employee</button>
              <button type="button" class="btn btn-secondary" onclick="toggleAddForm()">Cancel</button>
            </div>
          </form>
        </div>
      </div>

      <!-- List -->
      <% if (employees && employees.length > 0) { %>
        <div class="employees-grid">
          <% employees.forEach(function(emp) { %>
          <div class="employee-card glass-card">
            <% if (emp.photo?.url) { %>
              <img src="<%= emp.photo.url %>" alt="<%= emp.name?.en %>" class="employee-photo">
            <% } else { %>
              <div class="employee-photo-placeholder">👤</div>
            <% } %>
            <div class="employee-name"><%= emp.name?.en || 'Unnamed' %></div>
            <div class="employee-designation"><%= emp.designation?.en || '—' %></div>
            <div class="employee-actions">
              <button class="btn btn-sm btn-secondary" onclick="openEditModal('<%= emp._id %>', '<%= (emp.name?.en || '').replace(/'/g, '\\\'') %>', '<%= (emp.name?.bn || '').replace(/'/g, '\\\'') %>', '<%= (emp.designation?.en || '').replace(/'/g, '\\\'') %>', '<%= (emp.designation?.bn || '').replace(/'/g, '\\\'') %>', '<%= emp.photo?.url || '' %>', <%= emp.order || 0 %>)">Edit</button>
              <button class="btn btn-sm btn-danger" onclick="deleteMember('<%= emp._id %>')">Delete</button>
            </div>
          </div>
          <% }); %>
        </div>
      <% } else { %>
      <div class="empty-state">
        <div style="font-size:32px;">👨‍💼</div>
        <p style="color:#94a3b8;margin-top:8px;">No employees added yet. Click "Add Employee" to start.</p>
      </div>
      <% } %>
    </div>
  </main>
</div>

<!-- Edit Modal -->
<div id="editModal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:999;align-items:center;justify-content:center;">
  <div style="background:white;border-radius:12px;padding:28px;width:90%;max-width:520px;max-height:90vh;overflow-y:auto;">
    <h3 style="margin-bottom:20px;">✏️ Edit Employee</h3>
    <form id="editForm" method="POST" enctype="multipart/form-data">
      <div class="form-row">
        <div class="form-group">
          <label>Name (English)</label>
          <input type="text" id="editNameEn" name="nameEn" class="form-control">
        </div>
        <div class="form-group">
          <label>Name (বাংলা)</label>
          <input type="text" id="editNameBn" name="nameBn" class="form-control">
        </div>
        <div class="form-group">
          <label>Designation (English)</label>
          <input type="text" id="editDesigEn" name="designationEn" class="form-control">
        </div>
        <div class="form-group">
          <label>Designation (বাংলা)</label>
          <input type="text" id="editDesigBn" name="designationBn" class="form-control">
        </div>
        <div class="form-group">
          <label>Display Order</label>
          <input type="number" id="editOrder" name="order" class="form-control">
        </div>
      </div>
      <div id="currentPhotoWrap" style="margin-bottom:12px;"></div>
      <input type="hidden" id="editExistingPhoto" name="existingPhoto">
      <div class="form-group">
        <label>Replace Photo (optional)</label>
        <input type="file" name="image" class="form-control" accept="image/*">
      </div>
      <div style="display:flex;gap:10px;margin-top:12px;">
        <button type="submit" class="btn btn-primary">💾 Save Changes</button>
        <button type="button" class="btn btn-secondary" onclick="closeEditModal()">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
  function toggleAddForm() {
    const panel = document.getElementById('addFormPanel');
    panel.classList.toggle('open');
  }

  function openEditModal(id, nameEn, nameBn, desigEn, desigBn, photoUrl, order) {
    document.getElementById('editForm').action = '/admin/team/update/' + id;
    document.getElementById('editNameEn').value = nameEn;
    document.getElementById('editNameBn').value = nameBn;
    document.getElementById('editDesigEn').value = desigEn;
    document.getElementById('editDesigBn').value = desigBn;
    document.getElementById('editOrder').value = order;
    document.getElementById('editExistingPhoto').value = photoUrl;
    document.getElementById('currentPhotoWrap').innerHTML = photoUrl
      ? `<img src="${photoUrl}" style="height:70px;width:70px;border-radius:50%;object-fit:cover;border:3px solid #e2e8f0;">`
      : '';
    document.getElementById('editModal').style.display = 'flex';
  }

  function closeEditModal() {
    document.getElementById('editModal').style.display = 'none';
  }

  function deleteMember(id) {
    if (!confirm('Delete this team member? This cannot be undone.')) return;
    fetch('/admin/team/delete/' + id, { method: 'POST' })
      .then(r => r.json())
      .then(d => {
        if (d.success) location.reload();
        else alert('Error: ' + (d.error || 'Failed to delete'));
      })
      .catch(() => alert('Network error'));
  }
</script>
</body>
</html>
