<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Team Management - Admin</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: #f0f2f5; color: #333; }
    .admin-layout { display: flex; min-height: 100vh; }
    .sidebar { width: 250px; background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); color: white; padding: 0; position: fixed; height: 100vh; overflow-y: auto; z-index: 100; }
    .sidebar-header { padding: 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.1); text-align: center; }
    .sidebar-logo { font-size: 36px; margin-bottom: 8px; }
    .sidebar-header h2 { font-size: 16px; font-weight: 700; color: #e2e8f0; }
    .admin-name { font-size: 12px; color: rgba(255,255,255,0.5); margin-top: 4px; }
    .sidebar-menu { list-style: none; padding: 12px 0; }
    .sidebar-menu .menu-label { font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.35); padding: 16px 20px 6px; }
    .sidebar-menu .menu-separator { height: 1px; background: rgba(255,255,255,0.1); margin: 12px 20px; }
    .sidebar-menu a { display: flex; align-items: center; gap: 10px; padding: 10px 20px; color: rgba(255,255,255,0.7); text-decoration: none; font-size: 13.5px; transition: all 0.2s; border-left: 3px solid transparent; }
    .sidebar-menu a:hover { background: rgba(255,255,255,0.08); color: white; border-left-color: #667eea; }
    .sidebar-menu a.active { background: rgba(102,126,234,0.2); color: white; border-left-color: #667eea; font-weight: 600; }
    .logout-link:hover { background: rgba(239,68,68,0.2) !important; color: #fca5a5 !important; }
    .main-content { flex: 1; margin-left: 250px; padding: 28px; }
    .page-header { background: white; padding: 20px 28px; border-radius: 12px; margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
    .page-header h1 { font-size: 22px; font-weight: 700; color: #1a1a2e; }
    .breadcrumb { font-size: 13px; color: #94a3b8; }
    .panel { background: white; border-radius: 12px; padding: 28px; margin-bottom: 24px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
    .panel-title { font-size: 16px; font-weight: 700; color: #1a1a2e; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 2px solid #f0f2f5; display: flex; justify-content: space-between; align-items: center; }
    .btn { padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; transition: all 0.2s; }
    .btn-primary { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; }
    .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
    .btn-secondary { background: #f1f5f9; color: #475569; }
    .btn-danger { background: #fee2e2; color: #dc2626; }
    .btn-sm { padding: 7px 14px; font-size: 12px; }
    .form-control { width: 100%; padding: 10px 14px; border: 1.5px solid #e2e8f0; border-radius: 8px; font-size: 14px; font-family: inherit; transition: border-color 0.2s; background: #fafafa; }
    .form-control:focus { outline: none; border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,0.12); background: white; }
    textarea.form-control { min-height: 90px; resize: vertical; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    /* Founder section */
    .founder-layout { display: grid; grid-template-columns: 180px 1fr; gap: 28px; }
    .founder-photo-col { text-align: center; }
    .founder-photo { width: 160px; height: 160px; border-radius: 50%; object-fit: cover; border: 4px solid #667eea; display: block; margin: 0 auto 12px; }
    .founder-photo-placeholder { width: 160px; height: 160px; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); display: flex; align-items: center; justify-content: center; font-size: 48px; margin: 0 auto 12px; color: white; }
    .founder-tag { background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #78350f; font-size: 11px; font-weight: 700; padding: 4px 12px; border-radius: 20px; display: inline-block; }

    /* Employees grid */
    .employees-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
    .employee-card { background: #f8faff; border: 1.5px solid #e2e8f0; border-radius: 10px; padding: 20px; text-align: center; transition: all 0.2s; }
    .employee-card:hover { border-color: #667eea; box-shadow: 0 4px 16px rgba(102,126,234,0.12); }
    .employee-photo { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 3px solid #e2e8f0; display: block; margin: 0 auto 12px; }
    .employee-photo-placeholder { width: 80px; height: 80px; border-radius: 50%; background: #e2e8f0; display: flex; align-items: center; justify-content: center; font-size: 28px; margin: 0 auto 12px; }
    .employee-name { font-size: 14px; font-weight: 700; color: #1a1a2e; }
    .employee-designation { font-size: 12px; color: #667eea; margin-top: 4px; }
    .employee-actions { display: flex; justify-content: center; gap: 8px; margin-top: 14px; }

    .add-form-panel { display: none; }
    .add-form-panel.open { display: block; }
    .empty-state { text-align: center; padding: 40px 20px; color: #94a3b8; }
  </style>
</head>
<body>
<div class="admin-layout">
  <%- include('../partials/sidebar', { admin, activePage: 'team' }) %>

  <main class="main-content">
    <div class="page-header">
      <div>
        <h1>👥 Team Management</h1>
        <p class="breadcrumb">Admin → Team (<%= employees.length %> employees)</p>
      </div>
      <a href="/admin/dashboard" class="btn btn-secondary">← Dashboard</a>
    </div>

    <!-- ===== FOUNDER SECTION ===== -->
    <div class="panel">
      <div class="panel-title">
        <span>👑 Founder / Leadership</span>
        <span class="founder-tag">Protected Record</span>
      </div>
      <form action="/admin/team/founder" method="POST" enctype="multipart/form-data">
        <div class="founder-layout">
          <div class="founder-photo-col">
            <% if (founder?.photo?.url) { %>
              <img src="<%= founder.photo.url %>" alt="Founder" class="founder-photo">
            <% } else { %>
              <div class="founder-photo-placeholder">👤</div>
            <% } %>
            <input type="hidden" name="existingPhoto" value="<%= founder?.photo?.url || '' %>">
            <div class="form-group" style="text-align:left;">
              <label>Replace Photo</label>
              <input type="file" name="image" class="form-control" accept="image/*">
            </div>
          </div>
          <div>
            <div class="form-row">
              <div class="form-group">
                <label>Name (English)</label>
                <input type="text" name="nameEn" value="<%= founder?.name?.en || '' %>" class="form-control" placeholder="Founder's full name" required>
              </div>
              <div class="form-group">
                <label>Name (বাংলা)</label>
                <input type="text" name="nameBn" value="<%= founder?.name?.bn || '' %>" class="form-control" placeholder="প্রতিষ্ঠাতার নাম">
              </div>
              <div class="form-group">
                <label>Designation (English)</label>
                <input type="text" name="designationEn" value="<%= founder?.designation?.en || '' %>" class="form-control" placeholder="Founder & CEO">
              </div>
              <div class="form-group">
                <label>Designation (বাংলা)</label>
                <input type="text" name="designationBn" value="<%= founder?.designation?.bn || '' %>" class="form-control" placeholder="প্রতিষ্ঠাতা ও সিইও">
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Bio / About (English)</label>
                <textarea name="bioEn" class="form-control"><%= founder?.bio?.en || '' %></textarea>
              </div>
              <div class="form-group">
                <label>Bio / About (বাংলা)</label>
                <textarea name="bioBn" class="form-control"><%= founder?.bio?.bn || '' %></textarea>
              </div>
              <div class="form-group">
                <label>Quote / Message (English)</label>
                <textarea name="quoteEn" class="form-control"><%= founder?.quote?.en || '' %></textarea>
              </div>
              <div class="form-group">
                <label>Quote / Message (বাংলা)</label>
                <textarea name="quoteBn" class="form-control"><%= founder?.quote?.bn || '' %></textarea>
              </div>
            </div>
            <div class="form-row" style="grid-template-columns:1fr 1fr 1fr;">
              <div class="form-group">
                <label>Facebook URL</label>
                <input type="text" name="facebook" value="<%= founder?.socialLinks?.facebook || '' %>" class="form-control" placeholder="https://facebook.com/...">
              </div>
              <div class="form-group">
                <label>LinkedIn URL</label>
                <input type="text" name="linkedin" value="<%= founder?.socialLinks?.linkedin || '' %>" class="form-control">
              </div>
              <div class="form-group">
                <label>Twitter/X URL</label>
                <input type="text" name="twitter" value="<%= founder?.socialLinks?.twitter || '' %>" class="form-control">
              </div>
            </div>
            <button type="submit" class="btn btn-primary">💾 Save Founder Info</button>
          </div>
        </div>
      </form>
    </div>

    <!-- ===== EMPLOYEES SECTION ===== -->
    <div class="panel">
      <div class="panel-title">
        <span>👨‍💼 Employees (<%= employees.length %>)</span>
        <button class="btn btn-primary btn-sm" onclick="toggleAddForm()">+ Add Employee</button>
      </div>

      <!-- Add Form -->
      <div class="add-form-panel" id="addFormPanel">
        <div style="background:#f8faff;border:1.5px solid #e2e8f0;border-radius:10px;padding:20px;margin-bottom:20px;">
          <h4 style="margin-bottom:16px;color:#374151;">Add New Employee</h4>
          <form action="/admin/team/create" method="POST" enctype="multipart/form-data">
            <div class="form-row">
              <div class="form-group">
                <label>Name (English) *</label>
                <input type="text" name="nameEn" class="form-control" placeholder="Employee name" required>
              </div>
              <div class="form-group">
                <label>Name (বাংলা)</label>
                <input type="text" name="nameBn" class="form-control" placeholder="কর্মীর নাম">
              </div>
              <div class="form-group">
                <label>Designation (English) *</label>
                <input type="text" name="designationEn" class="form-control" placeholder="e.g. Travel Consultant" required>
              </div>
              <div class="form-group">
                <label>Designation (বাংলা)</label>
                <input type="text" name="designationBn" class="form-control">
              </div>
              <div class="form-group">
                <label>Photo</label>
                <input type="file" name="image" class="form-control" accept="image/*">
              </div>
              <div class="form-group">
                <label>Display Order</label>
                <input type="number" name="order" value="0" class="form-control">
              </div>
            </div>
            <div style="display:flex;gap:10px;">
              <button type="submit" class="btn btn-primary">💾 Add Employee</button>
              <button type="button" class="btn btn-secondary" onclick="toggleAddForm()">Cancel</button>
            </div>
          </form>
        </div>
      </div>

      <!-- List -->
      <% if (employees && employees.length > 0) { %>
      <div class="employees-grid">
        <% employees.forEach(function(emp) { %>
        <div class="employee-card">
          <% if (emp.photo?.url) { %>
            <img src="<%= emp.photo.url %>" alt="<%= emp.name?.en %>" class="employee-photo">
          <% } else { %>
            <div class="employee-photo-placeholder">👤</div>
          <% } %>
          <div class="employee-name"><%= emp.name?.en || 'Unnamed' %></div>
          <div class="employee-designation"><%= emp.designation?.en || '—' %></div>
          <div class="employee-actions">
            <button class="btn btn-sm btn-secondary" onclick="openEditModal('<%= emp._id %>', '<%= (emp.name?.en || '').replace(/'/g, '\\\'') %>', '<%= (emp.name?.bn || '').replace(/'/g, '\\\'') %>', '<%= (emp.designation?.en || '').replace(/'/g, '\\\'') %>', '<%= (emp.designation?.bn || '').replace(/'/g, '\\\'') %>', '<%= emp.photo?.url || '' %>', <%= emp.order || 0 %>)">✏️ Edit</button>
            <button class="btn btn-sm btn-danger" onclick="deleteMember('<%= emp._id %>')">🗑️</button>
          </div>
        </div>
        <% }); %>
      </div>
      <% } else { %>
      <div class="empty-state">
        <div style="font-size:32px;">👨‍💼</div>
        <p style="color:#94a3b8;margin-top:8px;">No employees added yet. Click "Add Employee" to start.</p>
      </div>
      <% } %>
    </div>
  </main>
</div>

<!-- Edit Modal -->
<div id="editModal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:999;align-items:center;justify-content:center;">
  <div style="background:white;border-radius:12px;padding:28px;width:90%;max-width:520px;max-height:90vh;overflow-y:auto;">
    <h3 style="margin-bottom:20px;">✏️ Edit Employee</h3>
    <form id="editForm" method="POST" enctype="multipart/form-data">
      <div class="form-row">
        <div class="form-group">
          <label>Name (English)</label>
          <input type="text" id="editNameEn" name="nameEn" class="form-control">
        </div>
        <div class="form-group">
          <label>Name (বাংলা)</label>
          <input type="text" id="editNameBn" name="nameBn" class="form-control">
        </div>
        <div class="form-group">
          <label>Designation (English)</label>
          <input type="text" id="editDesigEn" name="designationEn" class="form-control">
        </div>
        <div class="form-group">
          <label>Designation (বাংলা)</label>
          <input type="text" id="editDesigBn" name="designationBn" class="form-control">
        </div>
        <div class="form-group">
          <label>Display Order</label>
          <input type="number" id="editOrder" name="order" class="form-control">
        </div>
      </div>
      <div id="currentPhotoWrap" style="margin-bottom:12px;"></div>
      <input type="hidden" id="editExistingPhoto" name="existingPhoto">
      <div class="form-group">
        <label>Replace Photo (optional)</label>
        <input type="file" name="image" class="form-control" accept="image/*">
      </div>
      <div style="display:flex;gap:10px;margin-top:12px;">
        <button type="submit" class="btn btn-primary">💾 Save Changes</button>
        <button type="button" class="btn btn-secondary" onclick="closeEditModal()">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
  function toggleAddForm() {
    const panel = document.getElementById('addFormPanel');
    panel.classList.toggle('open');
  }

  function openEditModal(id, nameEn, nameBn, desigEn, desigBn, photoUrl, order) {
    document.getElementById('editForm').action = '/admin/team/update/' + id;
    document.getElementById('editNameEn').value = nameEn;
    document.getElementById('editNameBn').value = nameBn;
    document.getElementById('editDesigEn').value = desigEn;
    document.getElementById('editDesigBn').value = desigBn;
    document.getElementById('editOrder').value = order;
    document.getElementById('editExistingPhoto').value = photoUrl;
    document.getElementById('currentPhotoWrap').innerHTML = photoUrl
      ? `<img src="${photoUrl}" style="height:70px;width:70px;border-radius:50%;object-fit:cover;border:3px solid #e2e8f0;">`
      : '';
    document.getElementById('editModal').style.display = 'flex';
  }

  function closeEditModal() {
    document.getElementById('editModal').style.display = 'none';
  }

  function deleteMember(id) {
    if (!confirm('Delete this team member? This cannot be undone.')) return;
    fetch('/admin/team/delete/' + id, { method: 'POST' })
      .then(r => r.json())
      .then(d => {
        if (d.success) location.reload();
        else alert('Error: ' + (d.error || 'Failed to delete'));
      })
      .catch(() => alert('Network error'));
  }
</script>
</body>
</html>
