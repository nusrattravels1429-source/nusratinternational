<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Certifications - Admin</title>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    /* List View */
    .list-container { margin-top: 20px; }
    .list-item { display: flex; align-items: center; padding: 24px 32px; border-bottom: 1px solid var(--glass-border); transition: all 0.3s ease; cursor: grab; }
    .list-item:active { cursor: grabbing; background: rgba(255, 255, 255, 0.05); }
    .list-item.dragging { opacity: 0.5; border: 2px dashed var(--primary-color); }
    .list-item:last-child { border-bottom: none; }
    
    .drag-handle { padding: 8px; color: var(--text-muted); font-size: 20px; cursor: grab; margin-right: 16px; transition: color 0.3s; }
    .list-item:hover .drag-handle { color: var(--primary-color); }
    
    .cert-thumb { width: 100px; height: 75px; object-fit: contain; background: rgba(255, 255, 255, 0.05); border: 1px solid var(--glass-border); border-radius: 12px; margin-right: 28px; padding: 8px; }
    
    .cert-info { flex: 1; }
    .cert-title { font-weight: 800; font-size: 17px; color: white; margin-bottom: 8px; letter-spacing: -0.3px; }
    .cert-meta { font-size: 13px; color: var(--text-muted); display: flex; gap: 16px; align-items: center; font-weight: 500; }
    .cert-tag { font-size: 11px; background: rgba(99, 102, 241, 0.2); color: #6366f1; padding: 4px 12px; border-radius: 20px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
    
    .cert-status { font-size: 13px; font-weight: 700; display: inline-flex; align-items: center; gap: 12px; margin-right: 20px; }
    .status-active { color: var(--success-color); }
    .status-inactive { color: var(--error-color); }
    .status-featured { color: #f59e0b; }
    
    .list-actions { display: flex; gap: 10px; }
    .list-actions .btn { width: 40px; height: 40px; padding: 0; }

    /* Modal Premium Styles */
    .modal-overlay { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(12px); z-index: 9999; display: none; align-items: center; justify-content: center; padding: 20px; }
    .modal-overlay.active { display: flex; }
    .modal { background: #1e293b; width: 100%; max-width: 750px; max-height: 90vh; border-radius: 30px; border: 1px solid var(--glass-border); box-shadow: 0 30px 60px -12px rgba(0,0,0,0.5); overflow-y: auto; padding: 40px; animation: slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
    .modal h2 { margin-bottom: 2rem; font-size: 24px; font-weight: 800; color: white; letter-spacing: -0.5px; }
    .toggle-group { display: flex; align-items: center; gap: 2rem; margin-top: 1rem; padding: 20px 24px; background: rgba(15, 23, 42, 0.4); border-radius: 16px; border: 1px solid var(--glass-border); }
    .toggle-label { display: flex; align-items: center; gap: 10px; font-size: 14px; font-weight: 700; color: white; cursor: pointer; }
    .modal-actions { display: flex; justify-content: flex-end; gap: 1rem; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--glass-border); }

    @media (max-width: 768px) {
      .list-item { flex-direction: column; align-items: flex-start; position: relative; }
      .drag-handle { position: absolute; top: 1rem; right: 1rem; margin: 0; }
      .cert-thumb { margin-bottom: 1rem; }
      .list-actions { margin-left: 0; margin-top: 1rem; width: 100%; }
      .list-actions .btn { flex: 1; }
    }
  </style>
</head>
<body>
  <div class="layout">
    <%- include('../partials/sidebar', { admin: typeof admin !== 'undefined' ? admin : {}, activePage: 'certifications' }) %>
    
    <div class="main-content">
      <div class="page-header">
        <div>
          <h1>Certifications</h1>
          <p>Manage your company's official certifications and awards.</p>
        </div>
        <button class="btn btn-primary" onclick="openModal()">+ Add Certificate</button>
      </div>

      <div class="filters">
        <button class="btn btn-secondary" onclick="saveOrder()" id="saveOrderBtn" style="display:none;">💾 Save Order</button>
      </div>

      <div class="list-container glass-card" id="certList">
        <!-- JS rendered content -->
        <div style="padding: 2rem; text-align: center; color: #6b7280; font-style: italic;">Loading certifications...</div>
      </div>
    </div>
  </div>

  <!-- Modal -->
  <div class="modal-overlay" id="certModal">
    <div class="modal">
      <h2 id="modalTitle">Add New Certificate</h2>
      <form id="certForm" onsubmit="handleSubmit(event)">
        <input type="hidden" id="itemId">
        
        <div class="form-row">
          <div class="form-group" id="imageInputGroup">
            <label for="certImage">Certificate Image *</label>
            <input type="file" id="certImage" name="certImage" accept="image/*" class="form-control">
          </div>
          <div class="form-group">
            <label for="code">Certificate Code (Optional)</label>
            <input type="text" id="code" name="code" placeholder="e.g., CERT-2024-001" class="form-control">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="titleEn">Title (English) *</label>
            <input type="text" id="titleEn" name="titleEn" required class="form-control">
          </div>
          <div class="form-group">
            <label for="titleBn">Title (Bengali)</label>
            <input type="text" id="titleBn" name="titleBn" class="form-control">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="tagEn">Short Tag (English)</label>
            <input type="text" id="tagEn" name="tagEn" placeholder="e.g., IATA Accredited" class="form-control">
          </div>
          <div class="form-group">
            <label for="tagBn">Short Tag (Bengali)</label>
            <input type="text" id="tagBn" name="tagBn" class="form-control">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="issuingAuthority">Issuing Authority</label>
            <input type="text" id="issuingAuthority" name="issuingAuthority" class="form-control">
          </div>
          <div class="form-group">
            <label for="yearAwarded">Year Awarded</label>
            <input type="number" id="yearAwarded" name="yearAwarded" min="1990" max="2099" value="2024" class="form-control">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="descriptionEn">Description (English)</label>
            <textarea id="descriptionEn" name="descriptionEn" class="form-control"></textarea>
          </div>
          <div class="form-group">
            <label for="descriptionBn">Description (Bengali)</label>
            <textarea id="descriptionBn" name="descriptionBn" class="form-control"></textarea>
          </div>
        </div>

        <div class="toggle-group">
          <label class="toggle-label">
            <input type="checkbox" id="isActive" name="isActive" checked> Active
          </label>
          <label class="toggle-label">
            <input type="checkbox" id="isFeatured" name="isFeatured"> Featured (Show prominently)
          </label>
        </div>

        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
          <button type="submit" class="btn btn-primary" id="submitBtn">Save Certificate</button>
        </div>
      </form>
    </div>
  </div>

  <div class="toast-container" id="toastContainer"></div>

  <script>
    let certItems = [];
    let draggedItem = null;

    // Fetch and render
    async function fetchCerts() {
      try {
        const res = await fetch('/api/admin/certifications');
        const data = await res.json();
        if (data.success) {
          certItems = data.data;
          renderCerts();
        } else throw new Error(data.message);
      } catch (err) {
        showToast('Failed to load certifications', 'error');
      }
    }

    function renderCerts() {
      const container = document.getElementById('certList');
      container.innerHTML = '';

      if (certItems.length === 0) {
        container.innerHTML = '<div style="padding: 2rem; text-align: center; color: #6b7280;">No certifications found.</div>';
        return;
      }

      certItems.forEach((item, index) => {
        const el = document.createElement('div');
        el.className = 'list-item';
        el.draggable = true;
        el.dataset.id = item._id;

        el.addEventListener('dragstart', handleDragStart);
        el.addEventListener('dragover', handleDragOver);
        el.addEventListener('drop', handleDrop);
        el.addEventListener('dragend', handleDragEnd);

        el.innerHTML = `
          <div class="drag-handle">≡</div>
          <img src="${item.imageUrl}" class="cert-thumb" alt="Certificate">
          <div class="cert-info">
            <div class="cert-title">${item.title?.en || 'Untitled'}</div>
            <div class="cert-meta">
              ${item.tag?.en ? `<span class="cert-tag">${item.tag.en}</span>` : ''}
              <span>${item.issuingAuthority || 'No Authority Listed'}</span>
              <span>•</span>
              <span>${item.yearAwarded || ''}</span>
            </div>
          </div>
          <div class="cert-status">
            ${item.isFeatured ? '<span class="status-featured">⭐ Featured</span>' : ''}
            <span class="${item.isActive ? 'status-active' : 'status-inactive'}">
              ${item.isActive ? 'Active' : 'Hidden'}
            </span>
          </div>
          <div class="list-actions">
            <button class="btn btn-featured" onclick="toggleFeatured('${item._id}')" title="Toggle Featured">⭐</button>
            <button class="btn btn-secondary" onclick="openModal('${item._id}')">Edit</button>
            <button class="btn btn-danger" onclick="deleteItem('${item._id}')">Delete</button>
          </div>
        `;
        container.appendChild(el);
      });
    }

    // Modal
    function openModal(id = null) {
      const modal = document.getElementById('certModal');
      const form = document.getElementById('certForm');
      form.reset();
      
      const fileInput = document.getElementById('certImage');
      fileInput.required = !id; // Required for new upload

      if (id) {
        document.getElementById('modalTitle').textContent = 'Edit Certificate';
        const item = certItems.find(i => i._id === id);
        if (item) {
          document.getElementById('itemId').value = item._id;
          document.getElementById('titleEn').value = item.title?.en || '';
          document.getElementById('titleBn').value = item.title?.bn || '';
          document.getElementById('tagEn').value = item.tag?.en || '';
          document.getElementById('tagBn').value = item.tag?.bn || '';
          document.getElementById('code').value = item.code || '';
          document.getElementById('descriptionEn').value = item.description?.en || '';
          document.getElementById('descriptionBn').value = item.description?.bn || '';
          document.getElementById('issuingAuthority').value = item.issuingAuthority || '';
          document.getElementById('yearAwarded').value = item.yearAwarded || new Date().getFullYear();
          document.getElementById('isActive').checked = item.isActive;
          document.getElementById('isFeatured').checked = item.isFeatured;
        }
      } else {
        document.getElementById('modalTitle').textContent = 'Add New Certificate';
        document.getElementById('itemId').value = '';
        document.getElementById('yearAwarded').value = new Date().getFullYear();
      }
      modal.classList.add('active');
    }

    function closeModal() {
      document.getElementById('certModal').classList.remove('active');
    }

    // Submit
    async function handleSubmit(e) {
      e.preventDefault();
      const id = document.getElementById('itemId').value;
      const form = document.getElementById('certForm');
      const formData = new FormData(form);
      const btn = document.getElementById('submitBtn');
      
      // Map checkboxes to explicit boolean strings for form data robustness
      formData.set('isActive', document.getElementById('isActive').checked);
      formData.set('isFeatured', document.getElementById('isFeatured').checked);

      btn.disabled = true;
      btn.textContent = 'Saving...';

      const url = id ? '/api/admin/certifications/' + id : '/api/admin/certifications';
      const method = id ? 'PUT' : 'POST';

      try {
        const res = await fetch(url, { method, body: formData });
        const data = await res.json();
        
        if (data.success) {
          showToast(data.message, 'success');
          closeModal();
          fetchCerts();
        } else throw new Error(data.message);
      } catch (err) {
        showToast(err.message, 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Save Certificate';
      }
    }

    // Delete
    async function deleteItem(id) {
      if (!confirm('Are you sure you want to delete this certificate?')) return;
      try {
        const res = await fetch('/api/admin/certifications/' + id, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) {
          showToast(data.message, 'success');
          fetchCerts();
        } else throw new Error(data.message);
      } catch (err) {
        showToast(err.message, 'error');
      }
    }

    // Toggle Featured
    async function toggleFeatured(id) {
      try {
        const res = await fetch(`/api/admin/certifications/${id}/featured`, { method: 'PATCH' });
        const data = await res.json();
        if (data.success) {
          showToast('Featured status updated', 'success');
          fetchCerts();
        } else throw new Error(data.message);
      } catch (err) {
        showToast(err.message, 'error');
      }
    }

    // Drag and Drop Logic
    function handleDragStart() {
      draggedItem = this;
      setTimeout(() => this.classList.add('dragging'), 0);
    }
    
    function handleDragOver(e) {
      e.preventDefault();
      const container = document.getElementById('certList');
      const afterElement = getDragAfterElement(container, e.clientY);
      if (afterElement == null) {
        container.appendChild(draggedItem);
      } else {
        container.insertBefore(draggedItem, afterElement);
      }
    }
    
    function handleDrop(e) {
      e.preventDefault();
      document.getElementById('saveOrderBtn').style.display = 'inline-flex';
    }
    
    function handleDragEnd() {
      this.classList.remove('dragging');
      draggedItem = null;
    }

    function getDragAfterElement(container, y) {
      const draggableElements = [...container.querySelectorAll('.list-item:not(.dragging)')];
      return draggableElements.reduce((closest, child) => {
        const box = child.getBoundingClientRect();
        const offset = y - box.top - box.height / 2;
        if (offset < 0 && offset > closest.offset) {
          return { offset: offset, element: child }
        } else {
          return closest;
        }
      }, { offset: Number.NEGATIVE_INFINITY }).element;
    }

    // Save Order
    async function saveOrder() {
      const items = Array.from(document.querySelectorAll('.list-item')).map((el, idx) => ({
        _id: el.dataset.id,
        order: idx
      }));

      try {
        document.getElementById('saveOrderBtn').textContent = 'Saving...';
        const res = await fetch('/api/admin/certifications/reorder', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items })
        });
        const data = await res.json();
        if (data.success) {
          showToast('Order saved', 'success');
          document.getElementById('saveOrderBtn').style.display = 'none';
        } else throw new Error(data.message);
      } catch(err) {
        showToast('Failed to save order', 'error');
      } finally {
        document.getElementById('saveOrderBtn').textContent = '💾 Save Order';
      }
    }

    // Toast
    function showToast(msg, type) {
      const container = document.getElementById('toastContainer');
      const toast = document.createElement('div');
      toast.className = `toast ${type}`;
      toast.textContent = msg;
      container.appendChild(toast);
      setTimeout(() => toast.remove(), 3000);
    }

    document.addEventListener('DOMContentLoaded', fetchCerts);
  </script>
</body>
</html>
