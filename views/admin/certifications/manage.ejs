<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Certifications Management - Admin</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: #f0f2f5; color: #333; }
    .admin-layout { display: flex; min-height: 100vh; }
    .sidebar { width: 250px; background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); color: white; padding: 0; position: fixed; height: 100vh; overflow-y: auto; z-index: 100; }
    .sidebar-header { padding: 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.1); text-align: center; }
    .sidebar-logo { font-size: 36px; margin-bottom: 8px; }
    .sidebar-header h2 { font-size: 16px; font-weight: 700; color: #e2e8f0; }
    .admin-name { font-size: 12px; color: rgba(255,255,255,0.5); margin-top: 4px; }
    .sidebar-menu { list-style: none; padding: 12px 0; }
    .sidebar-menu .menu-label { font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.35); padding: 16px 20px 6px; }
    .sidebar-menu .menu-separator { height: 1px; background: rgba(255,255,255,0.1); margin: 12px 20px; }
    .sidebar-menu a { display: flex; align-items: center; gap: 10px; padding: 10px 20px; color: rgba(255,255,255,0.7); text-decoration: none; font-size: 13.5px; transition: all 0.2s; border-left: 3px solid transparent; }
    .sidebar-menu a:hover { background: rgba(255,255,255,0.08); color: white; border-left-color: #667eea; }
    .sidebar-menu a.active { background: rgba(102,126,234,0.2); color: white; border-left-color: #667eea; font-weight: 600; }
    .logout-link:hover { background: rgba(239,68,68,0.2) !important; color: #fca5a5 !important; }
    .main-content { flex: 1; margin-left: 250px; padding: 28px; }
    .page-header { background: white; padding: 20px 28px; border-radius: 12px; margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
    .page-header h1 { font-size: 22px; font-weight: 700; color: #1a1a2e; }
    .breadcrumb { font-size: 13px; color: #94a3b8; }
    .panel { background: white; border-radius: 12px; padding: 28px; margin-bottom: 24px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
    .panel-title { font-size: 16px; font-weight: 700; color: #1a1a2e; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 2px solid #f0f2f5; display: flex; justify-content: space-between; align-items: center; }
    .btn { padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; transition: all 0.2s; }
    .btn-primary { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; }
    .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
    .btn-secondary { background: #f1f5f9; color: #475569; }
    .btn-danger { background: #fee2e2; color: #dc2626; }
    .btn-warning { background: #fef3c7; color: #d97706; }
    .btn-sm { padding: 7px 14px; font-size: 12px; }
    .form-control { width: 100%; padding: 10px 14px; border: 1.5px solid #e2e8f0; border-radius: 8px; font-size: 14px; font-family: inherit; background: #fafafa; transition: border-color 0.2s; }
    .form-control:focus { outline: none; border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,0.12); background: white; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    /* Cert grid */
    .cert-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; }
    .cert-card { border-radius: 12px; overflow: hidden; border: 1.5px solid #e2e8f0; background: white; transition: all 0.2s; }
    .cert-card:hover { border-color: #667eea; box-shadow: 0 4px 20px rgba(102,126,234,0.1); }
    .cert-card-logo { height: 140px; display: flex; align-items: center; justify-content: center; background: #f8faff; overflow: hidden; }
    .cert-card-logo img { max-height: 120px; max-width: 100%; object-fit: contain; }
    .cert-card-logo .no-logo { font-size: 40px; color: #cbd5e1; }
    .cert-card-body { padding: 14px 16px; }
    .cert-card-title { font-size: 14px; font-weight: 700; color: #1a1a2e; }
    .cert-card-code { font-size: 12px; color: #667eea; font-weight: 600; margin-top: 2px; }
    .cert-card-tag { font-size: 11px; color: #94a3b8; }
    .cert-card-badges { display: flex; gap: 6px; margin-top: 8px; flex-wrap: wrap; }
    .badge { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; }
    .badge-featured { background: #fef9c3; color: #854d0e; }
    .badge-active { background: #dcfce7; color: #166534; }
    .badge-inactive { background: #fee2e2; color: #991b1b; }
    .cert-card-actions { padding: 10px 16px; border-top: 1px solid #f0f2f5; display: flex; gap: 8px; }

    .add-form-panel { display: none; }
    .add-form-panel.open { display: block; }
    .empty-state { text-align: center; padding: 60px 20px; color: #94a3b8; }
  </style>
</head>
<body>
<div class="admin-layout">
  <%- include('../partials/sidebar', { admin, activePage: 'certifications' }) %>

  <main class="main-content">
    <div class="page-header">
      <div>
        <h1>📜 Certifications Management</h1>
        <p class="breadcrumb">Admin → Certifications (<%= items.length %> total)</p>
      </div>
      <div style="display:flex;gap:10px;">
        <button class="btn btn-primary" onclick="toggleAddForm()">+ Add Certification</button>
        <a href="/admin/dashboard" class="btn btn-secondary">← Dashboard</a>
      </div>
    </div>

    <!-- Add Form -->
    <div class="panel add-form-panel" id="addFormPanel">
      <div class="panel-title">📋 Add New Certification</div>
      <form action="/admin/certifications/create" method="POST" enctype="multipart/form-data">
        <div class="form-row">
          <div class="form-group">
            <label>Title (English) *</label>
            <input type="text" name="titleEn" class="form-control" placeholder="e.g. IATA Accredited" required>
          </div>
          <div class="form-group">
            <label>Title (বাংলা)</label>
            <input type="text" name="titleBn" class="form-control" placeholder="আইএটিএ স্বীকৃত">
          </div>
          <div class="form-group">
            <label>Tag / Type (English)</label>
            <input type="text" name="tagEn" class="form-control" placeholder="Aviation & Travel">
          </div>
          <div class="form-group">
            <label>Tag / Type (বাংলা)</label>
            <input type="text" name="tagBn" class="form-control">
          </div>
          <div class="form-group">
            <label>Certificate Code / Number</label>
            <input type="text" name="code" class="form-control" placeholder="RL-1429">
          </div>
          <div class="form-group">
            <label>Display Order</label>
            <input type="number" name="order" value="0" class="form-control">
          </div>
          <div class="form-group">
            <label>Logo / Organization Image</label>
            <input type="file" name="logo" class="form-control" accept="image/*">
          </div>
          <div class="form-group">
            <label>Certificate Document Image (optional)</label>
            <input type="file" name="certificate" class="form-control" accept="image/*">
          </div>
        </div>
        <div style="display:flex;gap:20px;align-items:center;margin-bottom:16px;">
          <label style="display:flex;gap:8px;align-items:center;cursor:pointer;font-size:14px;">
            <input type="checkbox" name="isFeatured" value="on" style="width:16px;height:16px;">
            ⭐ Show on Homepage (Featured)
          </label>
        </div>
        <div style="display:flex;gap:10px;">
          <button type="submit" class="btn btn-primary">💾 Add Certification</button>
          <button type="button" class="btn btn-secondary" onclick="toggleAddForm()">Cancel</button>
        </div>
      </form>
    </div>

    <!-- List -->
    <div class="panel">
      <div class="panel-title">
        <span>All Certifications</span>
        <span style="font-size:13px;font-weight:400;color:#94a3b8;"><%= items.filter(i => i.isFeatured).length %> featured · <%= items.filter(i => i.isActive !== false).length %> active</span>
      </div>

      <% if (items && items.length > 0) { %>
      <div class="cert-grid">
        <% items.forEach(function(item) { %>
        <div class="cert-card">
          <div class="cert-card-logo">
            <% if (item.logoUrl) { %>
              <img src="<%= item.logoUrl %>" alt="<%= item.title?.en %>">
            <% } else { %>
              <div class="no-logo">📜</div>
            <% } %>
          </div>
          <div class="cert-card-body">
            <div class="cert-card-title"><%= item.title?.en || 'Untitled' %></div>
            <% if (item.code) { %><div class="cert-card-code"><%= item.code %></div><% } %>
            <div class="cert-card-tag"><%= item.tag?.en || '' %></div>
            <div class="cert-card-badges">
              <% if (item.isFeatured) { %><span class="badge badge-featured">⭐ Featured</span><% } %>
              <span class="badge <%= item.isActive !== false ? 'badge-active' : 'badge-inactive' %>"><%= item.isActive !== false ? '✓ Active' : '✗ Hidden' %></span>
            </div>
          </div>
          <div class="cert-card-actions">
            <button class="btn btn-sm btn-secondary" onclick="openEditModal(
              '<%= item._id %>',
              '<%= (item.title?.en || '').replace(/'/g, '\\\'') %>',
              '<%= (item.title?.bn || '').replace(/'/g, '\\\'') %>',
              '<%= (item.tag?.en || '').replace(/'/g, '\\\'') %>',
              '<%= (item.tag?.bn || '').replace(/'/g, '\\\'') %>',
              '<%= item.code || '' %>',
              '<%= item.logoUrl || '' %>',
              '<%= item.certificateImage || '' %>',
              '<%= item.isFeatured ? 'true' : 'false' %>',
              '<%= item.isActive !== false ? 'true' : 'false' %>',
              '<%= item.order || 0 %>'
            )">✏️ Edit</button>
            <button class="btn btn-sm btn-warning" onclick="toggleFeatured('<%= item._id %>', this)" title="Toggle Featured">⭐</button>
            <button class="btn btn-sm btn-danger" onclick="deleteCert('<%= item._id %>')">🗑️</button>
          </div>
        </div>
        <% }); %>
      </div>
      <% } else { %>
      <div class="empty-state">
        <div style="font-size:48px;margin-bottom:12px;">📜</div>
        <h3>No certifications yet</h3>
        <p>Click "Add Certification" to add your first certification.</p>
      </div>
      <% } %>
    </div>
  </main>
</div>

<!-- Edit Modal -->
<div id="editModal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:999;align-items:center;justify-content:center;">
  <div style="background:white;border-radius:12px;padding:28px;width:90%;max-width:540px;max-height:90vh;overflow-y:auto;">
    <h3 style="margin-bottom:20px;">✏️ Edit Certification</h3>
    <form id="editForm" method="POST" enctype="multipart/form-data">
      <div class="form-row">
        <div class="form-group">
          <label>Title (English)</label>
          <input type="text" id="eTitleEn" name="titleEn" class="form-control">
        </div>
        <div class="form-group">
          <label>Title (বাংলা)</label>
          <input type="text" id="eTitleBn" name="titleBn" class="form-control">
        </div>
        <div class="form-group">
          <label>Tag (English)</label>
          <input type="text" id="eTagEn" name="tagEn" class="form-control">
        </div>
        <div class="form-group">
          <label>Tag (বাংলা)</label>
          <input type="text" id="eTagBn" name="tagBn" class="form-control">
        </div>
        <div class="form-group">
          <label>Code</label>
          <input type="text" id="eCode" name="code" class="form-control">
        </div>
        <div class="form-group">
          <label>Order</label>
          <input type="number" id="eOrder" name="order" class="form-control">
        </div>
      </div>
      <div id="currentLogoWrap" style="margin-bottom:10px;"></div>
      <input type="hidden" id="eExistingLogo" name="existingLogo">
      <div class="form-group">
        <label>Replace Logo (optional)</label>
        <input type="file" name="logo" class="form-control" accept="image/*">
      </div>
      <input type="hidden" id="eExistingCert" name="existingCertificate">
      <div class="form-group">
        <label>Replace Certificate Image (optional)</label>
        <input type="file" name="certificate" class="form-control" accept="image/*">
      </div>
      <label style="display:flex;gap:8px;align-items:center;cursor:pointer;font-size:14px;margin-bottom:16px;">
        <input type="checkbox" id="eIsFeatured" name="isFeatured" value="on" style="width:16px;height:16px;">
        ⭐ Show on Homepage (Featured)
      </label>
      <div style="display:flex;gap:10px;">
        <button type="submit" class="btn btn-primary">💾 Save Changes</button>
        <button type="button" class="btn btn-secondary" onclick="closeEditModal()">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
  function toggleAddForm() {
    const panel = document.getElementById('addFormPanel');
    panel.classList.toggle('open');
    if (panel.classList.contains('open')) panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function openEditModal(id, titleEn, titleBn, tagEn, tagBn, code, logoUrl, certUrl, isFeatured, isActive, order) {
    document.getElementById('editForm').action = '/admin/certifications/update/' + id;
    document.getElementById('eTitleEn').value = titleEn;
    document.getElementById('eTitleBn').value = titleBn;
    document.getElementById('eTagEn').value = tagEn;
    document.getElementById('eTagBn').value = tagBn;
    document.getElementById('eCode').value = code;
    document.getElementById('eOrder').value = order;
    document.getElementById('eExistingLogo').value = logoUrl;
    document.getElementById('eExistingCert').value = certUrl;
    document.getElementById('eIsFeatured').checked = isFeatured === 'true';
    document.getElementById('currentLogoWrap').innerHTML = logoUrl
      ? `<img src="${logoUrl}" style="height:60px;border-radius:6px;object-fit:contain;background:#f8faff;padding:4px;">`
      : '';
    document.getElementById('editModal').style.display = 'flex';
  }

  function closeEditModal() {
    document.getElementById('editModal').style.display = 'none';
  }

  function toggleFeatured(id, btn) {
    fetch('/admin/certifications/toggle-featured/' + id, { method: 'POST' })
      .then(r => r.json())
      .then(d => { if (d.success) location.reload(); else alert('Error'); })
      .catch(() => alert('Network error'));
  }

  function deleteCert(id) {
    if (!confirm('Delete this certification? This cannot be undone.')) return;
    fetch('/admin/certifications/delete/' + id, { method: 'POST' })
      .then(r => r.json())
      .then(d => { if (d.success) location.reload(); else alert('Error: ' + d.error); })
      .catch(() => alert('Network error'));
  }
</script>
</body>
</html>
