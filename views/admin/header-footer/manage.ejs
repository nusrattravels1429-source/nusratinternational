<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Header & Footer Settings - Admin</title>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .card { padding: 32px; margin-bottom: 32px; }
    .card-title { font-size: 20px; font-weight: 800; color: white; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--glass-border); display: flex; align-items: center; gap: 10px; }
    
    .current-logo-preview { max-height: 80px; border-radius: 12px; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); padding: 12px; margin-bottom: 16px; display: block; }
    
    .hours-grid { display: grid; grid-template-columns: 120px 1fr 1fr auto; gap: 16px; align-items: center; padding: 16px; background: rgba(255,255,255,0.02); border-radius: 16px; border: 1px solid var(--glass-border); margin-bottom: 12px; }
    .hours-grid label { font-weight: 700; color: white; text-transform: uppercase; font-size: 12px; letter-spacing: 1px; }

    .tabs-container { margin-bottom: 32px; }
    .tab-btn { padding: 12px 24px; border-radius: 12px 12px 0 0; cursor: pointer; transition: all 0.3s; font-weight: 700; font-size: 14px; border: 1px solid var(--glass-border); border-bottom: none; background: rgba(255,255,255,0.05); color: var(--text-muted); }
    .tab-btn.active { background: var(--primary-color); color: white; border-color: var(--primary-color); box-shadow: 0 -4px 15px var(--primary-glow); }
  </style>
</head>
<body>
  <div class="layout">
    <%- include('../partials/sidebar', { admin: typeof admin !== 'undefined' ? admin : {}, activePage: 'header-footer' }) %>
    
    <div class="main-content container">
      <div class="page-header">
        <div>
          <h1>Global Navigation & Footer</h1>
          <p>Manage logos, social links, and navigation menus across the entire site.</p>
        </div>
        <a href="/admin/dashboard" class="btn btn-secondary">← Back</a>
      </div>

      <div class="tabs-container">
        <div class="tab-btn active" onclick="switchTab(event, 'header')">Header / Navbar</div>
        <div class="tab-btn" onclick="switchTab(event, 'footer')">Footer Settings</div>
      </div>

      <!-- HEADER TAB -->
      <div id="tab-header" class="tab-content active">
        
        <!-- Logo & Branding -->
        <div class="card">
          <h2 class="card-title">Header Branding</h2>
          <form id="headerBrandingForm" onsubmit="saveHeaderBranding(event)">
            <div class="form-row" style="align-items: flex-end;">
              <div class="form-group">
                <label>Current Logo</label>
                <img id="navLogoPreview" src="" class="current-logo-preview" alt="Header Logo" onerror="this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIxMDBwJSIgaGVpZ2h0PSIxMDBwJSI+PHJlY3Qgd2lkdGg9IjEwMCUiIGhlaWdodD0iMTAwJSIgZmlsbD0iI2VlZSIvPjx0ZXh0IHg9IjUwJSIgeT0iNTAlIiBmb250LXNpemU9IjE0IiBmaWxsPSIjOTk5IiB0ZXh0LWFuY2hvcj0ibWlkZGxlIiBkeT0iLjNlbSI+Tm8gTG9nbyBwb3N0ZWQ8L3RleHQ+PC9zdmc+';">
                <input type="file" id="navLogoFile" name="headerLogo" accept="image/*" class="form-control">
                <div style="margin-top: 0.5rem; font-size: 0.75rem; color: var(--text-muted);">OR paste URL (Fallback):</div>
                <input type="url" id="navLogoUrl" name="logoUrl" placeholder="https://..." class="form-control">
              </div>
              <div class="form-group">
                <label>Logo Text (English)</label>
                <input type="text" id="navLogoTextEn" placeholder="e.g. Nusrat International" class="form-control">
              </div>
              <div class="form-group">
                <label>Logo Text (Bengali)</label>
                <input type="text" id="navLogoTextBn" placeholder="নুসরাত ইন্টারন্যাশনাল" class="form-control">
              </div>
            </div>
            <button type="submit" class="btn btn-primary" id="btnSaveHeaderBrand">Save Header Branding</button>
          </form>
        </div>

        <!-- Navigation Links -->
        <div class="card glass-card">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h2 class="card-title" style="margin: 0; border: none;">Navigation Links</h2>
            <div>
              <button class="btn btn-success" id="btnSaveNavOrder" style="display:none;" onclick="saveNavOrder()">💾 Save Order</button>
              <button class="btn btn-primary" onclick="openNavModal()">+ Add Link</button>
            </div>
          </div>
          
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th width="40"></th>
                  <th>Label (EN / BN)</th>
                  <th>URL Link</th>
                  <th>External?</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="navTableBody">
                <tr><td colspan="6" style="text-align: center;">Loading...</td></tr>
              </tbody>
            </table>
          </div>
        </div>

      </div>

      <!-- FOOTER TAB -->
      <div id="tab-footer" class="tab-content">
        <form id="footerSettingsForm" onsubmit="saveFooterSettings(event)">
          <div class="card glass-card" style="position: sticky; top: 0; z-index: 10; display:flex; justify-content: space-between; padding: 1.5rem 1.5rem; background: rgba(99, 102, 241, 0.1); backdrop-filter: blur(10px); margin-bottom: 2rem;">
            <h2 style="font-size: 1.25rem; font-weight: 600; color: #3730a3; margin:0; line-height: 38px;">Footer Configuration</h2>
            <button type="submit" class="btn btn-primary" id="btnSaveFooter">Save All Footer Changes</button>
          </div>

          <!-- Footer Branding -->
          <div class="card glass-card">
            <h2 class="card-title">Footer Branding</h2>
            <div class="form-row">
              <div class="form-group">
                <label>Company Name (EN)</label>
                <input type="text" id="fcNameEn" required class="form-control">
              </div>
              <div class="form-group">
                <label>Company Name (BN)</label>
                <input type="text" id="fcNameBn" required class="form-control">
              </div>
            </div>
            <div class="form-row" style="align-items: flex-end;">
              <div class="form-group">
                <label>Footer Logo</label>
                <img id="footerLogoPreview" src="" class="current-logo-preview" alt="Footer Logo" onerror="this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIxMDBwJSIgaGVpZ2h0PSIxMDBwJSI+PHJlY3Qgd2lkdGg9IjEwMCUiIGhlaWdodD0iMTAwJSIgZmlsbD0iI2VlZSIvPjx0ZXh0IHg9IjUwJSIgeT0iNTAlIiBmb250LXNpemU9IjE0IiBmaWxsPSIjOTk5IiB0ZXh0LWFuY2hvcj0ibWlkZGxlIiBkeT0iLjNlbSI+Tm8gTG9nbyBwb3N0ZWQ8L3RleHQ+PC9zdmc+';">
                <input type="file" id="fLogoFile" name="footerLogo" accept="image/*" class="form-control">
                <input type="url" id="fLogoUrl" name="logoUrl" placeholder="Image URL Fallback" style="margin-top:0.5rem" class="form-control">
              </div>
              <div class="form-group">
                <label>Copyright Text (EN)</label>
                <input type="text" id="fCopyEn" placeholder="© 2024 Nusrat International. All rights reserved." class="form-control">
              </div>
            </div>
            <div class="form-group">
              <label>Copyright Text (BN)</label>
              <input type="text" id="fCopyBn" class="form-control">
            </div>
          </div>

          <!-- Contact & Social -->
          <div class="card glass-card">
            <h2 class="card-title">Contact & Social Links</h2>
            <div class="form-row">
              <div class="form-group">
                <label>Address (EN)</label>
                <textarea id="fAddrEn" class="form-control"></textarea>
              </div>
              <div class="form-group">
                <label>Address (BN)</label>
                <textarea id="fAddrBn" class="form-control"></textarea>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group"><label>Phone</label><input type="text" id="fPhone" class="form-control"></div>
              <div class="form-group"><label>WhatsApp</label><input type="text" id="fWhatsapp" class="form-control"></div>
              <div class="form-group"><label>Email</label><input type="email" id="fEmail" class="form-control"></div>
            </div>
            <div class="form-row">
              <div class="form-group"><label>Facebook URL</label><input type="url" id="fbLink" class="form-control"></div>
              <div class="form-group"><label>Instagram URL</label><input type="url" id="igLink" class="form-control"></div>
              <div class="form-group"><label>YouTube URL</label><input type="url" id="ytLink" class="form-control"></div>
              <div class="form-group"><label>LinkedIn URL</label><input type="url" id="liLink" class="form-control"></div>
              <div class="form-group"><label>Twitter/X URL</label><input type="url" id="twLink" class="form-control"></div>
            </div>
          </div>

          <!-- Business Hours -->
          <div class="card">
            <h2 class="card-title">Business Hours</h2>
            <div id="businessHoursContainer">
              <!-- JS Injected Rows -->
            </div>
          </div>

          <!-- Maps Embed -->
          <div class="card glass-card">
            <h2 class="card-title">Location / Google Maps</h2>
            <div class="form-group">
              <label>Google Maps Embed SRC URL</label>
              <input type="text" id="fMaps" placeholder="e.g. https://www.google.com/maps/embed?pb=..." class="form-control">
              <div style="font-size: 0.75rem; color: #6b7280; margin-top: 0.5rem;">Copy ONLY the src="..." content from the Google Maps iframe snippet</div>
            </div>
          </div>
        </form>

        <!-- Quick Links (Array managed separately) -->
        <div class="card glass-card">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h2 class="card-title" style="margin: 0; border: none;">Footer Quick Links</h2>
            <div>
              <button class="btn btn-success" id="btnSaveQkOrder" style="display:none;" onclick="saveQkOrder()">💾 Save Order</button>
              <button class="btn btn-primary" onclick="openQkModal()">+ Add Quick Link</button>
            </div>
          </div>
          
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th width="40"></th>
                  <th>Label (EN / BN)</th>
                  <th>URL Link</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="qkTableBody">
                <!-- JS Rendered -->
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- NAVIGATION MODAL -->
  <div class="modal-overlay" id="navModal">
    <div class="modal">
      <h2 id="navModalTitle">Add Navigation Link</h2>
      <form id="navForm" onsubmit="saveNav(event)">
        <input type="hidden" id="navId">
        <div class="form-row">
          <div class="form-group">
            <label>Label (EN) *</label>
            <input type="text" id="navLabelEn" required>
          </div>
          <div class="form-group">
            <label>Label (BN) *</label>
            <input type="text" id="navLabelBn" required>
          </div>
        </div>
        <div class="form-group">
          <label>URL Path *</label>
          <input type="text" id="navLink" required placeholder="/about">
        </div>
        <div style="display:flex; gap: 2rem; margin-top:1rem; padding: 1rem; background: #f9fafb;">
          <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer;">
            <input type="checkbox" id="navIsExternal"> Opens in New Tab
          </label>
          <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer;">
            <input type="checkbox" id="navIsActive" checked> Is Active
          </label>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="closeNavModal()">Cancel</button>
          <button type="submit" class="btn btn-primary" id="btnSubmitNav">Save Link</button>
        </div>
      </form>
    </div>
  </div>

  <!-- QUICK LINK MODAL -->
  <div class="modal-overlay" id="qkModal">
   <div class="modal">
     <h2 id="qkModalTitle">Add Quick Link</h2>
     <form id="qkForm" onsubmit="saveQk(event)">
       <input type="hidden" id="qkIndex">
       <div class="form-row">
         <div class="form-group">
           <label>Label (EN) *</label>
           <input type="text" id="qkLabelEn" required>
         </div>
         <div class="form-group">
           <label>Label (BN) *</label>
           <input type="text" id="qkLabelBn" required>
         </div>
       </div>
       <div class="form-group">
         <label>URL Path *</label>
         <input type="text" id="qkLink" required autocomplete="off">
       </div>
       <div class="modal-actions">
         <button type="button" class="btn btn-secondary" onclick="closeQkModal()">Cancel</button>
         <button type="submit" class="btn btn-primary" id="btnSubmitQk">Save Quick Link</button>
       </div>
     </form>
   </div>
 </div>

  <div class="toast-container" id="toastContainer"></div>

  <script>
    let navItems = [];
    let quickLinksData = [];
    let footerData = null;
    let draggedRow = null;
    const days = ['mon','tue','wed','thu','fri','sat','sun'];

    // Tab Switching
    function switchTab(e, tabId) {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      e.target.classList.add('active');
      document.getElementById('tab-' + tabId).classList.add('active');
    }

    // Initialize API calls
    document.addEventListener('DOMContentLoaded', () => {
      fetchPublicNavbar();
      fetchAdminNavItems();
      fetchFooterSettings();
    });

    /* ==================================================== */
    /* 1. HEADER BRANDING LOGIC                             */
    /* ==================================================== */
    async function fetchPublicNavbar() {
      try {
        const res = await fetch('/api/public/navbar');
        const data = await res.json();
        if(data.success && data.data) {
          document.getElementById('navLogoPreview').src = data.data.headerLogoUrl || '';
          document.getElementById('navLogoUrl').value = data.data.headerLogoUrl || '';
          document.getElementById('navLogoTextEn').value = data.data.logoText?.en || '';
          document.getElementById('navLogoTextBn').value = data.data.logoText?.bn || '';
        }
      } catch (err) {}
    }

    async function saveHeaderBranding(e) {
      e.preventDefault();
      const btn = document.getElementById('btnSaveHeaderBrand');
      btn.disabled = true;
      btn.textContent = 'Saving...';
      
      try {
        // 1. Text save
        await fetch('/api/admin/header/text', {
          method: 'PUT', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            logoTextEn: document.getElementById('navLogoTextEn').value,
            logoTextBn: document.getElementById('navLogoTextBn').value
          })
        });

        // 2. Image save
        const fileInput = document.getElementById('navLogoFile');
        const formData = new FormData();
        formData.append('logoUrl', document.getElementById('navLogoUrl').value || '');
        if(fileInput.files[0]) formData.append('headerLogo', fileInput.files[0]);

        const imgRes = await fetch('/api/admin/header/logo', {
          method: 'POST', body: formData
        });
        const imgData = await imgRes.json();
        if(imgData.success) {
          document.getElementById('navLogoPreview').src = imgData.data.headerLogoUrl;
          document.getElementById('navLogoUrl').value = imgData.data.headerLogoUrl;
        }

        showToast('Header branding saved', 'success');
      } catch (err) {
        showToast('Error saving header branding', 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Save Header Branding';
      }
    }

    /* ==================================================== */
    /* 2. NAVIGATION LINKS LOGIC                            */
    /* ==================================================== */
    async function fetchAdminNavItems() {
      try {
        const res = await fetch('/api/admin/header/nav');
        const data = await res.json();
        if(data.success) {
          navItems = data.data;
          renderNavTable();
        }
      } catch(err) {
        document.getElementById('navTableBody').innerHTML = '<tr><td colspan="6">Failed to load</td></tr>';
      }
    }

    function renderNavTable() {
      const tbody = document.getElementById('navTableBody');
      tbody.innerHTML = '';
      if(!navItems.length) {
        tbody.innerHTML = '<tr><td colspan="6" style="text-align: center; color:#6b7280;">No navigation links found.</td></tr>';
        return;
      }
      
      navItems.forEach((item, index) => {
        const tr = document.createElement('tr');
        tr.draggable = true;
        tr.dataset.id = item._id;
        
        tr.addEventListener('dragstart', function() { draggedRow = this; this.classList.add('dragging'); });
        tr.addEventListener('dragover', function(e) { 
          e.preventDefault(); 
          const afterObj = getDragAfterElement(tbody, e.clientY);
          if(!afterObj) tbody.appendChild(draggedRow);
          else tbody.insertBefore(draggedRow, afterObj);
        });
        tr.addEventListener('drop', function() { document.getElementById('btnSaveNavOrder').style.display = 'inline-block'; });
        tr.addEventListener('dragend', function() { this.classList.remove('dragging'); draggedRow = null; });

        tr.innerHTML = `
          <td class="drag-handle">≡</td>
          <td><strong>${item.label?.en || ''}</strong><br><small>${item.label?.bn || ''}</small></td>
          <td><code>${item.link}</code></td>
          <td>${item.isExternal ? 'Yes ↗' : 'No'}</td>
          <td><span class="status-badge ${item.isActive ? 'status-active' : 'status-inactive'}">${item.isActive ? 'Active' : 'Hidden'}</span></td>
          <td>
            <button type="button" class="btn btn-secondary" style="padding: 0.25rem 0.5rem;" onclick="openNavModal('${item._id}')">Edit</button>
            <button type="button" class="btn btn-danger" style="padding: 0.25rem 0.5rem;" onclick="deleteNav('${item._id}')">Del</button>
          </td>
        `;
        tbody.appendChild(tr);
      });
    }

    function getDragAfterElement(container, y) {
      const draggables = [...container.querySelectorAll('tr:not(.dragging)')];
      return draggables.reduce((closest, child) => {
        const box = child.getBoundingClientRect();
        const offset = y - box.top - box.height / 2;
        if(offset < 0 && offset > closest.offset) return { offset, element: child };
        else return closest;
      }, { offset: Number.NEGATIVE_INFINITY }).element;
    }

    async function saveNavOrder() {
      const rows = document.querySelectorAll('#navTableBody tr');
      const items = Array.from(rows).map((row, index) => ({
        _id: row.dataset.id, order: index
      }));
      document.getElementById('btnSaveNavOrder').textContent = 'Saving...';
      try {
        const res = await fetch('/api/admin/header/nav/reorder', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items })
        });
        if(res.ok) {
          showToast('Order saved', 'success');
          document.getElementById('btnSaveNavOrder').style.display = 'none';
          fetchAdminNavItems();
        }
      } catch(err) {
        showToast('Failed to save order', 'error');
      } finally {
        document.getElementById('btnSaveNavOrder').textContent = '💾 Save Order';
      }
    }

    function openNavModal(id = null) {
      document.getElementById('navForm').reset();
      document.getElementById('navId').value = id || '';
      document.getElementById('navModalTitle').textContent = id ? 'Edit Link' : 'Add Link';
      
      if(id) {
        const item = navItems.find(i => i._id === id);
        if(item) {
          document.getElementById('navLabelEn').value = item.label?.en || '';
          document.getElementById('navLabelBn').value = item.label?.bn || '';
          document.getElementById('navLink').value = item.link || '';
          document.getElementById('navIsExternal').checked = item.isExternal;
          document.getElementById('navIsActive').checked = item.isActive;
        }
      }
      document.getElementById('navModal').classList.add('active');
    }
    function closeNavModal() { document.getElementById('navModal').classList.remove('active'); }

    async function saveNav(e) {
      e.preventDefault();
      const id = document.getElementById('navId').value;
      const payload = {
        labelEn: document.getElementById('navLabelEn').value,
        labelBn: document.getElementById('navLabelBn').value,
        link: document.getElementById('navLink').value,
        isExternal: document.getElementById('navIsExternal').checked,
        isActive: document.getElementById('navIsActive').checked
      };

      const url = id ? '/api/admin/header/nav/' + id : '/api/admin/header/nav';
      const method = id ? 'PUT' : 'POST';
      const btn = document.getElementById('btnSubmitNav');
      btn.disabled = true;

      try {
        const res = await fetch(url, {
          method, headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        if(data.success) {
          showToast(data.message, 'success');
          closeNavModal();
          fetchAdminNavItems();
        } else throw new Error(data.message);
      } catch(err) {
        showToast(err.message, 'error');
      } finally {
        btn.disabled = false;
      }
    }

    async function deleteNav(id) {
      if(!confirm('Delete this navigation link?')) return;
      try {
        const res = await fetch('/api/admin/header/nav/' + id, { method: 'DELETE' });
        const data = await res.json();
        if(data.success){ showToast('Link deleted', 'success'); fetchAdminNavItems(); }
      } catch(e) { showToast('Delete failed', 'error'); }
    }


    /* ==================================================== */
    /* 3. FOOTER SETTINGS LOGIC                             */
    /* ==================================================== */
    async function fetchFooterSettings() {
      try {
        const res = await fetch('/api/admin/footer/settings');
        const data = await res.json();
        if(data.success && data.data) {
          footerData = data.data;
          quickLinksData = footerData.quickLinks || [];
          populateFooterForm();
          renderQkTable();
        }
      } catch(err) { console.error('Error fetching footer:', err); }
    }

    function generateBusinessHoursHTML() {
      const container = document.getElementById('businessHoursContainer');
      container.innerHTML = '';
      const bh = footerData?.businessHours || {};
      
      days.forEach(day => {
        const dayData = bh[day] || { open: '09:00', close: '18:00', closed: false };
        container.innerHTML += `
          <div class="hours-grid">
            <label>${day}</label>
            <input type="time" id="bh_open_${day}" value="${dayData.open}">
            <input type="time" id="bh_close_${day}" value="${dayData.close}">
            <label style="display:flex; align-items:center; gap:0.25rem;">
              <input type="checkbox" id="bh_closed_${day}" ${dayData.closed ? 'checked' : ''} onchange="toggleDayInputs('${day}')"> Closed
            </label>
          </div>
        `;
        setTimeout(() => toggleDayInputs(day), 10);
      });
    }

    function toggleDayInputs(day) {
      const isClosed = document.getElementById(`bh_closed_${day}`).checked;
      document.getElementById(`bh_open_${day}`).disabled = isClosed;
      document.getElementById(`bh_close_${day}`).disabled = isClosed;
    }

    function populateFooterForm() {
      const fd = footerData;
      document.getElementById('fcNameEn').value = fd.companyName?.en || '';
      document.getElementById('fcNameBn').value = fd.companyName?.bn || '';
      
      document.getElementById('footerLogoPreview').src = fd.logoUrl || '';
      document.getElementById('fLogoUrl').value = fd.logoUrl || '';
      
      document.getElementById('fCopyEn').value = fd.copyright?.en || '';
      document.getElementById('fCopyBn').value = fd.copyright?.bn || '';
      
      document.getElementById('fAddrEn').value = fd.address?.en || '';
      document.getElementById('fAddrBn').value = fd.address?.bn || '';
      document.getElementById('fPhone').value = fd.phone || '';
      document.getElementById('fWhatsapp').value = fd.whatsapp || '';
      document.getElementById('fEmail').value = fd.email || '';
      
      document.getElementById('fbLink').value = fd.socialLinks?.facebook || '';
      document.getElementById('igLink').value = fd.socialLinks?.instagram || '';
      document.getElementById('ytLink').value = fd.socialLinks?.youtube || '';
      document.getElementById('liLink').value = fd.socialLinks?.linkedin || '';
      document.getElementById('twLink').value = fd.socialLinks?.twitter || '';
      
      document.getElementById('fMaps').value = fd.mapsEmbedUrl || '';

      generateBusinessHoursHTML();
    }

    async function saveFooterSettings(e) {
      e.preventDefault();
      const btn = document.getElementById('btnSaveFooter');
      btn.disabled = true;
      btn.textContent = 'Saving...';

      const formData = new FormData();
      formData.append('companyNameEn', document.getElementById('fcNameEn').value);
      formData.append('companyNameBn', document.getElementById('fcNameBn').value);
      formData.append('logoUrl', document.getElementById('fLogoUrl').value);
      formData.append('copyrightEn', document.getElementById('fCopyEn').value);
      formData.append('copyrightBn', document.getElementById('fCopyBn').value);
      formData.append('addressEn', document.getElementById('fAddrEn').value);
      formData.append('addressBn', document.getElementById('fAddrBn').value);
      formData.append('phone', document.getElementById('fPhone').value);
      formData.append('whatsapp', document.getElementById('fWhatsapp').value);
      formData.append('email', document.getElementById('fEmail').value);
      formData.append('mapsEmbedUrl', document.getElementById('fMaps').value);

      const fLogoFile = document.getElementById('fLogoFile').files[0];
      if(fLogoFile) formData.append('footerLogo', fLogoFile);

      const socialLinks = {
        facebook: document.getElementById('fbLink').value,
        instagram: document.getElementById('igLink').value,
        youtube: document.getElementById('ytLink').value,
        linkedin: document.getElementById('liLink').value,
        twitter: document.getElementById('twLink').value
      };
      formData.append('socialLinks', JSON.stringify(socialLinks));

      const businessHours = {};
      days.forEach(day => {
        businessHours[day] = {
          open: document.getElementById(`bh_open_${day}`).value,
          close: document.getElementById(`bh_close_${day}`).value,
          closed: document.getElementById(`bh_closed_${day}`).checked
        };
      });
      formData.append('businessHours', JSON.stringify(businessHours));

      try {
        const res = await fetch('/api/admin/footer/settings', { method: 'PUT', body: formData });
        const data = await res.json();
        if(data.success) {
          showToast('Footer settings saved', 'success');
          fetchFooterSettings(); // Refresh UI
        } else throw new Error(data.message);
      } catch(err) { showToast(err.message, 'error'); } 
      finally { btn.disabled = false; btn.textContent = 'Save All Footer Changes'; }
    }

    /* ==================================================== */
    /* 4. FOOTER QUICK LINKS LOGIC                          */
    /* ==================================================== */
    function renderQkTable() {
      const tbody = document.getElementById('qkTableBody');
      tbody.innerHTML = '';
      if(!quickLinksData || !quickLinksData.length) {
        tbody.innerHTML = '<tr><td colspan="4" style="text-align: center; color:#6b7280;">No quick links added.</td></tr>';
        return;
      }
      
      quickLinksData.forEach((item, index) => {
        const tr = document.createElement('tr');
        tr.draggable = true;
        tr.dataset.index = index;
        
        tr.addEventListener('dragstart', function() { draggedRow = this; this.classList.add('dragging'); });
        tr.addEventListener('dragover', function(e) { 
          e.preventDefault(); 
          const afterObj = getDragAfterElement(tbody, e.clientY);
          if(!afterObj) tbody.appendChild(draggedRow);
          else tbody.insertBefore(draggedRow, afterObj);
        });
        tr.addEventListener('drop', function() { document.getElementById('btnSaveQkOrder').style.display = 'inline-block'; });
        tr.addEventListener('dragend', function() { this.classList.remove('dragging'); draggedRow = null; });

        tr.innerHTML = `
          <td class="drag-handle">≡</td>
          <td><strong>${item.label?.en || ''}</strong><br><small>${item.label?.bn || ''}</small></td>
          <td><code>${item.link}</code></td>
          <td>
            <button type="button" class="btn btn-secondary" style="padding: 0.25rem 0.5rem;" onclick="openQkModal(${index})">Edit</button>
            <button type="button" class="btn btn-danger" style="padding: 0.25rem 0.5rem;" onclick="deleteQk(${index})">Del</button>
          </td>
        `;
        tbody.appendChild(tr);
      });
    }

    async function saveQkOrder() {
      const rows = document.querySelectorAll('#qkTableBody tr');
      const newArray = Array.from(rows).map(row => quickLinksData[parseInt(row.dataset.index)]);
      
      document.getElementById('btnSaveQkOrder').textContent = 'Saving...';
      try {
        const res = await fetch('/api/admin/footer/quick-links/reorder', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: newArray })
        });
        if(res.ok) {
          showToast('Quick Links reordered', 'success');
          document.getElementById('btnSaveQkOrder').style.display = 'none';
          fetchFooterSettings();
        }
      } catch(err) {
        showToast('Failed to save order', 'error');
      } finally {
        document.getElementById('btnSaveQkOrder').textContent = '💾 Save Order';
      }
    }

    function openQkModal(index = null) {
      document.getElementById('qkForm').reset();
      document.getElementById('qkIndex').value = index !== null ? index : '';
      document.getElementById('qkModalTitle').textContent = index !== null ? 'Edit Quick Link' : 'Add Quick Link';
      
      if(index !== null) {
        const item = quickLinksData[index];
        if(item) {
          document.getElementById('qkLabelEn').value = item.label?.en || '';
          document.getElementById('qkLabelBn').value = item.label?.bn || '';
          document.getElementById('qkLink').value = item.link || '';
        }
      }
      document.getElementById('qkModal').classList.add('active');
    }
    function closeQkModal() { document.getElementById('qkModal').classList.remove('active'); }

    async function saveQk(e) {
      e.preventDefault();
      const indexStr = document.getElementById('qkIndex').value;
      const isEdit = indexStr !== '';
      
      const payload = {
        labelEn: document.getElementById('qkLabelEn').value,
        labelBn: document.getElementById('qkLabelBn').value,
        link: document.getElementById('qkLink').value
      };

      const url = isEdit ? '/api/admin/footer/quick-links/' + indexStr : '/api/admin/footer/quick-links';
      const method = isEdit ? 'PUT' : 'POST';
      const btn = document.getElementById('btnSubmitQk');
      btn.disabled = true;

      try {
        const res = await fetch(url, {
          method, headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        if(data.success) {
          showToast(data.message, 'success');
          closeQkModal();
          fetchFooterSettings();
        } else throw new Error(data.message);
      } catch(err) { showToast(err.message, 'error'); } 
      finally { btn.disabled = false; }
    }

    async function deleteQk(index) {
      if(!confirm('Delete this quick link?')) return;
      try {
        const res = await fetch('/api/admin/footer/quick-links/' + index, { method: 'DELETE' });
        const data = await res.json();
        if(data.success){ showToast('Quick link deleted', 'success'); fetchFooterSettings(); }
      } catch(e) { showToast('Delete failed', 'error'); }
    }

    // Toast function
    function showToast(msg, type) {
      const container = document.getElementById('toastContainer');
      const toast = document.createElement('div');
      toast.className = `toast ${type}`;
      toast.textContent = msg;
      container.appendChild(toast);
      setTimeout(() => toast.remove(), 3000);
    }
  </script>
</body>
</html>
