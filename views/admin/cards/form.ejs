<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= action === 'create' ? 'Create Card' : 'Edit Card' %> - Admin Panel</title>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .form-grid { display: grid; grid-template-columns: 1fr 340px; gap: 32px; align-items: start; }
    .section-title { font-size: 18px; font-weight: 800; color: white; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--glass-border); display: flex; align-items: center; gap: 10px; letter-spacing: -0.5px; }

    /* Type Select */
    .type-select-group { display: flex; gap: 12px; }
    .type-option { flex: 1; }
    .type-option input[type="radio"] { display: none; }
    .type-option label { display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 20px 10px; border: 1px solid var(--glass-border); border-radius: 20px; cursor: pointer; font-size: 13px; font-weight: 700; color: var(--text-muted); transition: all 0.3s; text-align: center; background: rgba(255,255,255,0.02); }
    .type-option input:checked + label { border-color: var(--primary-color); background: rgba(99, 102, 241, 0.1); color: white; box-shadow: 0 0 20px var(--primary-glow); }
    .type-option label span { font-size: 32px; margin-bottom: 4px; }

    /* Image upload */
    .upload-area { border: 2px dashed var(--glass-border); border-radius: 20px; padding: 40px; text-align: center; cursor: pointer; transition: all 0.3s; background: rgba(255,255,255,0.02); }
    .upload-area:hover, .upload-area.drag-over { border-color: var(--primary-color); background: rgba(99, 102, 241, 0.05); }
    .upload-icon { font-size: 48px; margin-bottom: 16px; }
    .upload-text { font-size: 15px; color: var(--text-muted); }
    .upload-text strong { color: var(--primary-color); }

    .images-preview { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-top: 24px; }
    .img-preview-item { position: relative; border-radius: 16px; overflow: hidden; aspect-ratio: 4/3; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); }
    .img-preview-item img { width: 100%; height: 100%; object-fit: cover; }
    .img-preview-item .remove-img { position: absolute; top: 10px; right: 10px; width: 30px; height: 30px; background: var(--error-color); color: white; border: none; border-radius: 50%; font-size: 18px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; z-index: 5; }
    .img-preview-item .remove-img:hover { transform: scale(1.1); background: #ef4444; }

    /* Action Card */
    .action-card { position: sticky; top: 32px; padding: 32px; }
    .toggle-row { display: grid; gap: 12px; }
    .toggle-item { display: flex; align-items: center; gap: 12px; padding: 16px; background: rgba(255,255,255,0.02); border-radius: 16px; border: 1px solid var(--glass-border); cursor: pointer; transition: all 0.3s; }
    .toggle-item:hover { border-color: var(--primary-color); }
    .toggle-item:has(input:checked) { border-color: var(--primary-color); background: rgba(99, 102, 241, 0.05); }
    .toggle-item input[type="checkbox"] { width: 20px; height: 20px; cursor: pointer; }
    .toggle-item label { font-size: 14px; font-weight: 700; color: white; cursor: pointer; }

    @media (max-width: 900px) {
      .form-grid { grid-template-columns: 1fr; }
      .action-card { position: static; }
      .form-row { grid-template-columns: 1fr; }
    }
    @media (max-width: 600px) {
      .main-content { padding: 16px; }
      .type-select-group { flex-direction: column; }
    }
  </style>
</head>
<body>
  <div class="admin-layout">
    <%- include('../partials/sidebar', { admin: typeof admin !== 'undefined' ? admin : {}, activePage: 'cards-all' }) %>

    <main class="main-content">
      <div class="page-header">
        <div>
          <h1><%= action === 'create' ? 'Create Package' : 'Edit Package' %></h1>
          <p>Fill in the details to <%= action === 'create' ? 'publish a new' : 'update this' %> travel package.</p>
        </div>
        <a href="/admin/cards" class="btn btn-primary">← Back to List</a>
      </div>

      <form id="cardForm" method="POST" enctype="multipart/form-data"
            action="<%= action === 'create' ? '/admin/cards/create' : '/admin/cards/update/' + card._id %>">

        <div class="form-grid">
          <!-- LEFT COLUMN -->
          <div>
            <!-- Package Type -->
            <div class="form-card">
              <div class="section-title">🏷️ Package Type</div>
              <div class="type-select-group">
                <div class="type-option">
                  <input type="radio" name="type" id="type-travel" value="travel" <%= (card?.type || 'travel') === 'travel' ? 'checked' : '' %> required>
                  <label for="type-travel"><span>✈️</span>Travel</label>
                </div>
                <div class="type-option">
                  <input type="radio" name="type" id="type-hajj" value="hajj" <%= card?.type === 'hajj' ? 'checked' : '' %>>
                  <label for="type-hajj"><span>🕋</span>Hajj</label>
                </div>
                <div class="type-option">
                  <input type="radio" name="type" id="type-work" value="work" <%= card?.type === 'work' ? 'checked' : '' %>>
                  <label for="type-work"><span>💼</span>Work</label>
                </div>
              </div>
            </div>

            <!-- Basic Info -->
            <div class="form-card glass-card">
              <div class="section-title">📝 Basic Information</div>
              <div class="form-row">
                <div class="form-group">
                  <label>Title (English) <span class="required">*</span></label>
                  <input type="text" name="titleEn" required value="<%= card?.title?.en || '' %>" placeholder="Package title in English" class="form-control">
                </div>
                <div class="form-group">
                  <label>Title (Bengali)</label>
                  <input type="text" name="titleBn" value="<%= card?.title?.bn || '' %>" placeholder="প্যাকেজের নাম বাংলায়" class="form-control">
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Description (English)</label>
                  <textarea name="descriptionEn" placeholder="Full package description in English" class="form-control"><%= card?.description?.en || '' %></textarea>
                </div>
                <div class="form-group">
                  <label>Description (Bengali)</label>
                  <textarea name="descriptionBn" placeholder="বাংলায় বিস্তারিত বিবরণ" class="form-control"><%= card?.description?.bn || '' %></textarea>
                </div>
              </div>
            </div>

            <!-- Location & Pricing -->
            <div class="form-card glass-card">
              <div class="section-title">📍 Location & Pricing</div>
              <div class="form-row">
                <div class="form-group">
                  <label>Location (English)</label>
                  <input type="text" name="locationEn" value="<%= card?.location?.en || '' %>" placeholder="e.g. Saudi Arabia" class="form-control">
                </div>
                <div class="form-group">
                  <label>Location (Bengali)</label>
                  <input type="text" name="locationBn" value="<%= card?.location?.bn || '' %>" placeholder="যেমন: সৌদি আরব" class="form-control">
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Price Amount</label>
                  <input type="text" name="priceAmount" value="<%= card?.pricing?.amount || '' %>" placeholder="e.g. 150,000 BDT or Negotiable" class="form-control">
                </div>
                <div class="form-group">
                  <label>Currency</label>
                  <select name="priceCurrency" class="form-control">
                    <option value="BDT" <%= (card?.pricing?.currency || 'BDT') === 'BDT' ? 'selected' : '' %>>BDT (৳)</option>
                    <option value="USD" <%= card?.pricing?.currency === 'USD' ? 'selected' : '' %>>USD ($)</option>
                  </select>
                </div>
              </div>
              <div class="form-group">
                <label>Duration</label>
                <input type="text" name="duration" value="<%= card?.duration || '' %>" placeholder="e.g. 7 Days, 30 Days" class="form-control">
              </div>
            </div>

            <!-- Features -->
            <div class="form-card">
              <div class="section-title">✨ Package Features</div>
              <div class="form-row">
                <div class="form-group">
                  <label>Features (English)</label>
                  <textarea name="featuresEn" rows="6" placeholder="One feature per line&#10;e.g. Visa Processing&#10;Hotel Accommodation&#10;Airport Pickup" class="form-control"><%= card?.features?.map(f => f.en).join('\n') || '' %></textarea>
                  <div class="help-text">Enter one feature per line</div>
                </div>
                <div class="form-group">
                  <label>Features (Bengali)</label>
                  <textarea name="featuresBn" rows="6" placeholder="প্রতি লাইনে একটি ফিচার&#10;যেমন: ভিসা প্রসেসিং&#10;হোটেল থাকার ব্যবস্থা&#10;এয়ারপোর্ট পিকআপ" class="form-control"><%= card?.features?.map(f => f.bn).join('\n') || '' %></textarea>
                  <div class="help-text">এক লাইনে একটি ফিচার লিখুন</div>
                </div>
              </div>
            </div>

            <!-- Images -->
            <div class="form-card">
              <div class="section-title">🖼️ Package Images (Max 4)</div>

              <div class="upload-area" id="uploadArea" onclick="document.getElementById('imageInput').click()">
                <input type="file" id="imageInput" name="images" multiple accept="image/jpeg,image/png,image/webp,image/gif">
                <div class="upload-icon">📸</div>
                <div class="upload-text"><strong>Click to upload</strong> or drag & drop images here</div>
                <div class="upload-limit">JPEG, PNG, WebP • Max 5MB each • Max 4 images total</div>
              </div>

              <div class="images-preview" id="imagesPreview"></div>
              <div class="img-count-badge" id="imgCountBadge"></div>

              <!-- Hidden input to track existing images on edit -->
              <% if (action === 'edit' && card?.images && card.images.length > 0) { %>
                <input type="hidden" id="existingImagesInput" name="existingImages" value='<%= JSON.stringify(card.images) %>'>
              <% } else { %>
                <input type="hidden" id="existingImagesInput" name="existingImages" value='[]'>
              <% } %>
            </div>
          </div>

          <!-- RIGHT COLUMN: Actions & Status -->
          <div>
            <div class="action-card">
              <div class="section-title">⚙️ Status & Actions</div>

              <div class="form-group">
                <label>Visibility</label>
                <div class="toggle-row">
                  <div class="toggle-item">
                    <input type="checkbox" id="isActive" name="isActive" <%= card?.isActive !== false ? 'checked' : '' %>>
                    <label for="isActive">Active</label>
                  </div>
                  <% if (action === 'edit') { %>
                    <div class="toggle-item">
                      <input type="checkbox" id="isPaused" name="isPaused" <%= card?.isPaused ? 'checked' : '' %>>
                      <label for="isPaused">Paused</label>
                    </div>
                  <% } %>
                </div>
                <div class="help-text" style="margin-top: 10px;">Active = shown on site. Paused = temporarily hidden without deleting.</div>
              </div>

              <button type="submit" id="submitBtn" class="btn-submit">
                <%= action === 'create' ? '🚀 Create Card' : '💾 Save Changes' %>
              </button>
              <a href="/admin/cards" class="btn-cancel">Cancel</a>

              <% if (action === 'edit') { %>
                <hr style="margin: 20px 0; border: none; border-top: 1px solid #f3f4f6;">
                <div style="font-size: 12px; color: #9ca3af;">
                  <div>Created: <%= card.createdAt ? new Date(card.createdAt).toLocaleDateString() : 'N/A' %></div>
                  <div style="margin-top: 4px;">Updated: <%= card.updatedAt ? new Date(card.updatedAt).toLocaleDateString() : 'N/A' %></div>
                  <% if (card.slug) { %>
                    <div style="margin-top: 4px;">Slug: <code style="font-size: 11px; background: #f3f4f6; padding: 2px 6px; border-radius: 4px;"><%= card.slug.substring(0, 30) %>...</code></div>
                  <% } %>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </form>
    </main>
  </div>

  <div class="toast-container" id="toastContainer"></div>

  <script>
    const MAX_IMAGES = 4;
    // Existing images from server (for edit mode)
    let existingImages = <%- JSON.stringify(card?.images || []) %>;
    let newFiles = []; // new File objects selected by user

    function showToast(msg, type = 'success') {
      const c = document.getElementById('toastContainer');
      const t = document.createElement('div');
      t.className = 'toast ' + type;
      t.textContent = msg;
      c.appendChild(t);
      setTimeout(() => t.remove(), 3500);
    }

    function updateCountBadge() {
      const total = existingImages.length + newFiles.length;
      const badge = document.getElementById('imgCountBadge');
      badge.textContent = total + ' / ' + MAX_IMAGES + ' image' + (total !== 1 ? 's' : '') + ' selected';
      badge.className = 'img-count-badge' + (total >= MAX_IMAGES ? ' at-limit' : '');
    }

    function renderPreviews() {
      const preview = document.getElementById('imagesPreview');
      preview.innerHTML = '';

      existingImages.forEach((img, i) => {
        const item = document.createElement('div');
        item.className = 'img-preview-item';
        item.innerHTML = `
          <img src="${img.url}" alt="Image ${i+1}">
          <button type="button" class="remove-img" onclick="removeExistingImage(${i})">×</button>
        `;
        preview.appendChild(item);
      });

      newFiles.forEach((file, i) => {
        const item = document.createElement('div');
        item.className = 'img-preview-item';
        const url = URL.createObjectURL(file);
        item.innerHTML = `
          <img src="${url}" alt="New image ${i+1}">
          <button type="button" class="remove-img" onclick="removeNewFile(${i})">×</button>
        `;
        preview.appendChild(item);
      });

      updateCountBadge();
    }

    function removeExistingImage(index) {
      existingImages.splice(index, 1);
      document.getElementById('existingImagesInput').value = JSON.stringify(existingImages);
      renderPreviews();
    }

    function removeNewFile(index) {
      newFiles.splice(index, 1);
      syncFileInput();
      renderPreviews();
    }

    function syncFileInput() {
      // Create a new DataTransfer to sync the file input with newFiles array
      const dt = new DataTransfer();
      newFiles.forEach(f => dt.items.add(f));
      document.getElementById('imageInput').files = dt.files;
    }

    document.getElementById('imageInput').addEventListener('change', function(e) {
      const selected = Array.from(e.target.files);
      const totalAfter = existingImages.length + newFiles.length + selected.length;

      if (totalAfter > MAX_IMAGES) {
        const allowable = MAX_IMAGES - existingImages.length - newFiles.length;
        showToast(`Maximum ${MAX_IMAGES} images allowed. You can add ${allowable} more.`, 'error');
        e.target.value = '';
        return;
      }
      newFiles = newFiles.concat(selected);
      syncFileInput();
      renderPreviews();
    });

    // Drag & drop
    const uploadArea = document.getElementById('uploadArea');
    uploadArea.addEventListener('dragover', e => { e.preventDefault(); uploadArea.classList.add('drag-over'); });
    uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('drag-over'));
    uploadArea.addEventListener('drop', e => {
      e.preventDefault();
      uploadArea.classList.remove('drag-over');
      const files = Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('image/'));
      const totalAfter = existingImages.length + newFiles.length + files.length;
      if (totalAfter > MAX_IMAGES) {
        showToast('Maximum ' + MAX_IMAGES + ' images allowed.', 'error');
        return;
      }
      newFiles = newFiles.concat(files);
      syncFileInput();
      renderPreviews();
    });

    // Form submit
    document.getElementById('cardForm').addEventListener('submit', function(e) {
      const titleEn = document.querySelector('[name="titleEn"]').value.trim();
      if (!titleEn) {
        e.preventDefault();
        showToast('Title (English) is required.', 'error');
        return;
      }
      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.textContent = 'Saving...';
    });

    // Initial render of existing images
    renderPreviews();
  </script>
</body>
</html>
