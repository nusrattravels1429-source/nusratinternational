<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= action === 'create' ? 'Create Card' : 'Edit Card' %> - Admin Panel</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'DM Sans', sans-serif; background: #f0f2f8; color: #1a1f2e; }
    .admin-layout { display: flex; min-height: 100vh; }
    .main-content { flex: 1; padding: 30px; }

    .page-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      border-radius: 16px;
      padding: 24px 32px;
      margin-bottom: 28px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: white;
      box-shadow: 0 8px 30px rgba(102,126,234,0.4);
    }
    .page-header h1 { font-size: 24px; font-weight: 700; }
    .btn-back { background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3); padding: 10px 20px; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 600; transition: background 0.2s; }
    .btn-back:hover { background: rgba(255,255,255,0.3); }

    .form-grid { display: grid; grid-template-columns: 1fr 340px; gap: 24px; align-items: start; }

    .form-card {
      background: white;
      border-radius: 16px;
      padding: 28px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.07);
      margin-bottom: 24px;
    }
    .section-title {
      font-size: 17px;
      font-weight: 700;
      color: #1a1f2e;
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 2px solid #f3f4f6;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-group { margin-bottom: 18px; }
    .form-group:last-child { margin-bottom: 0; }
    .form-group label {
      display: block;
      margin-bottom: 7px;
      font-size: 13px;
      font-weight: 600;
      color: #374151;
    }
    .form-group label .required { color: #ef4444; margin-left: 2px; }
    .form-group input,
    .form-group textarea,
    .form-group select {
      width: 100%;
      padding: 11px 14px;
      border: 2px solid #e5e7eb;
      border-radius: 10px;
      font-size: 14px;
      font-family: inherit;
      color: #1a1f2e;
      background: white;
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
    }
    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
      border-color: #667eea;
      box-shadow: 0 0 0 3px rgba(102,126,234,0.12);
    }
    .form-group textarea { resize: vertical; min-height: 110px; }
    .help-text { font-size: 12px; color: #9ca3af; margin-top: 5px; }

    /* Status toggles */
    .toggle-row { display: flex; gap: 16px; flex-wrap: wrap; }
    .toggle-item { display: flex; align-items: center; gap: 10px; padding: 12px 16px; background: #f9fafb; border-radius: 10px; border: 2px solid #e5e7eb; cursor: pointer; transition: border-color 0.2s; }
    .toggle-item:has(input:checked) { border-color: #667eea; background: #f0f2ff; }
    .toggle-item input[type="checkbox"] { width: 18px; height: 18px; accent-color: #667eea; cursor: pointer; }
    .toggle-item label { font-size: 14px; font-weight: 500; cursor: pointer; }

    /* Image upload */
    .upload-area {
      border: 2px dashed #d1d5db;
      border-radius: 12px;
      padding: 30px;
      text-align: center;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
    }
    .upload-area:hover, .upload-area.drag-over {
      border-color: #667eea;
      background: #f5f3ff;
    }
    .upload-area input[type="file"] { display: none; }
    .upload-icon { font-size: 40px; margin-bottom: 10px; }
    .upload-text { font-size: 14px; color: #6b7280; }
    .upload-text strong { color: #667eea; }
    .upload-limit { font-size: 12px; color: #9ca3af; margin-top: 6px; }

    .images-preview { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-top: 16px; }
    .img-preview-item {
      position: relative;
      border-radius: 10px;
      overflow: hidden;
      aspect-ratio: 4/3;
      background: #f3f4f6;
    }
    .img-preview-item img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .img-preview-item .remove-img {
      position: absolute;
      top: 6px; right: 6px;
      width: 26px; height: 26px;
      background: rgba(239,68,68,0.9);
      color: white;
      border: none;
      border-radius: 50%;
      font-size: 16px;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      line-height: 1;
      transition: background 0.2s;
    }
    .img-preview-item .remove-img:hover { background: #dc2626; }
    .img-count-badge {
      font-size: 12px;
      color: #6b7280;
      margin-top: 10px;
      text-align: center;
    }
    .img-count-badge.at-limit { color: #ef4444; font-weight: 600; }

    /* Sidebar action card */
    .action-card {
      background: white;
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.07);
      position: sticky;
      top: 30px;
    }
    .action-card .section-title { margin-bottom: 16px; }

    .btn-submit {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 15px rgba(102,126,234,0.4);
    }
    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(102,126,234,0.5); }
    .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

    .btn-cancel {
      width: 100%;
      padding: 12px;
      background: #f3f4f6;
      color: #6b7280;
      border: none;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 10px;
      text-align: center;
      display: block;
      text-decoration: none;
      transition: background 0.2s;
    }
    .btn-cancel:hover { background: #e5e7eb; color: #374151; }

    .type-select-group { display: flex; gap: 10px; }
    .type-option { flex: 1; }
    .type-option input[type="radio"] { display: none; }
    .type-option label {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      padding: 14px 10px;
      border: 2px solid #e5e7eb;
      border-radius: 12px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 600;
      color: #6b7280;
      transition: all 0.2s;
      text-align: center;
    }
    .type-option input:checked + label {
      border-color: #667eea;
      background: #f0f2ff;
      color: #667eea;
    }
    .type-option label span { font-size: 28px; }

    .toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 9999; display: flex; flex-direction: column; gap: 10px; }
    .toast { padding: 14px 20px; border-radius: 10px; color: white; font-size: 14px; font-weight: 500; min-width: 260px; box-shadow: 0 8px 24px rgba(0,0,0,0.15); animation: slideInToast 0.3s ease; }
    .toast.success { background: #10b981; }
    .toast.error { background: #ef4444; }
    @keyframes slideInToast { from { opacity: 0; transform: translateX(40px); } to { opacity: 1; transform: translateX(0); } }

    @media (max-width: 900px) {
      .form-grid { grid-template-columns: 1fr; }
      .action-card { position: static; }
      .form-row { grid-template-columns: 1fr; }
    }
    @media (max-width: 600px) {
      .main-content { padding: 16px; }
      .type-select-group { flex-direction: column; }
    }
  </style>
</head>
<body>
  <div class="admin-layout">
    <%- include('../partials/sidebar', { admin: typeof admin !== 'undefined' ? admin : {}, activePage: 'cards-all' }) %>

    <main class="main-content">
      <div class="page-header">
        <h1><%= action === 'create' ? '➕ Create New Card' : '✏️ Edit Card' %></h1>
        <a href="/admin/cards" class="btn-back">← Back to Cards</a>
      </div>

      <form id="cardForm" method="POST" enctype="multipart/form-data"
            action="<%= action === 'create' ? '/admin/cards/create' : '/admin/cards/update/' + card._id %>">

        <div class="form-grid">
          <!-- LEFT COLUMN -->
          <div>
            <!-- Package Type -->
            <div class="form-card">
              <div class="section-title">🏷️ Package Type</div>
              <div class="type-select-group">
                <div class="type-option">
                  <input type="radio" name="type" id="type-travel" value="travel" <%= (card?.type || 'travel') === 'travel' ? 'checked' : '' %> required>
                  <label for="type-travel"><span>✈️</span>Travel</label>
                </div>
                <div class="type-option">
                  <input type="radio" name="type" id="type-hajj" value="hajj" <%= card?.type === 'hajj' ? 'checked' : '' %>>
                  <label for="type-hajj"><span>🕋</span>Hajj</label>
                </div>
                <div class="type-option">
                  <input type="radio" name="type" id="type-work" value="work" <%= card?.type === 'work' ? 'checked' : '' %>>
                  <label for="type-work"><span>💼</span>Work</label>
                </div>
              </div>
            </div>

            <!-- Basic Info -->
            <div class="form-card">
              <div class="section-title">📝 Basic Information</div>
              <div class="form-row">
                <div class="form-group">
                  <label>Title (English) <span class="required">*</span></label>
                  <input type="text" name="titleEn" required value="<%= card?.title?.en || '' %>" placeholder="Package title in English">
                </div>
                <div class="form-group">
                  <label>Title (Bengali)</label>
                  <input type="text" name="titleBn" value="<%= card?.title?.bn || '' %>" placeholder="প্যাকেজের নাম বাংলায়">
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Description (English)</label>
                  <textarea name="descriptionEn" placeholder="Full package description in English"><%= card?.description?.en || '' %></textarea>
                </div>
                <div class="form-group">
                  <label>Description (Bengali)</label>
                  <textarea name="descriptionBn" placeholder="বাংলায় বিস্তারিত বিবরণ"><%= card?.description?.bn || '' %></textarea>
                </div>
              </div>
            </div>

            <!-- Location & Pricing -->
            <div class="form-card">
              <div class="section-title">📍 Location & Pricing</div>
              <div class="form-row">
                <div class="form-group">
                  <label>Location (English)</label>
                  <input type="text" name="locationEn" value="<%= card?.location?.en || '' %>" placeholder="e.g. Saudi Arabia">
                </div>
                <div class="form-group">
                  <label>Location (Bengali)</label>
                  <input type="text" name="locationBn" value="<%= card?.location?.bn || '' %>" placeholder="যেমন: সৌদি আরব">
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Price Amount</label>
                  <input type="text" name="priceAmount" value="<%= card?.pricing?.amount || '' %>" placeholder="e.g. 150,000 BDT or Negotiable">
                </div>
                <div class="form-group">
                  <label>Currency</label>
                  <select name="priceCurrency">
                    <option value="BDT" <%= (card?.pricing?.currency || 'BDT') === 'BDT' ? 'selected' : '' %>>BDT (৳)</option>
                    <option value="USD" <%= card?.pricing?.currency === 'USD' ? 'selected' : '' %>>USD ($)</option>
                  </select>
                </div>
              </div>
              <div class="form-group">
                <label>Duration</label>
                <input type="text" name="duration" value="<%= card?.duration || '' %>" placeholder="e.g. 7 Days, 30 Days">
              </div>
            </div>

            <!-- Features -->
            <div class="form-card">
              <div class="section-title">✨ Package Features</div>
              <div class="form-row">
                <div class="form-group">
                  <label>Features (English)</label>
                  <textarea name="featuresEn" rows="6" placeholder="One feature per line&#10;e.g. Visa Processing&#10;Hotel Accommodation&#10;Airport Pickup"><%= card?.features?.map(f => f.en).join('\n') || '' %></textarea>
                  <div class="help-text">Enter one feature per line</div>
                </div>
                <div class="form-group">
                  <label>Features (Bengali)</label>
                  <textarea name="featuresBn" rows="6" placeholder="প্রতি লাইনে একটি ফিচার&#10;যেমন: ভিসা প্রসেসিং&#10;হোটেল থাকার ব্যবস্থা&#10;এয়ারপোর্ট পিকআপ"><%= card?.features?.map(f => f.bn).join('\n') || '' %></textarea>
                  <div class="help-text">এক লাইনে একটি ফিচার লিখুন</div>
                </div>
              </div>
            </div>

            <!-- Images -->
            <div class="form-card">
              <div class="section-title">🖼️ Package Images (Max 4)</div>

              <div class="upload-area" id="uploadArea" onclick="document.getElementById('imageInput').click()">
                <input type="file" id="imageInput" name="images" multiple accept="image/jpeg,image/png,image/webp,image/gif">
                <div class="upload-icon">📸</div>
                <div class="upload-text"><strong>Click to upload</strong> or drag & drop images here</div>
                <div class="upload-limit">JPEG, PNG, WebP • Max 5MB each • Max 4 images total</div>
              </div>

              <div class="images-preview" id="imagesPreview"></div>
              <div class="img-count-badge" id="imgCountBadge"></div>

              <!-- Hidden input to track existing images on edit -->
              <% if (action === 'edit' && card?.images && card.images.length > 0) { %>
                <input type="hidden" id="existingImagesInput" name="existingImages" value='<%= JSON.stringify(card.images) %>'>
              <% } else { %>
                <input type="hidden" id="existingImagesInput" name="existingImages" value='[]'>
              <% } %>
            </div>
          </div>

          <!-- RIGHT COLUMN: Actions & Status -->
          <div>
            <div class="action-card">
              <div class="section-title">⚙️ Status & Actions</div>

              <div class="form-group">
                <label>Visibility</label>
                <div class="toggle-row">
                  <div class="toggle-item">
                    <input type="checkbox" id="isActive" name="isActive" <%= card?.isActive !== false ? 'checked' : '' %>>
                    <label for="isActive">Active</label>
                  </div>
                  <% if (action === 'edit') { %>
                    <div class="toggle-item">
                      <input type="checkbox" id="isPaused" name="isPaused" <%= card?.isPaused ? 'checked' : '' %>>
                      <label for="isPaused">Paused</label>
                    </div>
                  <% } %>
                </div>
                <div class="help-text" style="margin-top: 10px;">Active = shown on site. Paused = temporarily hidden without deleting.</div>
              </div>

              <button type="submit" id="submitBtn" class="btn-submit">
                <%= action === 'create' ? '🚀 Create Card' : '💾 Save Changes' %>
              </button>
              <a href="/admin/cards" class="btn-cancel">Cancel</a>

              <% if (action === 'edit') { %>
                <hr style="margin: 20px 0; border: none; border-top: 1px solid #f3f4f6;">
                <div style="font-size: 12px; color: #9ca3af;">
                  <div>Created: <%= card.createdAt ? new Date(card.createdAt).toLocaleDateString() : 'N/A' %></div>
                  <div style="margin-top: 4px;">Updated: <%= card.updatedAt ? new Date(card.updatedAt).toLocaleDateString() : 'N/A' %></div>
                  <% if (card.slug) { %>
                    <div style="margin-top: 4px;">Slug: <code style="font-size: 11px; background: #f3f4f6; padding: 2px 6px; border-radius: 4px;"><%= card.slug.substring(0, 30) %>...</code></div>
                  <% } %>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </form>
    </main>
  </div>

  <div class="toast-container" id="toastContainer"></div>

  <script>
    const MAX_IMAGES = 4;
    // Existing images from server (for edit mode)
    let existingImages = <%- JSON.stringify(card?.images || []) %>;
    let newFiles = []; // new File objects selected by user

    function showToast(msg, type = 'success') {
      const c = document.getElementById('toastContainer');
      const t = document.createElement('div');
      t.className = 'toast ' + type;
      t.textContent = msg;
      c.appendChild(t);
      setTimeout(() => t.remove(), 3500);
    }

    function updateCountBadge() {
      const total = existingImages.length + newFiles.length;
      const badge = document.getElementById('imgCountBadge');
      badge.textContent = total + ' / ' + MAX_IMAGES + ' image' + (total !== 1 ? 's' : '') + ' selected';
      badge.className = 'img-count-badge' + (total >= MAX_IMAGES ? ' at-limit' : '');
    }

    function renderPreviews() {
      const preview = document.getElementById('imagesPreview');
      preview.innerHTML = '';

      existingImages.forEach((img, i) => {
        const item = document.createElement('div');
        item.className = 'img-preview-item';
        item.innerHTML = `
          <img src="${img.url}" alt="Image ${i+1}">
          <button type="button" class="remove-img" onclick="removeExistingImage(${i})">×</button>
        `;
        preview.appendChild(item);
      });

      newFiles.forEach((file, i) => {
        const item = document.createElement('div');
        item.className = 'img-preview-item';
        const url = URL.createObjectURL(file);
        item.innerHTML = `
          <img src="${url}" alt="New image ${i+1}">
          <button type="button" class="remove-img" onclick="removeNewFile(${i})">×</button>
        `;
        preview.appendChild(item);
      });

      updateCountBadge();
    }

    function removeExistingImage(index) {
      existingImages.splice(index, 1);
      document.getElementById('existingImagesInput').value = JSON.stringify(existingImages);
      renderPreviews();
    }

    function removeNewFile(index) {
      newFiles.splice(index, 1);
      syncFileInput();
      renderPreviews();
    }

    function syncFileInput() {
      // Create a new DataTransfer to sync the file input with newFiles array
      const dt = new DataTransfer();
      newFiles.forEach(f => dt.items.add(f));
      document.getElementById('imageInput').files = dt.files;
    }

    document.getElementById('imageInput').addEventListener('change', function(e) {
      const selected = Array.from(e.target.files);
      const totalAfter = existingImages.length + newFiles.length + selected.length;

      if (totalAfter > MAX_IMAGES) {
        const allowable = MAX_IMAGES - existingImages.length - newFiles.length;
        showToast(`Maximum ${MAX_IMAGES} images allowed. You can add ${allowable} more.`, 'error');
        e.target.value = '';
        return;
      }
      newFiles = newFiles.concat(selected);
      syncFileInput();
      renderPreviews();
    });

    // Drag & drop
    const uploadArea = document.getElementById('uploadArea');
    uploadArea.addEventListener('dragover', e => { e.preventDefault(); uploadArea.classList.add('drag-over'); });
    uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('drag-over'));
    uploadArea.addEventListener('drop', e => {
      e.preventDefault();
      uploadArea.classList.remove('drag-over');
      const files = Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('image/'));
      const totalAfter = existingImages.length + newFiles.length + files.length;
      if (totalAfter > MAX_IMAGES) {
        showToast('Maximum ' + MAX_IMAGES + ' images allowed.', 'error');
        return;
      }
      newFiles = newFiles.concat(files);
      syncFileInput();
      renderPreviews();
    });

    // Form submit
    document.getElementById('cardForm').addEventListener('submit', function(e) {
      const titleEn = document.querySelector('[name="titleEn"]').value.trim();
      if (!titleEn) {
        e.preventDefault();
        showToast('Title (English) is required.', 'error');
        return;
      }
      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.textContent = 'Saving...';
    });

    // Initial render of existing images
    renderPreviews();
  </script>
</body>
</html>
