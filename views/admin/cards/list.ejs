<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Cards - Admin Panel</title>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .card-item.paused::before {
      content: 'PAUSED';
      position: absolute;
      top: 12px;
      left: 12px;
      background: var(--warning-color);
      color: white;
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 1px;
      padding: 4px 10px;
      border-radius: 20px;
      z-index: 2;
    }
    .card-item.inactive::before {
      content: 'INACTIVE';
      position: absolute;
      top: 12px;
      left: 12px;
      background: var(--error-color);
      color: white;
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 1px;
      padding: 4px 10px;
      border-radius: 20px;
      z-index: 2;
    }
    .card-img-wrap {
      height: 180px;
      position: relative;
      overflow: hidden;
      background: rgba(255,255,255,0.05);
    }
    .empty-state {
      grid-column: 1 / -1;
      text-align: center;
      padding: 80px 40px;
    }
    .empty-state .icon { font-size: 60px; margin-bottom: 20px; }
  </style>
</head>
<body>
  <div class="admin-layout">
    <%- include('../partials/sidebar', { admin: typeof admin !== 'undefined' ? admin : {}, activePage: 'cards-all' }) %>
    
    <main class="main-content">
      <div class="page-header">
        <div>
          <h1>Package Cards</h1>
          <p>Manage your travel, hajj, and work packages. Currently viewing <strong><%= type === 'all' ? 'All' : type.charAt(0).toUpperCase() + type.slice(1) %></strong>.</p>
        </div>
        <a href="/admin/cards/create" class="btn btn-primary">+ Add New Package</a>
      </div>

      <div class="filters-bar glass-card">
        <div class="filter-group">
          <label>Filter Type:</label>
          <select onchange="location.href='/admin/cards?type=' + this.value">
            <option value="all" <%= type==='all' ? 'selected' : '' %>>All Packages</option>
            <option value="travel" <%= type==='travel' ? 'selected' : '' %>>Travel Packages</option>
            <option value="hajj" <%= type==='hajj' ? 'selected' : '' %>>Hajj Packages</option>
            <option value="work" <%= type==='work' ? 'selected' : '' %>>Work Packages</option>
          </select>
        </div>
        
        <div class="stats-row">
          <span class="stat-pill stat-total">Total: <%= cards.length %></span>
          <span class="stat-pill stat-active">Active: <%= cards.filter(c => !c.isPaused).length %></span>
          <span class="stat-pill stat-paused">Paused: <%= cards.filter(c => c.isPaused).length %></span>
        </div>
      </div>

      <div class="cards-grid">
        <% if (cards.length === 0) { %>
          <div class="empty-state glass-card">
            <div class="icon">🎴</div>
            <h3>No packages found</h3>
            <p>Try changing the filter or <a href="/admin/cards/create">create a new one</a>.</p>
          </div>
        <% } else { %>
          <% cards.forEach(card => { %>
            <div class="card-item glass-card <%= card.isPaused ? 'paused' : '' %> <%= !card.isActive ? 'inactive' : '' %>" id="card-<%= card._id %>">
              <div class="card-img-wrap">
                <% if (card.images && card.images.length > 0) { %>
                  <img src="<%= card.images[0].url %>" alt="<%= card.title.en %>" loading="lazy" />
                  <% if (card.images.length > 1) { %>
                    <span class="img-count">1 / <%= card.images.length %></span>
                  <% } %>
                <% } else { %>
                  <div class="card-img-placeholder">🏝️</div>
                <% } %>
                <span class="card-type-badge badge-<%= card.type %>"><%= card.type %></span>
              </div>

              <div class="card-body">
                <h3 class="card-title" title="<%= card.title.en %>"><%= card.title.en %></h3>
                <p class="card-title-bn" title="<%= card.title.bn %>"><%= card.title.bn %></p>
                
                <div class="card-meta">
                  <span>💰 <strong><%= card.price || 'Contact' %></strong></span>
                  <span>📍 <strong><%= card.location || 'Global' %></strong></span>
                  <span>🗓️ <strong><%= card.duration || 'Flexible' %></strong></span>
                </div>

                <div class="card-actions">
                  <a href="/admin/cards/edit/<%= card._id %>" class="btn btn-edit">Edit</a>
                  <button onclick="toggleStatus('<%= card._id %>')" class="btn <%= card.isPaused ? 'btn-toggle-resume' : 'btn-toggle-pause' %>">
                    <%= card.isPaused ? 'Resume' : 'Pause' %>
                  </button>
                  <button onclick="deleteCard('<%= card._id %>')" class="btn btn-delete">Delete</button>
                </div>
              </div>
            </div>
          <% }); %>
        <% } %>
      </div>
    </main>
  </div>

  <div class="toast-container" id="toastContainer"></div>

  <script>
    function showToast(msg, type = 'success') {
      const c = document.getElementById('toastContainer');
      const t = document.createElement('div');
      t.className = 'toast ' + type;
      t.textContent = msg;
      c.appendChild(t);
      setTimeout(() => t.remove(), 3500);
    }

    async function toggleStatus(id, isPaused) {
      if (!confirm(isPaused ? 'Resume this card? It will become visible on the public site.' : 'Pause this card? It will be hidden from the public site.')) return;
      try {
        const res = await fetch('/admin/cards/toggle-status/' + id, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        const data = await res.json();
        if (data.success) {
          showToast(isPaused ? 'Card resumed successfully!' : 'Card paused successfully!', 'success');
          setTimeout(() => location.reload(), 800);
        } else {
          showToast('Error: ' + (data.error || 'Unknown error'), 'error');
        }
      } catch (err) {
        showToast('Network error. Please try again.', 'error');
      }
    }

    async function deleteCard(id) {
      if (!confirm('Are you sure you want to permanently delete this card? This cannot be undone.')) return;
      try {
        const res = await fetch('/admin/cards/delete/' + id, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        const data = await res.json();
        if (data.success) {
          showToast('Card deleted successfully!', 'success');
          setTimeout(() => location.reload(), 800);
        } else {
          showToast('Error: ' + (data.error || 'Unknown error'), 'error');
        }
      } catch (err) {
        showToast('Network error. Please try again.', 'error');
      }
    }
  </script>
</body>
</html>
