<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Footer Settings - Admin</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: #f0f2f5; color: #333; }
    .admin-layout { display: flex; min-height: 100vh; }
    
    /* Sidebar */
    .sidebar { width: 250px; background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); color: white; padding: 0; position: fixed; height: 100vh; overflow-y: auto; z-index: 100; }
    .sidebar-header { padding: 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.1); text-align: center; }
    .sidebar-logo { font-size: 36px; margin-bottom: 8px; }
    .sidebar-header h2 { font-size: 16px; font-weight: 700; color: #e2e8f0; }
    .admin-name { font-size: 12px; color: rgba(255,255,255,0.5); margin-top: 4px; }
    .sidebar-menu { list-style: none; padding: 12px 0; }
    .sidebar-menu .menu-label { font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.35); padding: 16px 20px 6px; }
    .sidebar-menu .menu-separator { height: 1px; background: rgba(255,255,255,0.1); margin: 12px 20px; }
    .sidebar-menu a { display: flex; align-items: center; gap: 10px; padding: 10px 20px; color: rgba(255,255,255,0.7); text-decoration: none; font-size: 13.5px; transition: all 0.2s; border-left: 3px solid transparent; }
    .sidebar-menu a:hover { background: rgba(255,255,255,0.08); color: white; border-left-color: #667eea; }
    .sidebar-menu a.active { background: rgba(102,126,234,0.2); color: white; border-left-color: #667eea; font-weight: 600; }
    .logout-link:hover { background: rgba(239,68,68,0.2) !important; color: #fca5a5 !important; }
    /* Main Content */
    .main-content { flex: 1; margin-left: 250px; padding: 28px; }
    .page-header { background: white; padding: 20px 28px; border-radius: 12px; margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
    .page-header h1 { font-size: 22px; font-weight: 700; color: #1a1a2e; }
    .breadcrumb { font-size: 13px; color: #94a3b8; }
    .panel { background: white; border-radius: 12px; padding: 28px; margin-bottom: 24px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
    .panel-title { font-size: 16px; font-weight: 700; color: #667eea; margin: 24px 0 12px; padding-bottom: 10px; border-bottom: 2px solid #f0f2f5; }
    .panel-title:first-child { margin-top: 0; }
    .btn { padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; transition: all 0.2s; }
    .btn-primary { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; }
    .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
    .btn-secondary { background: #f1f5f9; color: #475569; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px; }
    .form-control { width: 100%; padding: 10px 14px; border: 1.5px solid #e2e8f0; border-radius: 8px; font-size: 14px; font-family: inherit; background: #fafafa; transition: border-color 0.2s; }
    .form-control:focus { outline: none; border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,0.12); background: white; }
    textarea.form-control { min-height: 90px; resize: vertical; }
  </style>
</head>
<body>
  <div class="admin-layout">
    <%- include('../partials/sidebar', { admin, activePage: 'footer' }) %>
    <main class="main-content">
      <div class="page-header">
        <div>
          <h1>⚙️ Footer Settings</h1>
          <p class="breadcrumb">Admin → Footer</p>
        </div>
        <a href="/admin/dashboard" class="btn btn-secondary">← Dashboard</a>
      </div>

      <div class="panel">
        <form action="/admin/footer/update" method="POST" enctype="multipart/form-data">
          <div class="panel-title">📍 Contact Information</div>
          <div class="form-grid">
            <div class="form-group">
              <label>Company Name (English)</label>
              <input type="text" name="companyNameEn" value="<%= settings?.companyName?.en || '' %>" class="form-control">
            </div>
            <div class="form-group">
              <label>Company Name (বাংলা)</label>
              <input type="text" name="companyNameBn" value="<%= settings?.companyName?.bn || '' %>" class="form-control">
            </div>
            <div class="form-group">
              <label>Address (English)</label>
              <textarea name="addressEn" class="form-control"><%= settings?.address?.en || '' %></textarea>
            </div>
            <div class="form-group">
              <label>Address (বাংলা)</label>
              <textarea name="addressBn" class="form-control"><%= settings?.address?.bn || '' %></textarea>
            </div>
            <div class="form-group">
              <label>Phone Number</label>
              <input type="text" name="phone" value="<%= settings?.phone || '' %>" class="form-control">
            </div>
            <div class="form-group">
              <label>Email Address</label>
              <input type="email" name="email" value="<%= settings?.email || '' %>" class="form-control">
            </div>
            <div class="form-group">
              <label>WhatsApp Link</label>
              <input type="text" name="whatsapp" value="<%= settings?.whatsapp || '' %>" class="form-control" placeholder="https://wa.me/880...">
            </div>
          </div>

          <div class="panel-title">🔗 Social Media Links</div>
          <div class="form-grid">
            <div class="form-group"><label>Facebook URL</label><input type="text" name="facebook" value="<%= settings?.socialLinks?.facebook || '' %>" class="form-control"></div>
            <div class="form-group"><label>YouTube URL</label><input type="text" name="youtube" value="<%= settings?.socialLinks?.youtube || '' %>" class="form-control"></div>
            <div class="form-group"><label>Instagram URL</label><input type="text" name="instagram" value="<%= settings?.socialLinks?.instagram || '' %>" class="form-control"></div>
            <div class="form-group"><label>LinkedIn URL</label><input type="text" name="linkedin" value="<%= settings?.socialLinks?.linkedin || '' %>" class="form-control"></div>
          </div>

          <div class="panel-title">🕒 Business Hours</div>
          <div class="form-grid" style="grid-template-columns: 1fr;">
            <div style="background: #f8faff; border: 1.5px solid #e2e8f0; border-radius: 8px; padding: 16px;">
              <table style="width: 100%; border-collapse: collapse;">
                <thead>
                  <tr>
                    <th style="text-align: left; padding: 8px; color: #64748b; font-size: 13px;">Day</th>
                    <th style="text-align: left; padding: 8px; color: #64748b; font-size: 13px;">Open</th>
                    <th style="text-align: left; padding: 8px; color: #64748b; font-size: 13px;">Close</th>
                    <th style="text-align: center; padding: 8px; color: #64748b; font-size: 13px;">Closed</th>
                  </tr>
                </thead>
                <tbody>
                  <% const days = ['mon', 'tue', 'wed', 'thu', 'fri', 'sat', 'sun'];
                     const dayLabels = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
                     days.forEach(function(day, index) { 
                       const hours = settings?.businessHours?.[day] || { open: '09:00', close: '18:00', closed: false };
                  %>
                  <tr>
                    <td style="padding: 8px; font-weight: 600; font-size: 14px;"><%= dayLabels[index] %></td>
                    <td style="padding: 8px;">
                      <input type="time" class="form-control bh-open" data-day="<%= day %>" value="<%= hours.open %>" <%= hours.closed ? 'disabled' : '' %>>
                    </td>
                    <td style="padding: 8px;">
                      <input type="time" class="form-control bh-close" data-day="<%= day %>" value="<%= hours.close %>" <%= hours.closed ? 'disabled' : '' %>>
                    </td>
                    <td style="padding: 8px; text-align: center;">
                      <input type="checkbox" class="bh-closed" data-day="<%= day %>" <%= hours.closed ? 'checked' : '' %> style="width: 18px; height: 18px;" onchange="toggleHours(this, '<%= day %>')">
                    </td>
                  </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
            <input type="hidden" name="businessHours_json" id="businessHours_json">
          </div>

          <div class="panel-title">📄 Additional</div>
          <div class="form-grid">
            <div class="form-group">
              <label>About Text (English)</label>
              <textarea name="aboutTextEn" class="form-control"><%= settings?.aboutText?.en || '' %></textarea>
            </div>
            <div class="form-group">
              <label>About Text (বাংলা)</label>
              <textarea name="aboutTextBn" class="form-control"><%= settings?.aboutText?.bn || '' %></textarea>
            </div>
            <div class="form-group" style="grid-column:1/-1;">
              <label>Copyright Text</label>
              <input type="text" name="copyrightText" value="<%= settings?.copyrightText || '' %>" class="form-control" placeholder="© 2024 Nusrat International. All rights reserved.">
            </div>
          </div>

          <button type="submit" class="btn btn-primary" onclick="prepareSubmit()">💾 Save Footer Settings</button>
        </form>
      </div>
    </main>
  </div>
  
  <script>
    function toggleHours(checkbox, day) {
      const row = checkbox.closest('tr');
      const inputs = row.querySelectorAll('input[type="time"]');
      inputs.forEach(input => {
        input.disabled = checkbox.checked;
      });
    }

    function prepareSubmit() {
      const days = ['mon', 'tue', 'wed', 'thu', 'fri', 'sat', 'sun'];
      const businessHours = {};
      
      days.forEach(day => {
        const row = document.querySelector(`input.bh-closed[data-day="${day}"]`).closest('tr');
        businessHours[day] = {
          open: row.querySelector('.bh-open').value,
          close: row.querySelector('.bh-close').value,
          closed: row.querySelector('.bh-closed').checked
        };
      });
      
      document.getElementById('businessHours_json').value = JSON.stringify(businessHours);
      return true;
    }
  </script>
</body>
</html>
