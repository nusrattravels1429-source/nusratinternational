<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Admin Panel</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>

<body>
  <div class="admin-layout">
    <!-- Sidebar -->
    <%- include('./partials/sidebar', { admin: typeof admin !== 'undefined' ? admin : {}, activePage: 'dashboard' }) %>

    <!-- Main Content -->
    <main class="main-content">
      <div class="page-header">
        <div>
          <h1>Admin Dashboard</h1>
          <p>Welcome back, <strong><%= admin.username %></strong>. Here is what's happening today.</p>
        </div>
        <div class="user-info">
          <a href="/admin/logout" class="btn btn-danger">🚪 Logout</a>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats-grid">
        <div class="stat-card glass-card travel">
          <h3>Travel Packages</h3>
          <div class="number">
            <%= stats.travel %>
          </div>
        </div>
        <div class="stat-card glass-card hajj">
          <h3>Hajj Packages</h3>
          <div class="number">
            <%= stats.hajj %>
          </div>
        </div>
        <div class="stat-card glass-card work">
          <h3>Work Packages</h3>
          <div class="number">
            <%= stats.work %>
          </div>
        </div>
        <div class="stat-card glass-card gallery">
          <h3>Gallery Items</h3>
          <div class="number">
            <%= stats.gallery %>
          </div>
        </div>
        <div class="stat-card glass-card certifications">
          <h3>Certifications</h3>
          <div class="number">
            <%= stats.certifications %>
          </div>
        </div>
        <div class="stat-card glass-card team">
          <h3>Team Members</h3>
          <div class="number">
            <%= stats.team %>
          </div>
        </div>
        <div class="stat-card glass-card inbox" style="border-top: 4px solid var(--error-color);">
          <h3 style="color: var(--error-color);">📩 Unread Messages</h3>
          <div class="number" style="color: var(--error-color);">
            <%= stats.unreadMessages %>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="quick-actions glass-card">
        <h2>Quick Actions</h2>
        <div class="action-buttons">
          <a href="/admin/cards/create" class="btn btn-primary">+ Add New Card</a>
          <a href="/admin/cards" class="btn btn-secondary">View All Cards</a>
          <a href="/" target="_blank" class="btn btn-secondary">View Website</a>
        </div>
      </div>
    </main>
  </div>
</body>

</html>