<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Hero Slider</title>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .tab-btn { padding: 12px 24px; border-radius: 12px 12px 0 0; cursor: pointer; transition: all 0.3s; font-weight: 700; font-size: 14px; border: 1px solid var(--glass-border); border-bottom: none; background: rgba(255,255,255,0.05); color: var(--text-muted); }
    .tab-btn.active { background: var(--primary-color); color: white; border-color: var(--primary-color); box-shadow: 0 -4px 15px var(--primary-glow); }
    .tab-btn:not(.active):hover { background: rgba(255,255,255,0.1); color: white; }
    
    .tab-content { display: none; }
    .tab-content.active { display: block; animation: fadeIn 0.4s ease; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .upload-slot { border: 2px dashed var(--glass-border); border-radius: 20px; padding: 24px; text-align: center; transition: all 0.3s; position: relative; background: rgba(255,255,255,0.02); }
    .upload-slot:hover { border-color: var(--primary-color); background: rgba(99, 102, 241, 0.05); }
    .preview-img { width: 100%; height: 140px; object-fit: cover; border-radius: 12px; margin-bottom: 12px; border: 1px solid var(--glass-border); }
    
    .slide-item { display: flex; align-items: center; gap: 16px; padding: 16px; background: rgba(255,255,255,0.02); border: 1px solid var(--glass-border); border-radius: 16px; transition: all 0.3s; }
    .slide-item:hover { border-color: var(--primary-color); background: rgba(255,255,255,0.05); }
    
    .live-preview-box { height: 320px; background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border-radius: 24px; overflow: hidden; position: relative; border: 1px solid var(--glass-border); box-shadow: var(--shadow-lg); }
  </style>
</head>
<body>
<div class="flex">
    <%- include('../partials/sidebar', { admin: admin || {username:'Admin'}, activePage: activePage || 'hero-manage' }) %>

    <div class="main-content">
      <div class="page-header">
        <div>
          <h1>Hero Slider</h1>
          <p>Customize the main slider on your homepage.</p>
        </div>
        <div class="flex-actions">
          <a href="/" target="_blank" class="btn btn-primary">👁 View Site</a>
          <form action="/admin/hero-slider/reset" method="POST" onsubmit="return confirm('Reset all text content to defaults?')">
            <button type="submit" class="btn btn-secondary">🔄 Reset</button>
          </form>
        </div>
      </div>

      <div id="toast-container" class="toast-container"></div>

      <!-- Tabs -->
      <div class="tabs-container">
        <button class="tab-btn active" onclick="switchTab('images')">Images</button>
        <button class="tab-btn" onclick="switchTab('content')">Content</button>
        <button class="tab-btn" onclick="switchTab('settings')">Settings</button>
      </div>

      <!-- Images Tab -->
      <div id="tab-images" class="tab-content active">
        <div class="glass-card panel">
          <h2>Slider Images (4 Slots)</h2>
          <p class="text-muted">Recommended size: 1920x1080px. Max 5MB per image.</p>
          
          <form id="imageUploadForm" enctype="multipart/form-data" onsubmit="handleImageUpload(event)">
            <div class="grid-4" id="uploadSlots" style="margin: 24px 0;">
              <% for(let i = 0; i < 4; i++) { 
                const slide = heroSlider?.slides?.[i] || {};
              %>
              <div class="upload-slot" data-index="<%= i %>">
                <input type="file" name="sliderImages" accept="image/*" class="hidden" id="upload-<%= i %>" onchange="previewUpload(this, <%= i %>)">
                <% if (slide.imageUrl) { %>
                  <img src="<%= slide.imageUrl %>" alt="Slide <%= i + 1 %>" class="preview-img">
                  <button type="button" onclick="removeImage(<%= i %>)" class="btn btn-danger btn-sm" style="position: absolute; top: 10px; right: 10px;">×</button>
                  <p class="text-muted" style="font-size: 11px;">Replace image</p>
                <% } else { %>
                  <div class="preview-img" style="background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center;">
                    <span class="text-muted">Empty</span>
                  </div>
                  <p class="text-muted" style="font-size: 11px;">Click to upload</p>
                <% } %>
                <button type="button" onclick="document.getElementById('upload-<%= i %>').click()" class="btn btn-secondary btn-sm" style="margin-top: 10px; width: 100%;">
                  <%= slide.imageUrl ? 'Change' : 'Upload' %>
                </button>
              </div>
              <% } %>
            </div>
            
            <div class="flex-actions" style="justify-content: flex-end;">
              <button type="submit" class="btn btn-primary" id="saveImagesBtn">💾 Save Images</button>
            </div>
          </form>
                <!-- Slide Order -->
        <div class="glass-card panel" style="margin-top: 24px;">
          <h2>Slide Order & Status</h2>
          <div class="space-y-2" id="slideOrderList" style="margin-top: 16px;">
            <% (heroSlider?.slides || []).forEach((slide, index) => { %>
            <div class="slide-item" data-index="<%= index %>">
              <span class="drag-handle">⋮⋮</span>
              <div style="width: 64px; height: 40px; border-radius: 8px; overflow: hidden; background: rgba(255,255,255,0.1);">
                <% if (slide.imageUrl) { %>
                  <img src="<%= slide.imageUrl %>" style="width: 100%; height: 100%; object-fit: cover;">
                <% } %>
              </div>
              <span style="font-weight: 700; color: white; flex-grow: 1;">Slide <%= index + 1 %></span>
              <label style="display: flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 600; color: white; cursor: pointer;">
                <input type="checkbox" class="active-toggle" <%= slide.isActive !== false ? 'checked' : '' %> onchange="toggleSlideActive(<%= index %>, this.checked)">
                Active
              </label>
            </div>
            <% }) %>
          </div>
        </div>
      </div>

      <!-- Content Tab -->
      <div id="tab-content" class="tab-content">
        <form action="/admin/hero-slider/update" method="POST" enctype="multipart/form-data" onsubmit="handleContentSubmit(event)">
          <div class="glass-card panel">
            <h2>Global Text Content</h2>
            <p class="text-muted" style="margin-bottom: 24px;">This content is applied across all active slides.</p>
            
            <div style="margin-bottom: 24px;">
              <h3 style="color: var(--primary-color); font-size: 14px; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 1px;">Subtitle / Tagline</h3>
              <div class="form-row">
                <div class="form-group">
                  <label>English</label>
                  <input type="text" name="subtitle_en" value="<%= heroContent?.subtitle_en || '' %>" class="form-control" placeholder="✦ DISCOVER THE WORLD">
                </div>
                <div class="form-group">
                  <label>বাংলা (Bengali)</label>
                  <input type="text" name="subtitle_bn" value="<%= heroContent?.subtitle_bn || '' %>" class="form-control" placeholder="✦ বিশ্ব জুড়ে অন্বেষণ">
                </div>
              </div>
            </div>

            <div style="margin-bottom: 24px;">
              <h3 style="color: var(--primary-color); font-size: 14px; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 1px;">Main Title (HTML Allowed)</h3>
              <div class="form-row">
                <div class="form-group">
                  <label>English</label>
                  <input type="text" name="title_en" value="<%= heroContent?.title_en || '' %>" class="form-control" placeholder="Explore Beyond<br/><em>The Horizon</em>">
                </div>
                <div class="form-group">
                  <label>বাংলা (Bengali)</label>
                  <input type="text" name="title_bn" value="<%= heroContent?.title_bn || '' %>" class="form-control" placeholder="দিগন্তের ওপারে<br/><em>অন্বেষণ করুন</em>">
                </div>
              </div>
            </div>

            <div style="margin-bottom: 24px;">
              <h3 style="color: var(--primary-color); font-size: 14px; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 1px;">Description</h3>
              <div class="form-row">
                <div class="form-group">
                  <label>English</label>
                  <textarea name="description_en" class="form-control" style="min-height: 100px;"><%= heroContent?.description_en || '' %></textarea>
                </div>
                <div class="form-group">
                  <label>বাংলা (Bengali)</label>
                  <textarea name="description_bn" class="form-control" style="min-height: 100px;"><%= heroContent?.description_bn || '' %></textarea>
                </div>
              </div>
            </div>

            <div style="margin-bottom: 24px;">
              <h3 style="color: var(--primary-color); font-size: 14px; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 1px;">Call-to-Action</h3>
              <div class="form-row" style="grid-template-columns: 1fr 1fr 1fr;">
                <div class="form-group">
                  <label>Button Text (EN)</label>
                  <input type="text" name="ctaText_en" value="<%= heroContent?.ctaText_en || 'Start Exploring' %>" class="form-control">
                </div>
                <div class="form-group">
                  <label>Button Text (BN)</label>
                  <input type="text" name="ctaText_bn" value="<%= heroContent?.ctaText_bn || 'অন্বেষণ শুরু করুন' %>" class="form-control">
                </div>
                <div class="form-group">
                  <label>Link URL</label>
                  <input type="text" name="ctaLink" value="<%= heroContent?.ctaLink || '#travel' %>" class="form-control">
                </div>
              </div>
            </div>

            <div class="flex-actions" style="justify-content: flex-end;">
              <button type="submit" class="btn btn-primary">💾 Save Content</button>
            </div>
          </div>
        </form>

        <!-- Live Preview -->
        <div class="glass-card panel" style="margin-top: 24px;">
          <h2>Live Preview</h2>
          <div class="live-preview-box" id="livePreview" style="margin-top: 16px;">
            <div style="position: absolute; inset: 0; background: rgba(0,0,0,0.5); z-index: 1;"></div>
            <div style="position: relative; z-index: 2; height: 100%; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; color: white; padding: 40px;">
              <span style="font-size: 12px; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 8px; color: var(--primary-color);" id="preview-subtitle"><%= heroContent?.subtitle_en || '✦ DISCOVER THE WORLD' %></span>
              <h1 style="font-size: 32px; font-weight: 900; margin-bottom: 16px; line-height: 1.2;" id="preview-title"><%- heroContent?.title_en || 'Explore Beyond<br/><em>The Horizon</em>' %></h1>
              <p style="font-size: 16px; opacity: 0.8; max-width: 500px; margin-bottom: 24px;" id="preview-description"><%= heroContent?.description_en || '' %></p>
              <a href="#" class="btn btn-primary" id="preview-cta"><%= heroContent?.ctaText_en || 'Start Exploring' %></a>
            </div>
          </div>
        </div>
      </div>

      <!-- Settings Tab -->
      <div id="tab-settings" class="tab-content">
        <div class="glass-card panel">
          <h2>Slider Settings</h2>
          <div style="margin-top: 24px; display: grid; gap: 20px;">
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px; background: rgba(255,255,255,0.02); border-radius: 12px; border: 1px solid var(--glass-border);">
              <div>
                <h4 style="font-size: 15px; font-weight: 700; color: white;">Auto Play</h4>
                <p class="text-muted" style="font-size: 12px;">Cycle through slides automatically</p>
              </div>
              <input type="checkbox" name="autoPlay" <%= heroSlider?.settings?.autoPlay !== false ? 'checked' : '' %>>
            </div>

            <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px; background: rgba(255,255,255,0.02); border-radius: 12px; border: 1px solid var(--glass-border);">
              <div>
                <h4 style="font-size: 15px; font-weight: 700; color: white;">Show Navigation Dots</h4>
                <p class="text-muted" style="font-size: 12px;">Display dots at the bottom</p>
              </div>
              <input type="checkbox" name="showDots" <%= heroSlider?.settings?.showDots !== false ? 'checked' : '' %>>
            </div>

            <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px; background: rgba(255,255,255,0.02); border-radius: 12px; border: 1px solid var(--glass-border);">
              <div>
                <h4 style="font-size: 15px; font-weight: 700; color: white;">Show Arrows</h4>
                <p class="text-muted" style="font-size: 12px;">Display next/prev arrows</p>
              </div>
              <input type="checkbox" name="showArrows" <%= heroSlider?.settings?.showArrows !== false ? 'checked' : '' %>>
            </div>

            <div class="form-group">
              <label>Transition Speed (ms)</label>
              <input type="number" name="transitionSpeed" value="<%= heroSlider?.settings?.transitionSpeed || 5000 %>" class="form-control" min="1000" max="10000" step="500">
            </div>
          </div>

          <div class="flex-actions" style="justify-content: flex-end; margin-top: 24px;">
            <button type="button" onclick="saveSettings()" class="btn btn-primary">💾 Save Settings</button>
          </div>
        </div>
      </div>
</div>
</div>

<script>
    // Tab switching
    function switchTab(tabName) {
        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
        
        event.target.classList.add('active');
        document.getElementById('tab-' + tabName).classList.add('active');
    }

    // Image preview on upload
    function previewUpload(input, index) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const slot = input.closest('[data-index="' + index + '"]');
                const img = slot.querySelector('img.preview-img');
                const placeholder = slot.querySelector('.preview-placeholder');
                
                if (img) {
                    img.src = e.target.result;
                } else {
                    if (placeholder) {
                        placeholder.outerHTML = '<img src="' + e.target.result + '" alt="Preview" class="w-full h-32 object-cover rounded mb-2 preview-img">';
                    }
                }
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    // Remove image from slot
    function removeImage(index) {
        const input = document.getElementById('upload-' + index);
        input.value = '';
        const slot = input.closest('[data-index="' + index + '"]');
        const img = slot.querySelector('.preview-img');
        if (img) {
            img.outerHTML = '<div class="w-full h-32 bg-gray-100 rounded mb-2 flex items-center justify-center preview-placeholder"><span class="text-gray-400 text-sm">No image</span></div>';
        }
    }

    // Handle image form submit
    async function handleImageUpload(e) {
        e.preventDefault();
        const form = e.target;
        const formData = new FormData();
        
        // Ensure files retain their slot indices for the backend
        let hasFiles = false;
        for (let i = 0; i < 4; i++) {
            const fileInput = document.getElementById('upload-' + i);
            if (fileInput && fileInput.files.length > 0) {
                const file = fileInput.files[0];
                formData.append('sliderImages', file, `[${i}]_${file.name}`);
                hasFiles = true;
            }
        }
        
        if (!hasFiles) {
            showToast('No images selected to upload.', 'error');
            return;
        }
        const btn = document.getElementById('saveImagesBtn');
        const oldText = btn.innerText;
        
        btn.disabled = true;
        btn.innerText = 'Saving...';
        
        try {
            const res = await fetch('/admin/hero-slider/update', {
                method: 'POST',
                body: formData
            });
            
            if (res.ok) {
                showToast('Images saved successfully!', 'success');
                setTimeout(() => location.reload(), 1000);
            } else {
                const data = await res.json();
                showToast(data.message || 'Failed to save images', 'error');
            }
        } catch (error) {
            showToast('An error occurred while saving', 'error');
        } finally {
            btn.disabled = false;
            btn.innerText = oldText;
        }
    }

    // Handle content form submit
    async function handleContentSubmit(e) {
        e.preventDefault();
        const form = e.target;
        const formData = new FormData(form);
        
        try {
            const res = await fetch('/admin/hero-slider/update', {
                method: 'POST',
                body: formData
            });
            
            if (res.ok) {
                showToast('Text content saved successfully!', 'success');
                updateLivePreview(formData);
            } else {
                const data = await res.json();
                showToast(data.message || 'Failed to save content', 'error');
            }
        } catch (error) {
            showToast('An error occurred while saving', 'error');
        }
    }

    // Update live preview
    function updateLivePreview(formData) {
        document.getElementById('preview-subtitle').textContent = formData.get('subtitle_en') || '✦ DISCOVER THE WORLD';
        document.getElementById('preview-title').innerHTML = formData.get('title_en') || 'Explore Beyond<br/><em>The Horizon</em>';
        document.getElementById('preview-description').textContent = formData.get('description_en') || '';
        document.getElementById('preview-cta').textContent = formData.get('ctaText_en') || 'Start Exploring';
    }

    // Toggle slide active status
    async function toggleSlideActive(index, isActive) {
        try {
            const res = await fetch('/admin/hero-slider/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    slideOrders: JSON.stringify([{ index, isActive }])
                })
            });
            
            if (!res.ok) throw new Error('Failed to update');
        } catch (error) {
            showToast('Failed to update slide status', 'error');
        }
    }

    // Save settings
    async function saveSettings() {
        const autoPlay = document.querySelector('input[name="autoPlay"]').checked;
        const showDots = document.querySelector('input[name="showDots"]').checked;
        const showArrows = document.querySelector('input[name="showArrows"]').checked;
        const transitionSpeed = document.querySelector('input[name="transitionSpeed"]').value;
        
        try {
            const res = await fetch('/admin/hero-slider/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    settings: { autoPlay, showDots, showArrows, transitionSpeed: parseInt(transitionSpeed) }
                })
            });
            
            if (res.ok) {
                showToast('Settings saved successfully!', 'success');
            } else {
                showToast('Failed to save settings', 'error');
            }
        } catch (error) {
            showToast('An error occurred while saving', 'error');
        }
    }

    // Toast notification
    function showToast(message, type = 'success') {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        const color = type === 'success' ? 'bg-green-500' : 'bg-red-500';
        toast.className = `${color} text-white px-6 py-3 rounded shadow-lg mb-2 opacity-0 transition-opacity duration-300`;
        toast.innerText = message;
        
        container.appendChild(toast);
        setTimeout(() => toast.classList.remove('opacity-0'), 10);
        setTimeout(() => {
            toast.classList.add('opacity-0');
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }
</script>
</body>
</html>
