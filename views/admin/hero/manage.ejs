<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Hero Slider</title>
    <!-- Include Tailwind CSS if not already in the admin layout -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .sidebar { background: #f8fafc; border-right: 1px solid #e2e8f0; width: 250px; min-height: 100vh; position: fixed; left: 0; top: 0; padding: 20px; }
        .sidebar-menu li { margin-bottom: 10px; }
        .sidebar-menu a { text-decoration: none; color: #334155; }
        .sidebar-menu a.active { font-weight: bold; color: #2563eb; }
        .main-content { margin-left: 250px; padding: 20px; }
        .loading-indicator { font-style: italic; color: #888; }
        body { font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji"; }
    </style>
</head>
<body>
<div class="flex">
    <!-- Using existing partial via your previous setup, if it breaks adjust accordingly -->
    <%- include('../partials/sidebar', { admin: admin || {username:'Admin'}, activePage: activePage || 'hero-manage' }) %>

<div class="main-content flex-grow container mx-auto px-4 py-8 max-w-6xl">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Manage Hero Slider</h1>
        <button onclick="openModal()" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded shadow transition">
            + Add Slide
        </button>
    </div>

    <div id="toast-container" class="fixed top-4 right-4 z-50"></div>

    <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="grid grid-cols-12 bg-gray-100 p-4 font-semibold text-gray-700 border-b">
            <div class="col-span-1">Reorder</div>
            <div class="col-span-3">Image</div>
            <div class="col-span-3">Title (EN / BN)</div>
            <div class="col-span-3">Caption (EN / BN)</div>
            <div class="col-span-2 text-right">Actions</div>
        </div>

        <ul id="slides-list" class="divide-y divide-gray-200">
            <!-- Dynamically populated via JS -->
            <li class="p-8 text-center text-gray-500 loading-indicator">Loading slides...</li>
        </ul>
    </div>
</div>

<!-- Add/Edit Modal (Can be toggled) -->
<div id="slideFormModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-40 flex justify-center items-center">
    <div class="bg-white rounded-lg w-full max-w-2xl p-6 relative max-h-[90vh] overflow-y-auto">
        <button onclick="closeModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-800 font-bold text-xl">&times;</button>
        <h2 id="modalTitle" class="text-xl font-bold mb-4">Add New Slide</h2>
        
        <form id="slideForm" onsubmit="handleFormSubmit(event)">
            <input type="hidden" id="slideId" name="slideId">
            
            <div class="mb-4">
                <label class="block text-gray-700 font-medium mb-1">Image</label>
                <input type="file" id="heroImage" name="heroImage" accept="image/*" class="w-full border rounded p-2" onchange="previewImage(this)">
                <img id="imagePreview" class="hidden mt-2 max-h-40 rounded shadow">
            </div>

            <div class="grid grid-cols-2 gap-4 mb-4">
                <div>
                    <label class="block text-gray-700 font-medium mb-1">Title (EN)</label>
                    <input type="text" id="title_en" name="title.en" class="w-full border rounded p-2">
                </div>
                <div>
                    <label class="block text-gray-700 font-medium mb-1">Title (BN)</label>
                    <input type="text" id="title_bn" name="title.bn" class="w-full border rounded p-2">
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-6">
                <div>
                    <label class="block text-gray-700 font-medium mb-1">Caption (EN)</label>
                    <input type="text" id="caption_en" name="caption.en" class="w-full border rounded p-2">
                </div>
                <div>
                    <label class="block text-gray-700 font-medium mb-1">Caption (BN)</label>
                    <input type="text" id="caption_bn" name="caption.bn" class="w-full border rounded p-2">
                </div>
            </div>

            <div class="flex justify-end gap-2">
                <button type="button" onclick="closeModal()" class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" id="submitBtn">Save Slide</button>
            </div>
        </form>
    </div>
</div>
</div>

<script>
    let slidesData = [];
    let dragSourceEl = null;

    document.addEventListener("DOMContentLoaded", fetchSlides);

    async function fetchSlides() {
        try {
            const res = await fetch('/api/admin/hero-slides');
            const result = await res.json();
            if (result.success) {
                slidesData = result.data || [];
                renderSlides();
            } else {
                showToast(result.message, 'error');
            }
        } catch (error) {
            showToast('Failed to load slides', 'error');
        }
    }

    function renderSlides() {
        const list = document.getElementById('slides-list');
        list.innerHTML = '';
        
        if (slidesData.length === 0) {
            list.innerHTML = `<li class="p-8 text-center text-gray-500">No slides found. Add one above.</li>`;
            return;
        }

        slidesData.forEach((slide, index) => {
            const li = document.createElement('li');
            li.className = 'grid grid-cols-12 items-center p-4 hover:bg-gray-50 bg-white transition duration-150 ease-in-out';
            li.draggable = true;
            li.dataset.id = slide._id;
            
            // Drag and Drop Event Listeners
            li.addEventListener('dragstart', handleDragStart);
            li.addEventListener('dragover', handleDragOver);
            li.addEventListener('drop', handleDrop);
            li.addEventListener('dragend', handleDragEnd);

            li.innerHTML = \`
                <div class="col-span-1 text-gray-400 cursor-move text-xl" title="Drag to reorder">
                    &#9776;
                </div>
                <div class="col-span-3 pr-4">
                    <img src="\${slide.imageUrl}" alt="Slide Preview" class="w-full h-20 object-cover rounded shadow-sm">
                </div>
                <div class="col-span-3 pr-2">
                    <div class="text-sm font-semibold">\${slide.title?.en || '-'}</div>
                    <div class="text-xs text-gray-500">\${slide.title?.bn || '-'}</div>
                </div>
                <div class="col-span-3 pr-2">
                    <div class="text-sm">\${slide.caption?.en || '-'}</div>
                    <div class="text-xs text-gray-500">\${slide.caption?.bn || '-'}</div>
                </div>
                <div class="col-span-2 text-right flex justify-end gap-2">
                    <button onclick='editSlide(\${JSON.stringify(slide).replace(/'/g, "&#39;")})' class="text-blue-500 hover:text-blue-700 bg-blue-50 py-1 px-3 rounded">Edit</button>
                    \${slidesData.length > 1 
                        ? \`<button onclick="deleteSlide('\${slide._id}')" class="text-red-500 hover:text-red-700 bg-red-50 py-1 px-3 rounded">Delete</button>\` 
                        : \`<button disabled class="text-gray-400 bg-gray-100 py-1 px-3 rounded cursor-not-allowed" title="Minimum 1 slide required">Delete</button>\`
                    }
                </div>
            \`;
            list.appendChild(li);
        });
    }

    async function handleFormSubmit(e) {
        e.preventDefault();
        const slideId = document.getElementById('slideId').value;
        const formData = new FormData(e.target);
        
        const isEdit = !!slideId;
        const method = isEdit ? 'PUT' : 'POST';
        const url = isEdit ? \`/api/admin/hero-slides/\${slideId}\` : \`/api/admin/hero-slides\`;

        // Only enforce image on creation
        if (!isEdit && !document.getElementById('heroImage').files.length) {
            return showToast('Please select an image', 'error');
        }

        const btn = document.getElementById('submitBtn');
        const oldText = btn.innerText;
        btn.innerText = 'Saving...';
        btn.disabled = true;

        try {
            const res = await fetch(url, { method, body: formData });
            const data = await res.json();

            if (data.success) {
                showToast(data.message, 'success');
                closeModal();
                fetchSlides();
            } else {
                showToast(data.message, 'error');
            }
        } catch (error) {
            showToast('An error occurred while saving', 'error');
        } finally {
            btn.innerText = oldText;
            btn.disabled = false;
        }
    }

    async function deleteSlide(id) {
        if (!confirm('Are you sure you want to delete this slide?')) return;

        try {
            const res = await fetch(\`/api/admin/hero-slides/\${id}\`, { method: 'DELETE' });
            const data = await res.json();

            if (data.success) {
                showToast(data.message, 'success');
                fetchSlides();
            } else {
                showToast(data.message, 'error');
            }
        } catch (error) {
            showToast('An error occurred during deletion', 'error');
        }
    }

    // Modal Helpers
    function openModal() {
        document.getElementById('slideFormModal').classList.remove('hidden');
        document.getElementById('slideForm').reset();
        document.getElementById('slideId').value = '';
        document.getElementById('imagePreview').classList.add('hidden');
        document.getElementById('modalTitle').innerText = 'Add New Slide';
    }

    function closeModal() {
        document.getElementById('slideFormModal').classList.add('hidden');
    }

    function editSlide(slide) {
        openModal();
        document.getElementById('modalTitle').innerText = 'Edit Slide';
        document.getElementById('slideId').value = slide._id;
        document.getElementById('title_en').value = slide.title?.en || '';
        document.getElementById('title_bn').value = slide.title?.bn || '';
        document.getElementById('caption_en').value = slide.caption?.en || '';
        document.getElementById('caption_bn').value = slide.caption?.bn || '';
        
        const preview = document.getElementById('imagePreview');
        preview.src = slide.imageUrl;
        preview.classList.remove('hidden');
    }

    function previewImage(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const preview = document.getElementById('imagePreview');
                preview.src = e.target.result;
                preview.classList.remove('hidden');
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

    // Drag and Drop Logic
    function handleDragStart(e) {
        dragSourceEl = this;
        e.dataTransfer.effectAllowed = 'move';
        this.classList.add('opacity-50');
    }

    function handleDragOver(e) {
        if (e.preventDefault) { e.preventDefault(); }
        e.dataTransfer.dropEffect = 'move';
        return false;
    }

    function handleDrop(e) {
        if (e.stopPropagation) { e.stopPropagation(); }
        if (dragSourceEl !== this) {
            const list = document.getElementById('slides-list');
            const items = Array.from(list.children);
            const dropIndex = items.indexOf(this);
            const draggedIndex = items.indexOf(dragSourceEl);

            if (dropIndex > draggedIndex) {
                this.parentNode.insertBefore(dragSourceEl, this.nextSibling);
            } else {
                this.parentNode.insertBefore(dragSourceEl, this);
            }
            saveNewOrder();
        }
        return false;
    }

    function handleDragEnd(e) {
        this.classList.remove('opacity-50');
    }

    async function saveNewOrder() {
        const items = Array.from(document.getElementById('slides-list').children);
        const newOrder = items.map((li, index) => ({
            _id: li.dataset.id,
            order: index
        })).filter(item => item._id); // ensure valid ids

        if (newOrder.length === 0) return;

        try {
            const res = await fetch('/api/admin/hero-slides/reorder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(newOrder)
            });
            const data = await res.json();
            if (data.success) {
                showToast('Slides reordered successfully', 'success');
            }
        } catch (error) {
            showToast('Failed to save new order', 'error');
            fetchSlides(); // Revert UI if fail
        }
    }

    // Toast Utility
    function showToast(message, type = 'success') {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        const color = type === 'success' ? 'bg-green-500' : 'bg-red-500';
        toast.className = \`\${color} text-white px-6 py-3 rounded shadow-lg mb-2 opacity-0 transition-opacity duration-300\`;
        toast.innerText = message;
        
        container.appendChild(toast);
        setTimeout(() => toast.classList.remove('opacity-0'), 10);
        setTimeout(() => {
            toast.classList.add('opacity-0');
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }
</script>
</body>
</html>
