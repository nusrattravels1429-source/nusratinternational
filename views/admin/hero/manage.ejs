<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Hero Slider</title>
    <!-- Include Tailwind CSS if not already in the admin layout -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .sidebar { background: #f8fafc; border-right: 1px solid #e2e8f0; width: 250px; min-height: 100vh; position: fixed; left: 0; top: 0; padding: 20px; }
        .sidebar-menu li { margin-bottom: 10px; }
        .sidebar-menu a { text-decoration: none; color: #334155; }
        .sidebar-menu a.active { font-weight: bold; color: #2563eb; }
        .main-content { margin-left: 250px; padding: 20px; }
        .loading-indicator { font-style: italic; color: #888; }
        body { font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji"; }
    </style>
</head>
<body>
<div class="flex">
    <%- include('../partials/sidebar', { admin: admin || {username:'Admin'}, activePage: activePage || 'hero-manage' }) %>

<div class="main-content flex-grow container mx-auto px-4 py-8 max-w-6xl">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Manage Hero Slider</h1>
    </div>

    <div id="toast-container" class="fixed top-4 right-4 z-50"></div>

    <!-- Global Text Form -->
    <div class="bg-white rounded-lg shadow p-6 mb-8 border border-gray-200">
        <h2 class="text-xl font-bold text-gray-800 mb-4 border-b pb-2">Hero Text (Global for all images)</h2>
        <form action="/admin/content/update" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="section" value="homepage">
            <input type="hidden" name="key" value="homepage-hero-text">
            <input type="hidden" name="redirect" value="/admin/hero-manage">
            
            <div class="grid grid-cols-2 gap-4 mb-4">
                <div>
                    <label class="block text-gray-700 font-medium mb-1">Tagline/Subtitle (EN) (e.g., ✦ DISCOVER THE WORLD)</label>
                    <input type="text" name="subtitle_en" value="<%= heroText?.subtitle_en || '' %>" class="w-full border rounded p-2">
                </div>
                <div>
                    <label class="block text-gray-700 font-medium mb-1">Tagline/Subtitle (BN)</label>
                    <input type="text" name="subtitle_bn" value="<%= heroText?.subtitle_bn || '' %>" class="w-full border rounded p-2">
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-4">
                <div>
                    <label class="block text-gray-700 font-medium mb-1">Main Title (EN) (Use HTML like <code>&lt;br/&gt;</code> for newlines)</label>
                    <input type="text" name="title_en" value="<%= heroText?.title_en || '' %>" class="w-full border rounded p-2">
                </div>
                <div>
                    <label class="block text-gray-700 font-medium mb-1">Main Title (BN)</label>
                    <input type="text" name="title_bn" value="<%= heroText?.title_bn || '' %>" class="w-full border rounded p-2">
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-6">
                <div>
                    <label class="block text-gray-700 font-medium mb-1">Description (EN)</label>
                    <textarea name="description_en" class="w-full border rounded p-2 h-20"><%= heroText?.description_en || '' %></textarea>
                </div>
                <div>
                    <label class="block text-gray-700 font-medium mb-1">Description (BN)</label>
                    <textarea name="description_bn" class="w-full border rounded p-2 h-20"><%= heroText?.description_bn || '' %></textarea>
                </div>
            </div>

            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded shadow transition">
                💾 Save Global Text
            </button>
        </form>
    </div>

    <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-bold text-gray-800">Slider Images (Fixed 4 Slots)</h2>
    </div>

    <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="grid grid-cols-12 bg-gray-100 p-4 font-semibold text-gray-700 border-b">
            <div class="col-span-2">Slot</div>
            <div class="col-span-8">Image Preview</div>
            <div class="col-span-2 text-right">Actions</div>
        </div>

        <ul id="slides-list" class="divide-y divide-gray-200">
            <li class="p-8 text-center text-gray-500 loading-indicator">Loading slides...</li>
        </ul>
    </div>
</div>

<!-- Edit Modal -->
<div id="slideFormModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-[9999] flex justify-center items-center">
    <div class="bg-white rounded-lg w-full max-w-2xl p-6 relative max-h-[90vh] overflow-y-auto">
        <button onclick="closeModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-800 font-bold text-xl">&times;</button>
        <h2 id="modalTitle" class="text-xl font-bold mb-4">Upload Slide Image</h2>
        
        <form id="slideForm" enctype="multipart/form-data" onsubmit="handleFormSubmit(event)">
            <input type="hidden" id="slideId" name="slideId">
            
            <div class="mb-6">
                <label class="block text-gray-700 font-medium mb-1">Image (1600x900px recommended)</label>
                <input type="file" id="heroImage" name="heroImage" accept="image/*" class="w-full border rounded p-2" onchange="previewImage(this)" required>
                <img id="imagePreview" class="hidden mt-4 max-h-40 rounded shadow-md border">
            </div>

            <div class="flex justify-end gap-2">
                <button type="button" onclick="closeModal()" class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" id="submitBtn">Save Image</button>
            </div>
        </form>
    </div>
</div>
</div>

<script>
    let slidesData = [];

    document.addEventListener("DOMContentLoaded", fetchSlides);

    async function fetchSlides() {
        try {
            const res = await fetch('/admin/api/admin/hero-slides');
            const result = await res.json();
            if (result.success) {
                slidesData = result.data || [];
                renderSlides();
            } else {
                showToast(result.message, 'error');
            }
        } catch (error) {
            showToast('Failed to load slides', 'error');
        }
    }

    function renderSlides() {
        const list = document.getElementById('slides-list');
        list.innerHTML = '';
        
        if (slidesData.length === 0) {
            list.innerHTML = `<li class="p-8 text-center text-gray-500">No slides configured. Please refresh.</li>`;
            return;
        }

        slidesData.forEach((slide, index) => {
            const li = document.createElement('li');
            li.className = 'grid grid-cols-12 items-center p-4 hover:bg-gray-50 bg-white transition duration-150 ease-in-out';
            
            li.innerHTML = \`
                <div class="col-span-2 font-semibold text-gray-700">
                    Slide \${slide.order}
                </div>
                <div class="col-span-8 pr-4">
                    \${slide.imageUrl 
                        ? \`<img src="\${slide.imageUrl}" alt="Slide Preview" class="w-full h-24 object-cover rounded border shadow-sm">\`
                        : \`<div class="w-full h-24 bg-gray-100 flex items-center justify-center text-gray-400 rounded border border-dashed border-gray-300">No Image Uploaded</div>\`
                    }
                </div>
                <div class="col-span-2 text-right flex justify-end gap-2">
                    <button onclick='editSlide(\${JSON.stringify(slide).replace(/'/g, "&#39;")})' class="text-blue-500 hover:text-blue-700 bg-blue-50 py-1 px-3 rounded">
                        \${slide.imageUrl ? 'Change' : 'Upload'}
                    </button>
                </div>
            \`;
            list.appendChild(li);
        });
    }

    async function handleFormSubmit(e) {
        e.preventDefault();
        const slideId = document.getElementById('slideId').value;
        const formData = new FormData(e.target);
        
        const url = \`/admin/api/admin/hero-slides/\${slideId}\`;

        if (!document.getElementById('heroImage').files.length) {
            return showToast('Please select an image', 'error');
        }

        const btn = document.getElementById('submitBtn');
        const oldText = btn.innerText;
        btn.innerText = 'Uploading...';
        btn.disabled = true;

        try {
            const res = await fetch(url, { method: 'PUT', body: formData });
            const data = await res.json();

            if (data.success) {
                showToast(data.message, 'success');
                closeModal();
                fetchSlides();
            } else {
                showToast(data.message, 'error');
            }
        } catch (error) {
            showToast('An error occurred while saving', 'error');
        } finally {
            btn.innerText = oldText;
            btn.disabled = false;
        }
    }

    function openModal() {
        document.getElementById('slideFormModal').classList.remove('hidden');
        document.getElementById('slideForm').reset();
        document.getElementById('slideId').value = '';
        document.getElementById('imagePreview').classList.add('hidden');
        document.getElementById('modalTitle').innerText = 'Upload Slide Image';
    }

    function closeModal() {
        document.getElementById('slideFormModal').classList.add('hidden');
    }

    function editSlide(slide) {
        openModal();
        document.getElementById('modalTitle').innerText = \`Upload Image for Slide \${slide.order}\`;
        document.getElementById('slideId').value = slide._id;
        
        const preview = document.getElementById('imagePreview');
        if (slide.imageUrl) {
            preview.src = slide.imageUrl;
            preview.classList.remove('hidden');
        }
    }

    function previewImage(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const preview = document.getElementById('imagePreview');
                preview.src = e.target.result;
                preview.classList.remove('hidden');
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

    function showToast(message, type = 'success') {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        const color = type === 'success' ? 'bg-green-500' : 'bg-red-500';
        toast.className = \`\${color} text-white px-6 py-3 rounded shadow-lg mb-2 opacity-0 transition-opacity duration-300\`;
        toast.innerText = message;
        
        container.appendChild(toast);
        setTimeout(() => toast.classList.remove('opacity-0'), 10);
        setTimeout(() => {
            toast.classList.add('opacity-0');
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }
</script>
</body>
</html>
