<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Gallery - Admin</title>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .filters { display: flex; gap: 1rem; align-items: center; margin-bottom: 2rem; }
    
    /* Grid */
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem; }
    .card { overflow: hidden; position: relative; cursor: grab; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
    .card:active { cursor: grabbing; }
    .card.dragging { opacity: 0.5; border: 2px dashed var(--primary-color); }
    .card-img { width: 100%; height: 200px; object-fit: cover; border-bottom: 1px solid var(--glass-border); transition: transform 0.5s; }
    .card:hover .card-img { transform: scale(1.05); }
    .card-body { padding: 1.5rem; }
    .card-title { font-weight: 700; font-size: 16px; color: white; margin-bottom: 0.5rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .card-category { font-size: 0.7rem; text-transform: uppercase; padding: 4px 12px; background: rgba(99, 102, 241, 0.2); color: #6366f1; border-radius: 20px; display: inline-block; margin-bottom: 1rem; font-weight: 800; letter-spacing: 1px; }
    .card-status { font-size: 0.75rem; color: var(--success-color); font-weight: 700; display: flex; align-items: center; gap: 6px; }
    .card-status::before { content: ''; width: 8px; height: 8px; border-radius: 50%; background: currentColor; }
    .card-status.inactive { color: var(--error-color); }
    .card-actions { display: flex; gap: 10px; margin-top: 1.5rem; }
    .card-actions .btn { flex: 1; justify-content: center; font-size: 13px; padding: 10px; }
    .drag-handle { position: absolute; top: 1rem; right: 1rem; background: rgba(0,0,0,0.6); color: white; border-radius: 8px; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: 20px; cursor: grab; z-index: 10; border: 1px solid rgba(255,255,255,0.1); }
    .drag-handle:hover { background: var(--primary-color); }

    /* Modal Premium Styles */
    .modal-overlay { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(12px); z-index: 9999; display: none; align-items: center; justify-content: center; padding: 20px; }
    .modal-overlay.active { display: flex; }
    .modal { background: #1e293b; width: 100%; max-width: 650px; max-height: 90vh; border-radius: 30px; border: 1px solid var(--glass-border); box-shadow: 0 30px 60px -12px rgba(0,0,0,0.5); overflow-y: auto; padding: 40px; animation: slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
    .modal h2 { margin-bottom: 2rem; font-size: 24px; font-weight: 800; color: white; letter-spacing: -0.5px; }
    .modal-actions { display: flex; justify-content: flex-end; gap: 1rem; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--glass-border); }
  </style>
</head>
<body>
  <div class="layout">
    <%- include('../partials/sidebar', { admin: typeof admin !== 'undefined' ? admin : {}, activePage: 'gallery' }) %>
    
    <div class="main-content">
      <div class="page-header">
        <div>
          <h1>Gallery Management</h1>
          <p>Organize and manage your website's visual content. Drag to reorder.</p>
        </div>
        <button class="btn btn-primary" onclick="openModal()">+ Upload Image</button>
      </div>

      <div class="filters glass-card">
        <div class="filter-group">
          <label for="filterCategory">Filter Category:</label>
          <select id="filterCategory" onchange="renderGallery()">
            <option value="all">All Categories</option>
            <option value="general">General</option>
            <option value="hajj">Hajj</option>
            <option value="umrah">Umrah</option>
            <option value="team">Team</option>
            <option value="events">Events</option>
          </select>
        </div>
        <button class="btn btn-secondary" onclick="saveOrder()" id="saveOrderBtn" style="display:none; margin-left:auto;">💾 Save Order</button>
      </div>

      <div class="grid" id="galleryGrid">
        <!-- JS rendered content -->
        <p style="color: #6b7280; font-style: italic;">Loading gallery...</p>
      </div>
    </div>
  </div>

  <!-- Modal -->
  <div class="modal-overlay" id="galleryModal">
    <div class="modal">
      <h2 id="modalTitle">Upload New Image</h2>
      <form id="galleryForm" onsubmit="handleSubmit(event)">
        <input type="hidden" id="itemId">
        
        <div class="form-group" id="imageInputGroup">
          <label for="galleryImage">Image File *</label>
          <input type="file" id="galleryImage" name="galleryImage" accept="image/*" class="form-control">
        </div>

        <div class="form-group">
          <label>Category *</label>
          <select id="category" name="category" required class="form-control">
            <option value="general">General</option>
            <option value="hajj">Hajj</option>
            <option value="umrah">Umrah</option>
            <option value="team">Team</option>
            <option value="events">Events</option>
          </select>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="titleEn">Title (English)</label>
            <input type="text" id="titleEn" name="titleEn" placeholder="Optional title" class="form-control">
          </div>
          <div class="form-group">
            <label for="titleBn">Title (Bengali)</label>
            <input type="text" id="titleBn" name="titleBn" class="form-control">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="captionEn">Caption (English)</label>
            <textarea id="captionEn" name="captionEn" placeholder="Shown on hover overlay" class="form-control"></textarea>
          </div>
          <div class="form-group">
            <label for="captionBn">Caption (Bengali)</label>
            <textarea id="captionBn" name="captionBn" class="form-control"></textarea>
          </div>
        </div>

        <div class="form-group toggle-group">
          <input type="checkbox" id="isActive" name="isActive" checked>
          <label for="isActive" style="margin:0;">Active (Show on public site)</label>
        </div>

        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
          <button type="submit" class="btn btn-primary" id="submitBtn">Save Image</button>
        </div>
      </form>
    </div>
  </div>

  <div class="toast-container" id="toastContainer"></div>

  <script>
    let galleryItems = [];
    let draggedItem = null;
    let orderChanged = false;

    // Fetch and render
    async function fetchGallery() {
      try {
        const res = await fetch('/api/admin/gallery');
        const data = await res.json();
        if (data.success) {
          galleryItems = data.data;
          renderGallery();
        } else throw new Error(data.message);
      } catch (err) {
        showToast('Failed to load gallery items', 'error');
      }
    }

    function renderGallery() {
      const grid = document.getElementById('galleryGrid');
      const filter = document.getElementById('filterCategory').value;
      grid.innerHTML = '';

      let items = galleryItems;
      if (filter !== 'all') {
        items = galleryItems.filter(i => i.category === filter);
      }

      if (items.length === 0) {
        grid.innerHTML = '<p style="color:#6b7280;">No images found.</p>';
        return;
      }

      items.forEach((item, index) => {
        const card = document.createElement('div');
        card.className = 'card glass-card';
        card.draggable = true;
        card.dataset.id = item._id;
        card.dataset.index = index;

        card.addEventListener('dragstart', handleDragStart);
        card.addEventListener('dragover', handleDragOver);
        card.addEventListener('drop', handleDrop);
        card.addEventListener('dragend', handleDragEnd);

        card.innerHTML = `
          <div class="drag-handle">≡</div>
          <img src="${item.imageUrl}" class="card-img" alt="${item.title?.en || 'Gallery Image'}">
          <div class="card-body">
            <div class="card-category">${item.category}</div>
            <h3 class="card-title">${item.title?.en || 'Untitled'}</h3>
            <div class="card-status ${!item.isActive ? 'inactive' : ''}">${item.isActive ? 'Active' : 'Hidden'}</div>
            <div class="card-actions">
              <button class="btn btn-secondary" onclick="openModal('${item._id}')">Edit</button>
              <button class="btn btn-danger" onclick="deleteItem('${item._id}')">Delete</button>
            </div>
          </div>
        `;
        grid.appendChild(card);
      });
    }

    // Modal logic
    function openModal(id = null) {
      const modal = document.getElementById('galleryModal');
      const form = document.getElementById('galleryForm');
      form.reset();
      
      const fileInput = document.getElementById('galleryImage');
      fileInput.required = !id; // Required for new upload

      if (id) {
        document.getElementById('modalTitle').textContent = 'Edit Image';
        const item = galleryItems.find(i => i._id === id);
        if (item) {
          document.getElementById('itemId').value = item._id;
          document.getElementById('category').value = item.category;
          document.getElementById('titleEn').value = item.title?.en || '';
          document.getElementById('titleBn').value = item.title?.bn || '';
          document.getElementById('captionEn').value = item.caption?.en || '';
          document.getElementById('captionBn').value = item.caption?.bn || '';
          document.getElementById('isActive').checked = item.isActive;
        }
      } else {
        document.getElementById('modalTitle').textContent = 'Upload New Image';
        document.getElementById('itemId').value = '';
      }
      modal.classList.add('active');
    }

    function closeModal() {
      document.getElementById('galleryModal').classList.remove('active');
    }

    // Form submit logic
    async function handleSubmit(e) {
      e.preventDefault();
      const id = document.getElementById('itemId').value;
      const form = document.getElementById('galleryForm');
      const formData = new FormData(form);
      const btn = document.getElementById('submitBtn');
      
      btn.disabled = true;
      btn.textContent = 'Saving...';

      const url = id ? '/api/admin/gallery/' + id : '/api/admin/gallery';
      const method = id ? 'PUT' : 'POST';

      try {
        const res = await fetch(url, { method, body: formData });
        const data = await res.json();
        
        if (data.success) {
          showToast(data.message, 'success');
          closeModal();
          fetchGallery();
        } else {
          throw new Error(data.message);
        }
      } catch (err) {
        showToast(err.message, 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Save Image';
      }
    }

    // Delete logic
    async function deleteItem(id) {
      if (!confirm('Are you sure you want to delete this image?')) return;
      
      try {
        const res = await fetch('/api/admin/gallery/' + id, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) {
          showToast(data.message, 'success');
          fetchGallery();
        } else throw new Error(data.message);
      } catch (err) {
        showToast(err.message, 'error');
      }
    }

    // DnD logic
    function handleDragStart(e) {
      draggedItem = this;
      setTimeout(() => this.classList.add('dragging'), 0);
    }
    
    function handleDragOver(e) {
      e.preventDefault();
      const grid = document.getElementById('galleryGrid');
      const afterElement = getDragAfterElement(grid, e.clientY, e.clientX);
      if (afterElement == null) {
        grid.appendChild(draggedItem);
      } else {
        grid.insertBefore(draggedItem, afterElement);
      }
    }
    
    function handleDrop(e) {
      e.preventDefault();
      orderChanged = true;
      document.getElementById('saveOrderBtn').style.display = 'inline-flex';
    }
    
    function handleDragEnd() {
      this.classList.remove('dragging');
      draggedItem = null;
    }

    function getDragAfterElement(container, y, x) {
      const draggableElements = [...container.querySelectorAll('.card:not(.dragging)')];
      return draggableElements.reduce((closest, child) => {
        const box = child.getBoundingClientRect();
        const offset = y - box.top - box.height / 2;
        // Simple 1D-like check for flex/grid
        if (offset < 0 && offset > closest.offset) {
          return { offset: offset, element: child }
        } else {
          return closest;
        }
      }, { offset: Number.NEGATIVE_INFINITY }).element;
    }

    // Save Order
    async function saveOrder() {
      const cards = document.querySelectorAll('.card');
      const items = Array.from(cards).map((card, idx) => ({
        _id: card.dataset.id,
        order: idx
      }));

      try {
        document.getElementById('saveOrderBtn').textContent = 'Saving...';
        const res = await fetch('/api/admin/gallery/reorder', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items })
        });
        const data = await res.json();
        if (data.success) {
          showToast('Order saved', 'success');
          document.getElementById('saveOrderBtn').style.display = 'none';
          orderChanged = false;
        } else throw new Error(data.message);
      } catch(err) {
        showToast('Failed to save order', 'error');
      } finally {
        document.getElementById('saveOrderBtn').textContent = '💾 Save Order';
      }
    }

    // Toast
    function showToast(msg, type) {
      const container = document.getElementById('toastContainer');
      const toast = document.createElement('div');
      toast.className = `toast ${type}`;
      toast.textContent = msg;
      container.appendChild(toast);
      setTimeout(() => toast.remove(), 3000);
    }

    // Initial load
    document.addEventListener('DOMContentLoaded', fetchGallery);
  </script>
</body>
</html>
