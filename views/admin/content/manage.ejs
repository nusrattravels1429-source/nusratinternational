<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage <%= section.charAt(0).toUpperCase() + section.slice(1) %> Content - Admin</title>
  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
  <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: #f0f2f5; color: #333; }
    .admin-layout { display: flex; min-height: 100vh; }

    /* Sidebar */
    .sidebar { width: 250px; background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); color: white; padding: 0; position: fixed; height: 100vh; overflow-y: auto; z-index: 100; }
    .sidebar-header { padding: 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.1); text-align: center; }
    .sidebar-logo { font-size: 36px; margin-bottom: 8px; }
    .sidebar-header h2 { font-size: 16px; font-weight: 700; color: #e2e8f0; }
    .admin-name { font-size: 12px; color: rgba(255,255,255,0.5); margin-top: 4px; }
    .sidebar-menu { list-style: none; padding: 12px 0; }
    .sidebar-menu .menu-label { font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.35); padding: 16px 20px 6px; }
    .sidebar-menu .menu-separator { height: 1px; background: rgba(255,255,255,0.1); margin: 12px 20px; }
    .sidebar-menu a { display: flex; align-items: center; gap: 10px; padding: 10px 20px; color: rgba(255,255,255,0.7); text-decoration: none; font-size: 13.5px; transition: all 0.2s; border-left: 3px solid transparent; }
    .sidebar-menu a:hover { background: rgba(255,255,255,0.08); color: white; border-left-color: #667eea; }
    .sidebar-menu a.active { background: rgba(102,126,234,0.2); color: white; border-left-color: #667eea; font-weight: 600; }
    .logout-link:hover { background: rgba(239,68,68,0.2) !important; color: #fca5a5 !important; }

    /* Main Content */
    .main-content { flex: 1; margin-left: 250px; padding: 28px; }
    .page-header { background: white; padding: 20px 28px; border-radius: 12px; margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
    .page-header h1 { font-size: 22px; font-weight: 700; color: #1a1a2e; }
    .breadcrumb { font-size: 13px; color: #94a3b8; }

    /* Panels */
    .panel { background: white; border-radius: 12px; padding: 28px; margin-bottom: 24px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
    .panel-title { font-size: 16px; font-weight: 700; color: #1a1a2e; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 2px solid #f0f2f5; display: flex; align-items: center; gap: 8px; }

    /* Form */
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-group { margin-bottom: 18px; }
    .form-group.full { grid-column: 1 / -1; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px; }
    .form-group small { display: block; color: #94a3b8; font-size: 12px; margin-top: 4px; }
    .form-control { width: 100%; padding: 10px 14px; border: 1.5px solid #e2e8f0; border-radius: 8px; font-size: 14px; font-family: inherit; transition: border-color 0.2s, box-shadow 0.2s; background: #fafafa; }
    .form-control:focus { outline: none; border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,0.12); background: white; }
    textarea.form-control { min-height: 110px; resize: vertical; }

    /* Bilingual tabs */
    .lang-tabs { display: flex; gap: 0; margin-bottom: 16px; border-bottom: 2px solid #e2e8f0; }
    .lang-tab { padding: 8px 20px; cursor: pointer; font-size: 13px; font-weight: 600; color: #94a3b8; border-bottom: 2px solid transparent; margin-bottom: -2px; background: none; border-top: none; border-left: none; border-right: none; transition: all 0.2s; }
    .lang-tab.active { color: #667eea; border-bottom-color: #667eea; }
    .lang-panel { display: none; }
    .lang-panel.active { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

    /* Slide cards */
    .slides-container { }
    .slide-card { background: #f8faff; border: 1.5px solid #e2e8f0; border-radius: 10px; padding: 20px; margin-bottom: 16px; position: relative; }
    .slide-card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
    .slide-card-title { font-size: 14px; font-weight: 700; color: #374151; }
    .slide-number { background: #667eea; color: white; width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; }
    .slide-preview { width: 100%; height: 140px; object-fit: cover; border-radius: 8px; margin-bottom: 12px; background: #e2e8f0; }
    .slide-preview-placeholder { width: 100%; height: 140px; border-radius: 8px; margin-bottom: 12px; background: linear-gradient(135deg, #e2e8f0, #cbd5e1); display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 13px; }

    /* Image preview */
    .image-preview-wrap { margin-top: 8px; }
    .image-preview-wrap img { max-height: 100px; border-radius: 6px; object-fit: cover; }

    /* Contact grid */
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

    /* Buttons */
    .btn { padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; transition: all 0.2s; }
    .btn-primary { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; }
    .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(102,126,234,0.4); }
    .btn-secondary { background: #f1f5f9; color: #475569; }
    .btn-secondary:hover { background: #e2e8f0; }
    .btn-danger { background: #fee2e2; color: #dc2626; }
    .btn-danger:hover { background: #fecaca; }
    .btn-sm { padding: 7px 14px; font-size: 12px; }

    /* Toast */
    .toast { position: fixed; top: 20px; right: 20px; background: #10b981; color: white; padding: 14px 24px; border-radius: 10px; font-size: 14px; font-weight: 600; z-index: 9999; animation: slideIn 0.3s ease; box-shadow: 0 4px 20px rgba(0,0,0,0.15); }
    .toast.error { background: #ef4444; }
    @keyframes slideIn { from { transform: translateX(100px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

    @media (max-width: 768px) {
      .sidebar { transform: translateX(-100%); }
      .main-content { margin-left: 0; }
      .form-grid, .lang-panel.active, .contact-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<div class="admin-layout">
  <%- include('../partials/sidebar', { admin, activePage: section }) %>

  <main class="main-content">
    <div class="page-header">
      <div>
        <h1><%=
          section === 'homepage' ? '🏠 Homepage Content' :
          section === 'ticketing' ? '🎫 Ticketing Content' :
          section === 'travel' ? '✈️ Travel Page Content' :
          section === 'hajj' ? '🕋 Hajj Page Content' :
          section === 'work' ? '💼 Work Page Content' :
          section === 'contact' ? '📞 Contact Information' :
          section === 'about' ? 'ℹ️ About Page Content' : section + ' Content'
        %></h1>
        <p class="breadcrumb">Admin → Content → <%= section %></p>
      </div>
      <a href="/admin/dashboard" class="btn btn-secondary">← Dashboard</a>
    </div>

    <!-- ===== HOMEPAGE ===== -->
    <% if (section === 'homepage') { %>

    <div class="panel" style="background:#eff6ff;border:1px solid #bfdbfe;">
      <div class="panel-title">🎬 Hero Slider & Global Text</div>
      <p style="font-size:14px; margin-bottom:12px;">The hero slider images and its global text are managed in a dedicated section.</p>
      <a href="/admin/hero-manage" class="btn btn-primary" style="display:inline-block; text-decoration:none;">Go to Manage Hero Slider</a>
    </div>

    <!-- ===== TICKETING ===== -->
    <% } else if (section === 'ticketing') { %>
    <div class="panel">
      <div class="panel-title">🎫 Ticketing Section Info</div>
      <form action="/admin/content/update" method="POST">
        <input type="hidden" name="section" value="ticketing">
        <input type="hidden" name="key" value="ticketing-intro">
        <div class="form-grid">
          <div class="form-group">
            <label>Section Title (English)</label>
            <input type="text" name="title_en" value="<%= content['ticketing-intro']?.title_en || '' %>" class="form-control" placeholder="Air Ticketing Services">
          </div>
          <div class="form-group">
            <label>Section Title (বাংলা)</label>
            <input type="text" name="title_bn" value="<%= content['ticketing-intro']?.title_bn || '' %>" class="form-control" placeholder="এয়ার টিকেটিং সেবা">
          </div>
          <div class="form-group">
            <label>Phone Number</label>
            <input type="text" name="phone" value="<%= content['ticketing-intro']?.phone || '' %>" class="form-control" placeholder="01713-165116">
          </div>
          <div class="form-group">
            <label>WhatsApp Link</label>
            <input type="text" name="whatsapp" value="<%= content['ticketing-intro']?.whatsapp || '' %>" class="form-control" placeholder="https://wa.me/8801713165116">
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" value="<%= content['ticketing-intro']?.email || '' %>" class="form-control" placeholder="info@nusrat.com">
          </div>
          <div class="form-group full">
            <label>Description (English)</label>
            <textarea name="description_en" class="form-control"><%= content['ticketing-intro']?.description_en || '' %></textarea>
          </div>
          <div class="form-group full">
            <label>Description (বাংলা)</label>
            <textarea name="description_bn" class="form-control"><%= content['ticketing-intro']?.description_bn || '' %></textarea>
          </div>
        </div>
        <button type="submit" class="btn btn-primary">💾 Save Ticketing Info</button>
      </form>
    </div>

    <!-- ===== TRAVEL PAGE ===== -->
    <% } else if (section === 'travel') { %>
    <div class="panel">
      <div class="panel-title">✈️ Travel Page Static Content</div>
      <form action="/admin/content/update" method="POST">
        <input type="hidden" name="section" value="travel">
        <input type="hidden" name="key" value="travel-page-intro">
        <div class="form-grid">
          <div class="form-group">
            <label>Page Header (English)</label>
            <input type="text" name="page_header_en" value="<%= content['travel-page-intro']?.page_header_en || '' %>" class="form-control" placeholder="Popular Destinations">
          </div>
          <div class="form-group">
            <label>Page Header (বাংলা)</label>
            <input type="text" name="page_header_bn" value="<%= content['travel-page-intro']?.page_header_bn || '' %>" class="form-control" placeholder="জনপ্রিয় গন্তব্য">
          </div>
          <div class="form-group">
            <label>Contact Phone</label>
            <input type="text" name="contact_phone" value="<%= content['travel-page-intro']?.contact_phone || '' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Contact WhatsApp URL</label>
            <input type="text" name="contact_whatsapp" value="<%= content['travel-page-intro']?.contact_whatsapp || '' %>" class="form-control">
          </div>
          <div class="form-group full">
            <label>Description (English)</label>
            <textarea name="header_desc_en" class="form-control"><%= content['travel-page-intro']?.header_desc_en || '' %></textarea>
          </div>
          <div class="form-group full">
            <label>Description (বাংলা)</label>
            <textarea name="header_desc_bn" class="form-control"><%= content['travel-page-intro']?.header_desc_bn || '' %></textarea>
          </div>
        </div>
        <button type="submit" class="btn btn-primary">💾 Save Travel Page Content</button>
      </form>
    </div>

    <!-- ===== HAJJ PAGE ===== -->
    <% } else if (section === 'hajj') { %>
    <div class="panel">
      <div class="panel-title">🕋 Hajj/Umrah Page Content</div>
      <form action="/admin/content/update" method="POST">
        <input type="hidden" name="section" value="hajj">
        <input type="hidden" name="key" value="hajj-page-intro">
        <div class="form-grid">
          <div class="form-group">
            <label>Page Title (English)</label>
            <input type="text" name="page_title_en" value="<%= content['hajj-page-intro']?.page_title_en || 'Hajj & Umrah Packages' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Page Title (বাংলা)</label>
            <input type="text" name="page_title_bn" value="<%= content['hajj-page-intro']?.page_title_bn || 'হজ ও উমরাহ প্যাকেজ' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Contact Phone</label>
            <input type="text" name="contact_phone" value="<%= content['hajj-page-intro']?.contact_phone || '' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Contact WhatsApp</label>
            <input type="text" name="contact_whatsapp" value="<%= content['hajj-page-intro']?.contact_whatsapp || '' %>" class="form-control">
          </div>
          <div class="form-group full">
            <label>Description (English)</label>
            <textarea name="description_en" class="form-control"><%= content['hajj-page-intro']?.description_en || '' %></textarea>
          </div>
          <div class="form-group full">
            <label>Description (বাংলা)</label>
            <textarea name="description_bn" class="form-control"><%= content['hajj-page-intro']?.description_bn || '' %></textarea>
          </div>
        </div>
        <button type="submit" class="btn btn-primary">💾 Save Hajj Page Content</button>
      </form>
    </div>

    <!-- ===== WORK PAGE ===== -->
    <% } else if (section === 'work') { %>
    <div class="panel">
      <div class="panel-title">💼 Work Abroad Page Content</div>
      <form action="/admin/content/update" method="POST">
        <input type="hidden" name="section" value="work">
        <input type="hidden" name="key" value="work-page-intro">
        <div class="form-grid">
          <div class="form-group">
            <label>Page Title (English)</label>
            <input type="text" name="page_title_en" value="<%= content['work-page-intro']?.page_title_en || 'Work Abroad Programs' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Page Title (বাংলা)</label>
            <input type="text" name="page_title_bn" value="<%= content['work-page-intro']?.page_title_bn || 'বিদেশে কাজের সুযোগ' %>" class="form-control">
          </div>
          <div class="form-group full">
            <label>Intro Text (English)</label>
            <textarea name="intro_en" class="form-control"><%= content['work-page-intro']?.intro_en || '' %></textarea>
          </div>
          <div class="form-group full">
            <label>Intro Text (বাংলা)</label>
            <textarea name="intro_bn" class="form-control"><%= content['work-page-intro']?.intro_bn || '' %></textarea>
          </div>
        </div>
        <button type="submit" class="btn btn-primary">💾 Save Work Page Content</button>
      </form>
    </div>

    <!-- ===== CONTACT ===== -->
    <% } else if (section === 'contact') { %>
    <div class="panel">
      <div class="panel-title">📞 Contact Page Information</div>
      <form action="/admin/content/update" method="POST">
        <input type="hidden" name="section" value="contact">
        <input type="hidden" name="key" value="contact-info">
        <div class="form-grid">
          <div class="form-group">
            <label>Primary Phone</label>
            <input type="text" name="phone_primary" value="<%= content['contact-info']?.phone_primary || '' %>" class="form-control" placeholder="01713-165116">
          </div>
          <div class="form-group">
            <label>Secondary Phone</label>
            <input type="text" name="phone_secondary" value="<%= content['contact-info']?.phone_secondary || '' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>WhatsApp Link</label>
            <input type="text" name="whatsapp_link" value="<%= content['contact-info']?.whatsapp_link || '' %>" class="form-control" placeholder="https://wa.me/...">
          </div>
          <div class="form-group">
            <label>Email Address</label>
            <input type="email" name="email_address" value="<%= content['contact-info']?.email_address || '' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Business Address (English)</label>
            <textarea name="address_en" class="form-control"><%= content['contact-info']?.address_en || '' %></textarea>
          </div>
          <div class="form-group">
            <label>Business Address (বাংলা)</label>
            <textarea name="address_bn" class="form-control"><%= content['contact-info']?.address_bn || '' %></textarea>
          </div>
          <div class="form-group full">
            <label>Google Maps Embed URL</label>
            <input type="text" name="google_maps_url" value="<%= content['contact-info']?.google_maps_url || '' %>" class="form-control" placeholder="https://maps.google.com/maps?...">
            <small>Paste the URL from the Google Maps &lt;iframe src="..."&gt; attribute</small>
          </div>
          <div class="form-group full">
            <label>Business Hours (English)</label>
            <textarea name="hours_en" class="form-control" placeholder="Monday - Friday: 9:00 AM - 6:00 PM&#10;Saturday: 9:00 AM - 2:00 PM&#10;Sunday: Closed"><%= content['contact-info']?.hours_en || '' %></textarea>
          </div>
          <div class="form-group full">
            <label>Business Hours (বাংলা)</label>
            <textarea name="hours_bn" class="form-control"><%= content['contact-info']?.hours_bn || '' %></textarea>
          </div>
        </div>
        <button type="submit" class="btn btn-primary">💾 Save Contact Information</button>
      </form>
    </div>

    <!-- ===== ABOUT ===== -->
    <% } else if (section === 'about') { %>
    <div class="panel">
      <div class="panel-title">ℹ️ About Page - Header</div>
      <form action="/admin/content/update" method="POST">
        <input type="hidden" name="section" value="about">
        <input type="hidden" name="key" value="about-header">
        <div class="form-grid">
          <div class="form-group">
            <label>Page Title (English)</label>
            <input type="text" name="page_title_en" value="<%= content['about-header']?.page_title_en || '' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Page Title (বাংলা)</label>
            <input type="text" name="page_title_bn" value="<%= content['about-header']?.page_title_bn || '' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Tagline (English)</label>
            <input type="text" name="tagline_en" value="<%= content['about-header']?.tagline_en || '' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Tagline (বাংলা)</label>
            <input type="text" name="tagline_bn" value="<%= content['about-header']?.tagline_bn || '' %>" class="form-control">
          </div>
          <div class="form-group full">
            <label>Main Description (English)</label>
            <textarea name="description_en" class="form-control"><%= content['about-header']?.description_en || '' %></textarea>
          </div>
          <div class="form-group full">
            <label>Main Description (বাংলা)</label>
            <textarea name="description_bn" class="form-control"><%= content['about-header']?.description_bn || '' %></textarea>
          </div>
        </div>
        <button type="submit" class="btn btn-primary">💾 Save About Header</button>
      </form>
    </div>

    <div class="panel">
      <div class="panel-title">📊 Statistics</div>
      <form action="/admin/content/update" method="POST">
        <input type="hidden" name="section" value="about">
        <input type="hidden" name="key" value="about-stats">
        <p style="color:#64748b;font-size:13px;margin-bottom:16px;">Edit the key statistics shown on the About page (e.g., "10,000+ Clients", "15+ Years")</p>
        <div class="form-grid">
          <div class="form-group">
            <label>Stat 1 Value</label>
            <input type="text" name="stat1_value" value="<%= content['about-stats']?.stat1_value || '10,000+' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Stat 1 Label (EN)</label>
            <input type="text" name="stat1_label_en" value="<%= content['about-stats']?.stat1_label_en || 'Happy Clients' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Stat 2 Value</label>
            <input type="text" name="stat2_value" value="<%= content['about-stats']?.stat2_value || '15+' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Stat 2 Label (EN)</label>
            <input type="text" name="stat2_label_en" value="<%= content['about-stats']?.stat2_label_en || 'Years Experience' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Stat 3 Value</label>
            <input type="text" name="stat3_value" value="<%= content['about-stats']?.stat3_value || '50+' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Stat 3 Label (EN)</label>
            <input type="text" name="stat3_label_en" value="<%= content['about-stats']?.stat3_label_en || 'Countries' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Stat 4 Value</label>
            <input type="text" name="stat4_value" value="<%= content['about-stats']?.stat4_value || '5000+' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Stat 4 Label (EN)</label>
            <input type="text" name="stat4_label_en" value="<%= content['about-stats']?.stat4_label_en || 'Hajj Pilgrims' %>" class="form-control">
          </div>
        </div>
        <button type="submit" class="btn btn-primary">💾 Save Statistics</button>
      </form>
    </div>

    <div class="panel" style="background:#fef9c3;border:1px solid #fde68a;">
      <div class="panel-title">💡 Team/Founder management</div>
      <p style="font-size:14px;">Go to the <a href="/admin/team" style="color:#667eea;font-weight:600;">Team Members</a> section to manage the founder photo, Leadership team, and employee cards.</p>
    </div>

    <!-- Our Story Section -->
    <div class="panel">
      <div class="panel-title">📖 Our Story</div>
      <form action="/admin/content/update" method="POST" enctype="multipart/form-data" id="storyForm">
        <input type="hidden" name="section" value="about">
        <input type="hidden" name="key" value="about-story">
        <div class="form-grid">
          <div class="form-group">
            <label>Section Title (English)</label>
            <input type="text" name="title_en" value="<%= content['about-story']?.title_en || 'Our Story' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Section Title (বাংলা)</label>
            <input type="text" name="title_bn" value="<%= content['about-story']?.title_bn || 'আমাদের গল্প' %>" class="form-control">
          </div>
          <div class="form-group">
            <label>Section Tag (e.g., OUR STORY)</label>
            <input type="text" name="tag_en" value="<%= content['about-story']?.tag_en || 'OUR STORY' %>" class="form-control">
          </div>
          <div class="form-group full">
            <label>Featured Image</label>
            <% if (content['about-story']?.imageUrl) { %>
              <img src="<%= content['about-story'].imageUrl %>" style="max-height:100px; display:block; margin-bottom:10px; border-radius:6px;">
            <% } %>
            <input type="file" name="imageUrl" class="form-control" accept="image/*">
          </div>
          <div class="form-group full">
            <label>Story Quote (English)</label>
            <textarea name="quote_en" class="form-control"><%= content['about-story']?.quote_en || '' %></textarea>
          </div>
          <div class="form-group full">
            <label>Quote Citation (EN) - e.g. Name, Title</label>
            <input type="text" name="citation_en" value="<%= content['about-story']?.citation_en || '' %>" class="form-control">
          </div>
        </div>

        <div style="margin-top: 16px;">
          <label style="font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px; display: block;">Content (English)</label>
          <div id="quillEn" style="min-height: 200px; background: white;"><%- content['about-story']?.content_en || '' %></div>
          <textarea name="content_en" id="storyContentEn" style="display:none;"></textarea>
        </div>

        <div style="margin-top: 24px;">
          <label style="font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px; display: block;">Content (বাংলা)</label>
          <div id="quillBn" style="min-height: 200px; background: white;"><%- content['about-story']?.content_bn || '' %></div>
          <textarea name="content_bn" id="storyContentBn" style="display:none;"></textarea>
        </div>

        <button type="button" class="btn btn-primary" style="margin-top: 20px;" onclick="saveStory()">💾 Save Our Story</button>
      </form>
    </div>

    <% } %>

  </main>
</div>

<script>
  <% if (section === 'about') { %>
  // --- ABOUT PAGE SCRIPTS ---
  // Quill Editors Setup
  let quillEn, quillBn;
  if(document.getElementById('quillEn')) {
    quillEn = new Quill('#quillEn', { theme: 'snow' });
    quillBn = new Quill('#quillBn', { theme: 'snow' });
  }

  function saveStory() {
    document.getElementById('storyContentEn').value = quillEn.root.innerHTML;
    document.getElementById('storyContentBn').value = quillBn.root.innerHTML;
    document.getElementById('storyForm').submit();
  }

  <% } %>
</script>
</body>
</html>
