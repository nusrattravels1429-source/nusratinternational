<%- include('partials/header', { pageTitle: 'Hajj & Umrah Packages — Nusrat International', activePage: 'hajj', bodyClass: '', cssFiles: ['Hajj.css', 'common.css', 'cards.css', 'contact.css'] }) %>

<div class="page-hero hajj-hero">
  <div class="hero-badge">☪ SACRED JOURNEY</div>
  <h1>Hajj &amp; Umrah<br /><em>Packages</em></h1>
  <p>পবিত্র হজ ও উমরাহ প্যাকেজ — Journey to the house of Allah with complete peace of mind.</p>
  
</div>

<main>
  <section class="package-section hajj-bg" id="hajj">
   

    <div class="container">
      <% if (packages && packages.length > 0) { %>
        <% packages.forEach(pkg => { %>
          <%- include('partials/card', { pkg: pkg, type: 'hajj' }) %>
        <% }); %>
      <% } else { %>
        <p class="no-packages">No Hajj/Umrah packages are available at the moment.</p>
      <% } %>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
