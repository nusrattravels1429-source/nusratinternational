<%- include('partials/header', { pageTitle: 'Hajj & Umrah Packages', activePage: 'hajj', bodyClass: '' }) %>

<div class="page-hero hajj-hero">
  <div class="hero-badge">☪ SACRED JOURNEY</div>
  <h1>Hajj &amp; Umrah<br /><em>Packages</em></h1>
  <p>পবিত্র হজ ও উমরাহ প্যাকেজ — Journey to the house of Allah with complete peace of mind.</p>
  <div class="hero-stats">
    <div class="h-stat"><span>10,000+</span><small>Pilgrims Served</small></div>
    <div class="h-stat"><span>15+</span><small>Years Experience</small></div>
    <div class="h-stat"><span>100%</span><small>Visa Success</small></div>
  </div>
</div>

<main>
  <div class="container" id="packagesGrid">
    <% if (packages && packages.length > 0) { %>
      <% packages.forEach(pkg => { %>
        <div class="pkg-card hajj-card">
          <div class="pkg-img-wrap">
            <img src="<%= pkg.image %>" alt="<%= pkg.title_en %>" />
            <div class="pkg-price">$<%= pkg.price %></div>
            <div class="pkg-duration"><%= pkg.duration %></div>
            <div class="hajj-badge"><%= pkg.type || 'Hajj' %></div>
          </div>
          <div class="pkg-body">
            <div class="pkg-top">
              <div><h3><%= pkg.title_en %></h3><h4><%= pkg.title_bn || '' %></h4></div>
              <span class="rating">★ <%= pkg.rating || 0 %></span>
            </div>
            <p class="pkg-desc"><%= pkg.desc_en %></p>
            <a href="/hajj/<%= pkg._id %>"><button class="view-btn gold">View Details | বিস্তারিত দেখুন</button></a>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <p>No Hajj/Umrah packages are available at the moment.</p>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
